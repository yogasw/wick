package view

import "github.com/yogasw/wick/internal/entity"

// CustomPastePage is the entry of the paste flow: one big paste box
// behind two parser tabs. The cURL tab is the deterministic default;
// the AI tab renders only when an LLM provider is configured. Parse
// posts the box to /manager/connectors/custom/parse and, on success,
// the JS stores the returned draft in sessionStorage and navigates to
// the review page.
templ CustomPastePage(hasAI bool, user *entity.User) {
	@Layout("Manager · New custom connector", user) {
		<main class="mx-auto w-full max-w-container px-6 py-8" data-cc-paste data-parse-url="/manager/connectors/custom/parse" data-review-url="/manager/connectors/custom/new/review">
			<div class="flex items-center gap-2 text-sm text-black-700 dark:text-black-600">
				<a href="/manager/connectors" class="hover:text-green-600">Connectors</a>
				<span>/</span>
				<span>New custom</span>
				<span>/</span>
				<span class="text-black-900 dark:text-white-100">From paste</span>
			</div>
			<div class="mt-4">
				<h1 class="text-[1.375rem] font-semibold text-black-900 dark:text-white-100">New connector from paste</h1>
				<p class="mt-1 text-sm text-black-800 dark:text-black-600">
					Paste an HTTP call and wick extracts the connector definition. Both parsers feed the same review step.
				</p>
			</div>
			<section class="mt-6 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6">
				<!-- parser tabs -->
				<div class="flex w-fit items-center gap-1 rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 p-1">
					<button
						type="button"
						data-cc-tab="curl"
						class="rounded-lg px-3 py-1.5 text-sm font-medium text-black-800 dark:text-black-600 transition-colors"
					>📋 cURL parser</button>
					if hasAI {
						<button
							type="button"
							data-cc-tab="ai"
							class="rounded-lg px-3 py-1.5 text-sm font-medium text-black-800 dark:text-black-600 transition-colors"
						>✨ AI parser</button>
					}
				</div>
				<div data-cc-tab-help="curl" class="mt-3 text-sm text-black-800 dark:text-black-600">
					Deterministic, instant, no LLM call. Reads <code class="font-mono text-xs">-X</code>, <code class="font-mono text-xs">-H</code>, <code class="font-mono text-xs">-d</code>, <code class="font-mono text-xs">-u</code>, the URL, and the query string. Values that look like tokens are auto-flagged secret.
				</div>
				if hasAI {
					<div data-cc-tab-help="ai" class="mt-3 hidden text-sm text-black-800 dark:text-black-600">
						One LLM call. Accepts anything the cURL parser rejects: <code class="font-mono text-xs">fetch()</code> snippets, axios calls, raw API doc paragraphs, plain English. The raw paste is never persisted.
					</div>
				}
				<label class="mt-4 block text-xs font-medium text-black-800 dark:text-black-600" for="cc-paste-box">
					<span data-cc-paste-label>cURL command</span>
				</label>
				<textarea
					id="cc-paste-box"
					rows="10"
					placeholder="curl -X POST 'https://api.example.com/v1/items' -H 'Authorization: Bearer ...' -d 'name=demo'"
					class="mt-1 w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 font-mono text-xs text-black-900 dark:text-white-100 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800"
				></textarea>
				<p class="mt-1 text-[11px] text-black-700 dark:text-black-600">
					Tip: copy from browser DevTools → Network → Copy as cURL. One endpoint per paste, up to 8 KB.
				</p>
				<div data-cc-error class="mt-4 hidden rounded-lg border border-neg-400 bg-neg-100 px-4 py-3">
					<p class="text-sm font-medium text-neg-400">✗ <span data-cc-error-text></span></p>
					<p class="mt-1 text-xs text-black-800">
						Common causes: paste too short or over 8 KB, multiple endpoints mixed in, non-HTTP content. Trim it down to a single endpoint
						if hasAI {
							or switch parser tabs
						}
						and try again.
					</p>
				</div>
				<div class="mt-6 flex items-center justify-between">
					<a href="/manager/connectors" class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm font-medium text-black-800 dark:text-black-600 hover:border-green-400 hover:text-green-600">← Cancel</a>
					<button
						type="button"
						data-cc-parse
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 disabled:cursor-not-allowed disabled:opacity-60"
					>Parse →</button>
				</div>
			</section>
		</main>
		<script src="/modules/manager/js/custom_paste.js"></script>
	}
}
