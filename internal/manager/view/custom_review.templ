package view

import "github.com/yogasw/wick/internal/entity"

// customSaveURL picks the save endpoint for the draft form: the create
// endpoint for new drafts, the per-def update endpoint when editing.
func customSaveURL(mode, defID string) string {
	if mode == "edit" {
		return "/manager/connectors/custom/" + defID + "/save"
	}
	return "/manager/connectors/custom/save"
}

// CustomReviewPage renders the review form for a custom connector
// draft. mode "new" loads the draft from sessionStorage (stored there
// by the paste / import JS); mode "edit" embeds the stored definition
// as JSON. The form itself is rendered client-side by custom_review.js
// into the containers customDraftForm lays out.
templ CustomReviewPage(mode string, defID string, draft any, categories []string, info *CustomDefInfo, user *entity.User) {
	@Layout("Manager · Review custom connector", user) {
		<main class="mx-auto w-full max-w-container px-6 py-8">
			<div class="flex items-center gap-2 text-sm text-black-700 dark:text-black-600">
				<a href="/manager/connectors" class="hover:text-green-600">Connectors</a>
				<span>/</span>
				if mode == "edit" {
					<span class="text-black-900 dark:text-white-100">Edit definition</span>
				} else {
					<span>New custom</span>
					<span>/</span>
					<span class="text-black-900 dark:text-white-100">Review</span>
				}
			</div>
			<!-- Sticky action toolbar — title left, all actions top-right so
			     they never scroll out of reach on a long form. -->
			<div class="sticky top-16 z-30 mt-3 -mx-6 border-b border-white-300 bg-white-200 px-6 py-3 dark:border-navy-600 dark:bg-navy-800">
				<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
					<h1 class="min-w-0 truncate text-lg font-semibold text-black-900 dark:text-white-100">
						if mode == "edit" {
							Edit connector definition
						} else {
							Review extracted definition
						}
					</h1>
					<div class="flex flex-wrap items-center gap-2 sm:flex-shrink-0">
						if mode == "edit" && info != nil {
							if info.Disabled {
								<form method="POST" action={ templ.SafeURL("/manager/connectors/custom/" + info.DefID + "/enable") }>
									<button type="submit" class="rounded-lg border border-green-500 px-4 py-2 text-sm font-medium text-green-600 transition-colors hover:bg-green-50 dark:text-green-400 dark:hover:bg-green-900/20">Enable</button>
								</form>
							} else {
								<form method="POST" action={ templ.SafeURL("/manager/connectors/custom/" + info.DefID + "/disable") }>
									<button type="submit" class="rounded-lg border border-cau-400 px-4 py-2 text-sm font-medium text-cau-400 transition-colors hover:bg-cau-100">Disable</button>
								</form>
							}
							<form
								method="POST"
								action={ templ.SafeURL("/manager/connectors/custom/" + info.DefID + "/delete") }
								onsubmit="return confirm('Delete this custom connector definition and its instances? This cannot be undone.')"
							>
								<button type="submit" class="rounded-lg border border-neg-400 px-4 py-2 text-sm font-medium text-neg-400 transition-colors hover:bg-neg-100">Delete</button>
							</form>
						}
						<button
							type="button"
							data-cc-save
							class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 shadow-sm transition-colors hover:bg-green-600 disabled:cursor-not-allowed disabled:opacity-60"
						>
							if mode == "edit" {
								Save changes
							} else {
								Save connector →
							}
						</button>
					</div>
				</div>
			</div>
			<p class="mt-3 text-sm text-black-800 dark:text-black-600">
				if mode == "edit" {
					The key is immutable. Saving marks the definition dirty — the live executor keeps serving until you reload it.
				} else {
					Rename keys, adjust widgets, and toggle secrets before saving. The right panel previews the stored row.
				}
			</p>
			if draft != nil {
				@templ.JSONScript("cc-draft", draft)
			}
			@customDraftForm(mode, defID, categories)
		</main>
		<script src="/modules/manager/js/vendor_emoji_mart.js"></script>
		<script src="/modules/manager/js/icon_picker.js"></script>
		<script src="/modules/manager/js/custom_review.js"></script>
	}
}

// customDraftForm is the shared draft editor used by the review page
// and the manual builder. Static shell only — rows, op cards, and the
// JSON preview are rendered by custom_review.js from the draft.
templ customDraftForm(mode string, defID string, categories []string) {
	<div
		data-cc-review
		data-mode={ mode }
		data-save-url={ customSaveURL(mode, defID) }
		class="mt-6"
	>
		<!-- Meta -->
		<section data-cc-section="meta" class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6">
			<div class="grid grid-cols-12 gap-4">
				<div class="col-span-12 sm:col-span-2">
					<label class="block text-xs font-medium text-black-800 dark:text-black-600">Icon</label>
					@IconPicker("cc-icon")
				</div>
				<div class="col-span-12 sm:col-span-4">
					<label class="block text-xs font-medium text-black-800 dark:text-black-600">Key (slug, unique)</label>
					if mode == "edit" {
						<input id="cc-key" type="text" disabled class="mt-1 w-full cursor-not-allowed rounded-lg border border-white-400 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-3 py-2 font-mono text-sm text-black-700 dark:text-black-600 outline-none"/>
						<p class="mt-1 text-[11px] text-black-700 dark:text-black-600">Immutable after create.</p>
					} else {
						<input id="cc-key" type="text" placeholder="my_api" class="mt-1 w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 font-mono text-sm text-black-900 dark:text-white-100 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800"/>
						<p class="mt-1 text-[11px] text-black-700 dark:text-black-600">Used in the MCP tool id. Lowercase slug.</p>
					}
				</div>
				<div class="col-span-12 sm:col-span-6">
					<label class="block text-xs font-medium text-black-800 dark:text-black-600">Display name</label>
					<input id="cc-name" type="text" placeholder="My API" class="mt-1 w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800"/>
				</div>
				<div class="col-span-12">
					<label class="block text-xs font-medium text-black-800 dark:text-black-600">Description</label>
					<input id="cc-desc" type="text" placeholder="What this connector does, shown to the LLM and on cards." class="mt-1 w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800"/>
				</div>
			</div>
		</section>
		<!-- Access + behavior — kept near the top so identity, access, and
		     behavior are decided before the detailed configs/operations. -->
		<section data-cc-section="access" class="mt-6 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6">
			<h2 class="text-base font-semibold text-black-900 dark:text-white-100">Access &amp; behavior</h2>
			<p class="mt-1 text-sm text-black-800 dark:text-black-600">
				Wick auto-creates the filter tag
				<span class="mx-1 inline-flex items-center rounded-full border border-green-500 bg-green-200 px-2.5 py-0.5 font-mono text-[11px] font-medium text-green-700"><span id="cc-tag-name">custom:…</span></span>
				on save. You can open it up later under <code class="font-mono text-xs">/admin/tags</code>.
			</p>
			<div class="mt-4 max-w-xs">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600">Category (visual group on the connector index)</label>
				<select id="cc-category" class="mt-1 w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800">
					<option value="">Other (no category)</option>
					for _, c := range categories {
						<option value={ c }>{ c }</option>
					}
				</select>
			</div>
			<div class="mt-4 divide-y divide-white-300 rounded-xl border border-white-300 dark:divide-navy-600 dark:border-navy-600">
				@ccToggleRow("cc-single", "Single instance only", "Default off — like built-in connectors, admins can add and duplicate instance rows, each with its own credentials. No row is created until someone clicks + New row.")
				@ccToggleRow("cc-allow-session-config", "Allow per-session config override", "Default off. When on, this connector can be cloned into a per-session instance from the session Config tab (point at staging, use a different key) without touching the saved instance. An admin still flips the per-instance toggle. Best for API connectors — leave off for OAuth/SSO logins.")
			</div>
			<div class="mt-4 rounded-lg border border-cau-400 bg-cau-100 px-4 py-3">
				<p class="text-xs text-black-800">
					<span class="font-semibold text-cau-400">⚠ Default = admin-only.</span>
					No user carries the auto-created tag at save, so non-admins cannot see or call this connector. Grant access by assigning the tag to user groups at <code class="font-mono text-xs">/admin/tags</code>, or remove the filter tag to open it to all approved users.
				</p>
			</div>
		</section>
		<div data-cc-grid class="mt-6 grid grid-cols-12 gap-6">
			<!-- LEFT: editable fields -->
			<div data-cc-editor class="col-span-12 space-y-6 lg:col-span-7">
				<section data-cc-section="configs" class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6">
					<div class="flex items-center justify-between gap-3">
						<h2 class="text-base font-semibold text-black-900 dark:text-white-100">Configs</h2>
						<button type="button" data-cc-add-config class="inline-flex items-center gap-1 rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:border-green-400 hover:text-green-600">+ Add field</button>
					</div>
					<p class="mt-1 text-sm text-black-800 dark:text-black-600">Stable per-instance values such as base URLs and credentials. Secret fields encrypt at rest and mask in MCP responses.</p>
					<div id="cc-configs" class="mt-4 space-y-2"></div>
				</section>
				<section data-cc-section="ops" class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6">
					<div class="flex items-center justify-between gap-3">
						<h2 class="text-base font-semibold text-black-900 dark:text-white-100">Operations</h2>
						<button type="button" data-cc-add-op class="inline-flex items-center gap-1 rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:border-green-400 hover:text-green-600">+ Add operation</button>
					</div>
					<p class="mt-1 text-sm text-black-800 dark:text-black-600">Inputs are per-call values the LLM provides. Templates render against <code class="font-mono text-xs">&#123;&#123;.cfg.*&#125;&#125;</code> and <code class="font-mono text-xs">&#123;&#123;.in.*&#125;&#125;</code>.</p>
					<div id="cc-ops" class="mt-4 space-y-4"></div>
				</section>
			</div>
			<!-- RIGHT: navigator (Jump + JSON). Docked sticky on desktop;
			     off-canvas slide-over on mobile (opened by the floating Jump
			     button). Hideable so it's out of the way while editing. -->
			<div data-cc-nav-col class="col-span-12 lg:col-span-5">
				<div data-cc-nav-backdrop class="fixed inset-0 z-40 hidden bg-black/40 lg:hidden"></div>
				<div
					data-cc-nav
					class="fixed inset-y-0 right-0 z-50 flex w-[22rem] max-w-[85vw] translate-x-full flex-col border-l border-white-300 bg-white-100 shadow-xl transition-transform dark:border-navy-600 dark:bg-navy-700 lg:sticky lg:inset-y-auto lg:top-36 lg:z-auto lg:max-h-[calc(100vh-11rem)] lg:w-auto lg:max-w-none lg:translate-x-0 lg:rounded-xl lg:shadow-none lg:transition-none"
				>
					<div class="flex items-center justify-between gap-2 border-b border-white-300 px-3 py-2 dark:border-navy-600">
						<div class="flex items-center gap-1">
							<button type="button" data-cc-nav-tab="jump" class="rounded-lg px-3 py-1.5 text-xs font-medium">Jump</button>
							<button type="button" data-cc-nav-tab="json" class="rounded-lg px-3 py-1.5 text-xs font-medium">JSON</button>
						</div>
						<button type="button" data-cc-nav-close title="Hide panel" class="rounded-lg p-1.5 text-black-700 transition-colors hover:bg-white-200 hover:text-green-600 dark:text-black-600 dark:hover:bg-navy-800">
							<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M4 4l8 8M12 4l-8 8" stroke-linecap="round"></path></svg>
						</button>
					</div>
					<div class="min-h-0 flex-1 overflow-y-auto">
						<div data-cc-nav-jump class="p-2"></div>
						<div data-cc-nav-json class="hidden p-2">
							<pre id="cc-preview" class="overflow-auto rounded-lg bg-navy-800 p-4 font-mono text-xs leading-relaxed text-white-100"></pre>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- Floating opener: mobile always; desktop only when the panel is
		     collapsed (toggled by JS). -->
		<button
			type="button"
			data-cc-nav-open
			class="fixed bottom-4 right-4 z-30 inline-flex items-center gap-1.5 rounded-full bg-green-500 px-4 py-2.5 text-sm font-medium text-white-100 shadow-lg transition-colors hover:bg-green-600 lg:hidden"
		>
			<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h10M4 18h7" stroke-linecap="round"></path></svg>
			Jump
		</button>
		<!-- Error -->
		<div data-cc-error class="mt-4 hidden rounded-lg border border-neg-400 bg-neg-100 px-4 py-3">
			<p class="text-sm font-medium text-neg-400">✗ <span data-cc-error-text></span></p>
		</div>
	</div>
}

// ccToggleRow renders one labeled switch row in the builder, matching the
// Access Policy toggle style on the connector detail page. The checkbox
// carries an id (not a name) so custom_review.js reads/sets it from the
// draft; there is no form submit here.
templ ccToggleRow(id, label, description string) {
	<label class="flex cursor-pointer items-center justify-between gap-4 px-4 py-3 hover:bg-white-200 dark:hover:bg-navy-800">
		<div class="min-w-0 flex-1">
			<p class="text-sm font-medium text-black-900 dark:text-white-100">{ label }</p>
			<p class="mt-0.5 text-xs text-black-700 dark:text-black-600">{ description }</p>
		</div>
		<div class="relative ml-4 flex-shrink-0">
			<input id={ id } type="checkbox" class="peer sr-only"/>
			<div class="h-5 w-9 rounded-full bg-white-400 transition-colors peer-checked:bg-green-500 dark:bg-navy-600"></div>
			<div class="absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white-100 shadow transition-transform peer-checked:translate-x-4"></div>
		</div>
	</label>
}
