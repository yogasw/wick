package view

import (
	"fmt"

	"github.com/yogasw/wick/internal/entity"
)

// ConnectorsIndexPage lists every connector definition, grouped by
// category tag into bordered group cards (same chrome as the home page),
// with a search box and category filter chips. It is the destination of
// the single "Connectors" launcher on the home page: the connector set is
// expected to grow large, so this page stays browsable while the home
// grid stays clean.
templ ConnectorsIndexPage(groups []ConnectorIndexGroup, user *entity.User) {
	@Layout("Manager · Connectors", user) {
		<main class="mx-auto w-full max-w-container px-6 py-8">
			<div class="flex items-center gap-2 text-sm text-black-700 dark:text-black-600">
				<a href="/" class="hover:text-green-600">Home</a>
				<span>/</span>
				<span class="text-black-900 dark:text-white-100">Connectors</span>
			</div>
			<!-- Header -->
			<div class="mt-4 flex items-center gap-3">
				<div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-green-200 dark:bg-green-800 text-lg font-semibold text-green-700 dark:text-green-300">
					🔌
				</div>
				<div>
					<h1 class="text-[1.375rem] font-semibold text-black-900 dark:text-white-100">Connectors</h1>
					<p class="mt-0.5 text-sm text-black-800 dark:text-black-600">
						LLM-callable connectors that wrap external APIs. Pick one to manage its instances and operations.
					</p>
				</div>
			</div>
			if len(groups) == 0 {
				<div class="mt-8 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-8 text-center">
					<p class="text-sm text-black-700 dark:text-black-600">No connectors available.</p>
				</div>
			} else {
				<!-- Search -->
				<div class="mt-6 flex max-w-lg items-center gap-3 rounded-xl border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-4 py-3 shadow-sm focus-within:border-green-500 focus-within:ring-2 focus-within:ring-green-200 dark:focus-within:ring-green-800 transition-all">
					<svg class="h-5 w-5 flex-shrink-0 text-black-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<circle cx="11" cy="11" r="8"></circle>
						<path d="m21 21-4.35-4.35"></path>
					</svg>
					<input
						id="search"
						type="text"
						placeholder="Search connectors…"
						oninput="filterConnectors(this.value)"
						class="flex-1 bg-transparent text-sm text-black-900 dark:text-white-100 placeholder:text-black-700 outline-none"
					/>
					<kbd class="hidden sm:inline-flex items-center rounded border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-2 py-0.5 text-xs text-black-700 dark:text-black-600 font-mono">/</kbd>
				</div>
				<!-- Filter chips -->
				<div class="mt-4 flex flex-wrap items-center gap-2">
					@connectorChip("all", "All")
					for _, g := range groups {
						@connectorChip(g.Name, g.Name)
					}
				</div>
				<!-- Grouped category boxes (home chrome). Two layout modes,
				     switched by connectors_index.js:
				       • browse (default, All + no search): boxes sit side by
				         side in a page grid and cards stack inside each box —
				         compact, like the home page, no big empty gaps.
				       • filter (a chip active or search typed): boxes go full
				         width and cards spread across an auto-fill grid so the
				         result fans out instead of stacking into one column. -->
				<div id="groups" class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
					for _, g := range groups {
						<section data-group data-group-name={ g.Name } class="flex flex-col rounded-2xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm">
							<header class="mb-4">
								<h2 class="text-base font-semibold text-black-900 dark:text-white-100">{ g.Name }</h2>
								if g.Description != "" {
									<p class="mt-0.5 text-xs text-black-700 dark:text-black-600">{ g.Description }</p>
								}
							</header>
							<div data-cards class="grid gap-3 grid-cols-1">
								for _, c := range g.Cards {
									@connectorIndexCard(c)
								}
							</div>
						</section>
					}
				</div>
				<p id="no-results" class="hidden mt-12 text-center text-sm text-black-700 dark:text-black-600">
					No connectors match your search.
				</p>
			}
		</main>
		<script src="/modules/manager/js/connectors_index.js"></script>
	}
}

templ connectorChip(value, label string) {
	<button
		type="button"
		data-chip={ value }
		class="rounded-full border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-3 py-1 text-xs font-medium text-black-800 dark:text-black-600 transition-colors hover:border-green-400"
	>
		{ label }
	</button>
}

templ connectorIndexCard(c ConnectorIndexCard) {
	<a
		data-conn-card
		data-name={ c.Name }
		data-desc={ c.Description }
		data-tags={ c.Category }
		data-category={ c.Category }
		href={ templ.SafeURL("/manager/connectors/" + c.Key) }
		class="flex h-full items-start gap-3 rounded-xl border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 p-4 shadow-sm transition-all duration-150 hover:-translate-y-px hover:border-green-400 hover:shadow-md"
	>
		<div class="relative flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-green-200 dark:bg-green-800 text-lg font-semibold text-green-700 dark:text-green-300">
			{ c.Icon }
			<span class="absolute -right-1 -bottom-1 flex h-4 w-4 items-center justify-center rounded-full bg-green-200 dark:bg-green-800 text-[8px] shadow-sm" aria-label="LLM connector">🔌</span>
		</div>
		<div class="min-w-0 flex-1">
			<div class="flex items-center gap-2">
				<p class="truncate text-sm font-semibold text-black-900 dark:text-white-100">{ c.Name }</p>
				if c.System {
					<span class="flex-shrink-0 rounded-full bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-[10px] font-medium text-black-800 dark:text-black-600">System</span>
				}
			</div>
			if c.Description != "" {
				<p class="mt-1 text-xs leading-relaxed text-black-700 dark:text-black-600">{ c.Description }</p>
			}
			<p class="mt-2 text-xs text-black-700 dark:text-black-600">
				{ fmt.Sprintf("%d operation(s) · %d active", c.OpCount, c.ActiveCount) }
				if c.NeedsSetupCount > 0 {
					<span class="font-medium text-cau-400">{ fmt.Sprintf(" · %d needs setup", c.NeedsSetupCount) }</span>
				}
				if c.DisabledCount > 0 {
					<span class="font-medium text-neg-400">{ fmt.Sprintf(" · %d disabled", c.DisabledCount) }</span>
				}
			</p>
		</div>
	</a>
}
