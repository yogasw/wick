package fieldtype

import "github.com/yogasw/wick/internal/entity"

templ Textarea(row entity.Config) {
	<textarea
		name="value"
		rows="4"
		placeholder={ placeholderFor(row) }
		class="w-96 rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100 placeholder:text-black-700 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800"
	>{ valueFor(row) }</textarea>
}
