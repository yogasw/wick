package view

import (
	"fmt"
	"net/url"

	managerview "github.com/yogasw/wick/internal/manager/view"
)

templ ProviderDetailPage(vm ProviderDetailVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-4">
			<!-- Header -->
			<div class="flex items-center justify-between gap-3">
				<div class="flex items-center gap-3">
					<a href={ templ.SafeURL(vm.Base + "/providers") } class="text-xs text-black-700 dark:text-black-600 hover:underline">← Providers</a>
					<span class="text-black-400 dark:text-black-600">/</span>
					<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">{ string(vm.Status.Instance.Type) }/{ vm.Status.Instance.Name }</h1>
					if !vm.Status.PathFound {
						<span class="rounded bg-red-100 dark:bg-red-900 px-2 py-0.5 text-xs font-medium text-red-700 dark:text-red-300">not found</span>
					} else {
						<span class="rounded bg-green-100 dark:bg-green-900 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-300">{ vm.Status.Version }</span>
					}
					if vm.ActiveCount > 0 {
						<span class="rounded bg-blue-100 dark:bg-blue-900 px-2 py-0.5 text-xs font-medium text-blue-700 dark:text-blue-300">{ fmt.Sprintf("%d active", vm.ActiveCount) }</span>
					}
				</div>
				<form method="POST" action={ templ.SafeURL(vm.ActionBase + "/disabled") }>
					<input type="hidden" name="value" value={ func() string { if vm.Status.Instance.Disabled { return "false" }; return "true" }() }/>
					if vm.Status.Instance.Disabled {
						<button type="submit" class="flex items-center gap-2 rounded-lg border border-amber-400 dark:border-amber-700 px-3 py-1.5 text-xs font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/20">
							<span class="inline-block w-2 h-2 rounded-full bg-amber-500"></span>
							Disabled — click to enable
						</button>
					} else {
						<button type="submit" class="flex items-center gap-2 rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">
							<span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
							Enabled — click to disable
						</button>
					}
				</form>
			</div>
			<!-- Flash / error -->
			if vm.Flash == "saved" {
				<div class="rounded-lg bg-green-100 dark:bg-green-900 px-4 py-2 text-sm text-green-700 dark:text-green-300">Settings saved.</div>
			}
			if vm.Error != "" {
				<div class="rounded-lg bg-red-100 dark:bg-red-900 px-4 py-2 text-sm text-red-700 dark:text-red-300">{ vm.Error }</div>
			}
			<!-- Binary info -->
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 space-y-1 text-xs">
				<div class="flex gap-2">
					<span class="w-20 text-black-700 dark:text-black-600">resolved</span>
					if vm.Status.Path != "" {
						<span class="font-mono text-black-900 dark:text-white-100 break-all">{ vm.Status.Path }</span>
					} else {
						<span class="text-black-600 dark:text-black-700">—</span>
					}
				</div>
				if vm.Status.VersionErr != "" {
					<div class="flex gap-2">
						<span class="w-20 text-black-700 dark:text-black-600">error</span>
						<span class="font-mono text-red-600 dark:text-red-400 break-all">{ vm.Status.VersionErr }</span>
					</div>
				}
			</div>
			<!-- Settings -->
			@managerview.ConfigsTableFull(vm.Rows, vm.ActionBase)
			<!-- Command Gate -->
			@providerGateCard(vm.Base, vm.Status, vm.Gate)
			<!-- Active processes -->
			if len(vm.ActivePIDs) > 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
					<div class="px-5 py-3 border-b border-white-300 dark:border-navy-600 flex items-center justify-between">
						<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Active Processes</h2>
						<span class="rounded bg-blue-100 dark:bg-blue-900 px-2 py-0.5 text-xs font-medium text-blue-700 dark:text-blue-300">{ fmt.Sprintf("%d", len(vm.ActivePIDs)) }</span>
					</div>
					<table class="w-full text-xs">
						<thead>
							<tr class="border-b border-white-300 dark:border-navy-600 text-black-700 dark:text-black-600">
								<th class="px-5 py-2 text-left font-medium">Session</th>
								<th class="px-5 py-2 text-left font-medium">PID</th>
								<th class="px-5 py-2 text-left font-medium">State</th>
								<th class="px-5 py-2 text-right font-medium">Action</th>
							</tr>
						</thead>
						<tbody>
							for _, p := range vm.ActivePIDs {
								<tr class="border-b border-white-300 dark:border-navy-600 last:border-0 hover:bg-white-200 dark:hover:bg-navy-800">
									<td class="px-5 py-2 font-mono text-black-900 dark:text-white-100">{ p.SessionID[:min(8, len(p.SessionID))] }</td>
									<td class="px-5 py-2 font-mono text-black-700 dark:text-black-600">
										if p.PID > 0 {
											{ fmt.Sprintf("%d", p.PID) }
										} else {
											—
										}
									</td>
									<td class="px-5 py-2">@lifecycleBadge(p.Lifecycle, p.PID, 0, 0)</td>
									<td class="px-5 py-2 text-right">
										<button
											data-kill-session={ p.SessionID }
											class="kill-process-btn rounded px-2 py-1 text-xs font-medium bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300 hover:bg-red-200 dark:hover:bg-red-800 transition-colors"
										>Kill</button>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			<!-- Recent spawns -->
			<details data-remember-open={ "spawns-" + string(vm.Status.Instance.Type) + "-" + vm.Status.Instance.Name } class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden group">
				<summary class="px-5 py-3 flex items-center gap-2 cursor-pointer list-none select-none hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
					<svg class="w-3.5 h-3.5 text-black-700 dark:text-black-600 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Recent Spawns</h2>
					if len(vm.Spawns) > 0 {
						<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">{ fmt.Sprintf("%d", len(vm.Spawns)) }</span>
					}
				</summary>
				if len(vm.Spawns) == 0 {
					<div class="px-5 py-8 text-center text-sm text-black-700 dark:text-black-600">No spawns recorded yet.</div>
				} else {
					<table class="w-full text-xs">
						<thead>
							<tr class="border-b border-white-300 dark:border-navy-600 text-black-700 dark:text-black-600">
								<th class="px-5 py-2.5 text-left">Started</th>
								<th class="px-5 py-2.5 text-left">Session</th>
								<th class="px-5 py-2.5 text-left">PID</th>
								<th class="px-5 py-2.5 text-left">Status</th>
								<th class="px-5 py-2.5 text-left">First Message</th>
							</tr>
						</thead>
						<tbody>
							for _, s := range vm.Spawns {
								<tr class="border-b border-white-300 dark:border-navy-600 last:border-0 hover:bg-white-200 dark:hover:bg-navy-800 cursor-pointer" onclick={ templ.ComponentScript{Call: fmt.Sprintf("window.location='%s/providers/spawns/%s'", vm.Base, url.PathEscape(filenameOf(s.Path)))} }>
									<td class="px-5 py-2 font-mono text-black-700 dark:text-black-600 whitespace-nowrap">{ s.StartedAt.Format("2006-01-02 15:04:05") }</td>
									<td class="px-5 py-2 font-mono text-black-900 dark:text-white-100">{ shortID(s.SessionID) }</td>
									<td class="px-5 py-2 font-mono text-black-700 dark:text-black-600">
										if s.PID > 0 {
											{ fmt.Sprintf("%d", s.PID) }
										} else {
											—
										}
									</td>
									<td class="px-5 py-2">
										if s.ExitReason == "" {
											<span class="rounded bg-green-100 dark:bg-green-900 px-1.5 py-0.5 text-xs text-green-700 dark:text-green-300">running</span>
										} else if s.ExitReason == "unclean" {
											<span class="rounded bg-red-100 dark:bg-red-900 px-1.5 py-0.5 text-xs text-red-700 dark:text-red-300">unclean exit</span>
										} else {
											<span class="rounded bg-white-300 dark:bg-navy-600 px-1.5 py-0.5 text-xs text-black-700 dark:text-black-600">{ s.ExitReason }</span>
										}
									</td>
									<td class="px-5 py-2 text-black-700 dark:text-black-600 max-w-xs truncate">{ s.FirstUserMessage }</td>
								</tr>
							}
						</tbody>
					</table>
					if vm.Page > 1 || vm.HasNext {
						<div class="flex items-center justify-between border-t border-white-300 dark:border-navy-600 px-5 py-3">
							if vm.Page > 1 {
								<a href={ templ.SafeURL(fmt.Sprintf("%s/providers/%s/%s?page=%d", vm.Base, string(vm.Status.Instance.Type), vm.Status.Instance.Name, vm.Page-1)) } class="text-sm text-green-600 dark:text-green-400 hover:underline">← Prev</a>
							} else {
								<span></span>
							}
							<span class="text-xs text-black-700 dark:text-black-600">Page { fmt.Sprintf("%d", vm.Page) }</span>
							if vm.HasNext {
								<a href={ templ.SafeURL(fmt.Sprintf("%s/providers/%s/%s?page=%d", vm.Base, string(vm.Status.Instance.Type), vm.Status.Instance.Name, vm.Page+1)) } class="text-sm text-green-600 dark:text-green-400 hover:underline">Next →</a>
							} else {
								<span></span>
							}
						</div>
					}
				}
			</details>
		</div>
		<script>
		document.addEventListener('click', function(e) {
			var btn = e.target.closest('.kill-process-btn');
			if (!btn) return;
			var sid = btn.dataset.killSession;
			var base = document.querySelector('meta[name="wick-base"]')?.content || '';
			if (!sid || !confirm('Kill this process?')) return;
			fetch(base + '/tools/agents/sessions/' + encodeURIComponent(sid) + '/kill', { method: 'POST', credentials: 'include' })
				.then(function() { location.reload(); });
		});
		</script>
	}
}
