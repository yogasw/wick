package view

// ProvidersSPAVM feeds the thin-shell that hosts the providers SPA
// inside the standard agents layout. AssetURL is the hashed Vite bundle
// path resolved at boot via spaAssetURL("providers").
type ProvidersSPAVM struct {
	Layout   AgentsLayoutVM
	Base     string
	AssetURL string
}

// ProvidersSPA renders the providers SPA shell inside the agents chrome.
// The SPA reads data-base from the #app div and uses it as the prefix for
// all API calls (e.g. ${base}/api/providers).
templ ProvidersSPA(vm ProvidersSPAVM) {
	@AgentsLayout(vm.Layout) {
		if vm.AssetURL == "" {
			<div class="p-8 text-sm text-rose-600 dark:text-rose-400">
				Providers bundle not built yet. Run
				<code class="font-mono">npm --workspace=@wick-fe/agents-providers run build</code>
				in <code class="font-mono">fe/</code> and refresh.
			</div>
		} else {
			<div
				id="app"
				data-base={ vm.Base }
				class="h-full"
			></div>
			<script type="module" src={ vm.AssetURL }></script>
		}
	}
}
