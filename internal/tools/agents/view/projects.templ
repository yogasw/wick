package view

// ProjectSettingsPage is the full project settings page (mockup ④):
// icon header + editable name, folder (managed/custom radio), defaults,
// pinned sessions, and a meta.json preview. Navigable, not a modal.
templ ProjectSettingsPage(vm ProjectSettingsVM) {
	@AgentsLayout(vm.Layout) {
		<div class="max-w-5xl mx-auto space-y-5">
			<a href={ templ.SafeURL(vm.BackHref()) } class="text-xs text-black-600 dark:text-black-700 hover:text-black-900 dark:hover:text-white-100 transition-colors">← Back</a>
			<form method="POST" action={ templ.SafeURL(vm.Action) } data-project-form class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm p-6 space-y-6">
				<!-- Header: icon + name + meta + delete -->
				<div class="flex items-center gap-3 pb-4 border-b border-white-300 dark:border-navy-600">
					<input
						type="text"
						name="icon"
						maxlength="2"
						value={ vm.Icon }
						class="w-12 h-12 rounded-xl bg-white-200 dark:bg-navy-800 text-center text-2xl outline-none border border-transparent focus:border-green-400"
					/>
					<div class="min-w-0">
						<input
							type="text"
							name="name"
							required
							value={ vm.Name }
							placeholder="Project name"
							class="text-2xl font-bold bg-transparent text-black-900 dark:text-white-100 outline-none border-b border-transparent focus:border-green-400 w-full"
						/>
						if !vm.IsNew {
							<p class="text-xs text-black-600 dark:text-black-700">{ fmtCount(vm.ChatCount) } chats · created { vm.CreatedAt }</p>
						}
					</div>
					if !vm.IsNew && !vm.IsDefault {
						<button
							type="button"
							data-delete-project={ vm.ID }
							data-redirect={ vm.Base + "/sessions" }
							class="ml-auto text-xs px-3 py-1.5 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-md border border-red-200 dark:border-red-800 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors"
						>Delete project</button>
					}
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<!-- Left: folder + defaults -->
					<div class="space-y-6">
						<div>
							<h4 class="font-bold text-sm mb-2 text-black-900 dark:text-white-100">Folder</h4>
							<div class="border border-white-300 dark:border-navy-600 rounded-lg p-3 space-y-2">
								<label class="flex items-center gap-2 text-sm cursor-pointer">
									if !vm.Managed {
										<input type="radio" name="folder_mode" value="custom" checked data-folder-mode class="text-green-500 focus:ring-green-500"/>
									} else {
										<input type="radio" name="folder_mode" value="custom" data-folder-mode class="text-green-500 focus:ring-green-500"/>
									}
									<span class="font-semibold text-black-900 dark:text-white-100">Custom path</span>
									<span class="rounded bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 px-1.5 py-0.5 text-[10px] font-bold uppercase">custom</span>
								</label>
								<div data-custom-path-fields class={ templ.KV("hidden", vm.Managed) }>
									<div class="flex gap-2">
										<input
											type="text"
											name="custom_path"
											data-custom-path-input
											value={ vm.CustomPath }
											placeholder="D:/code/work/wick"
											class="flex-1 rounded-md border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-2 py-1.5 text-xs font-mono text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none"
										/>
										<label class="rounded-md border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 cursor-pointer transition-colors whitespace-nowrap">
											Choose…
											<input type="file" data-folder-picker webkitdirectory directory multiple class="hidden"/>
										</label>
									</div>
									<p data-custom-path-error class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
									<p class="text-xs text-black-600 dark:text-black-700 mt-1">Absolute path to an existing folder. Wick uses this as the agent cwd. Browsers hide absolute paths — the picker fills only the folder name, prefix the parent manually.</p>
								</div>
								<label class="flex items-center gap-2 text-sm cursor-pointer mt-3 pt-3 border-t border-white-300 dark:border-navy-600">
									if vm.Managed {
										<input type="radio" name="folder_mode" value="managed" checked data-folder-mode class="text-green-500 focus:ring-green-500"/>
									} else {
										<input type="radio" name="folder_mode" value="managed" data-folder-mode class="text-green-500 focus:ring-green-500"/>
									}
									<span class="font-semibold text-black-900 dark:text-white-100">Managed</span>
									<span class="rounded bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 px-1.5 py-0.5 text-[10px] font-bold uppercase">managed</span>
								</label>
								<p class="text-xs text-black-600 dark:text-black-700">Wick creates and owns the folder at <code class="font-mono">projects/&lt;id&gt;/files/</code>. Useful for scratch sessions.</p>
							</div>
						</div>
						<div>
							<h4 class="font-bold text-sm mb-2 text-black-900 dark:text-white-100">Defaults</h4>
							<div class="space-y-3">
								<div>
									<label class="block text-black-600 dark:text-black-700 text-xs mb-0.5">Provider</label>
									<select name="provider" class="w-full rounded-md border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-2 py-1.5 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none">
										@providerOption("claude", "Claude", vm.DefaultProvider)
										@providerOption("codex", "Codex", vm.DefaultProvider)
										@providerOption("gemini", "Gemini", vm.DefaultProvider)
									</select>
								</div>
								<div>
									<label class="block text-black-600 dark:text-black-700 text-xs mb-0.5">Preset</label>
									<select name="preset" class="w-full rounded-md border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-2 py-1.5 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none">
										@presetOption("default", vm.DefaultPreset)
										for _, name := range vm.PresetList {
											if name != "default" {
												@presetOption(name, vm.DefaultPreset)
											}
										}
									</select>
								</div>
								<div>
									<label class="block text-black-600 dark:text-black-700 text-xs mb-0.5">System prompt addon</label>
									<textarea
										name="system_addon"
										rows="3"
										placeholder="Appended to preset system prompt for every session..."
										class="w-full rounded-md border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 p-2 text-xs text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none resize-none"
									>{ vm.SystemAddon }</textarea>
								</div>
								<div>
									<label class="block text-black-600 dark:text-black-700 text-xs mb-0.5">Description</label>
									<input
										type="text"
										name="description"
										value={ vm.Description }
										placeholder="Short description"
										class="w-full rounded-md border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-2 py-1.5 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none"
									/>
								</div>
							</div>
						</div>
					</div>
					<!-- Right: pinned + meta preview + folder semantics -->
					<div class="space-y-6">
						if !vm.IsNew {
							<div>
								<h4 class="font-bold text-sm mb-2 text-black-900 dark:text-white-100">📌 Pinned sessions</h4>
								<div class="space-y-1" data-base={ vm.Base } data-project-id={ vm.ID }>
									if len(vm.Pinned) == 0 {
										<p class="text-xs text-black-600 dark:text-black-700 italic px-2 py-1">No pinned sessions. Pin one from a chat's menu.</p>
									}
									for _, pin := range vm.Pinned {
										<div class="row-light flex items-center gap-2 rounded-md border border-white-300 dark:border-navy-600 px-3 py-2 text-sm text-black-900 dark:text-white-100">
											<span class="flex-1 min-w-0 truncate">{ pin.Label }</span>
											<button type="button" data-unpin-session={ pin.ID } class="text-black-500 dark:text-black-600 hover:text-red-500 transition-colors" title="Unpin">✕</button>
										</div>
									}
								</div>
							</div>
							<div>
								<h4 class="font-bold text-sm mb-2 text-black-900 dark:text-white-100">Project meta preview</h4>
								<pre class="text-xs bg-white-200 dark:bg-navy-800 border border-white-300 dark:border-navy-600 rounded-md p-3 overflow-x-auto text-black-800 dark:text-black-600">{ vm.MetaJSON }</pre>
							</div>
						}
						<div>
							<h4 class="font-bold text-sm mb-2 text-black-900 dark:text-white-100">Folder change semantics</h4>
							<ul class="list-disc pl-5 text-xs text-black-600 dark:text-black-700 space-y-1">
								<li>Managed → custom: managed <code class="font-mono">files/</code> kept on disk (orphaned backup; delete manually)</li>
								<li>Custom → managed: new managed dir created; custom path untouched</li>
								<li>Live sessions: cwd shifts at next spawn; running subprocess unaffected until restart</li>
							</ul>
						</div>
					</div>
				</div>
				<div class="flex justify-end gap-3 pt-2 border-t border-white-300 dark:border-navy-600">
					<a href={ templ.SafeURL(vm.BackHref()) } class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">Cancel</a>
					if vm.IsNew {
						<button type="submit" class="rounded-lg bg-green-500 px-5 py-2 text-sm font-medium text-white-100 hover:bg-green-600 transition-colors">Create project</button>
					} else {
						<button type="submit" class="rounded-lg bg-green-500 px-5 py-2 text-sm font-medium text-white-100 hover:bg-green-600 transition-colors">Save</button>
					}
				</div>
			</form>
		</div>
		<script src={ vm.Base + "/static/js/agents.js" }></script>
	}
}

templ providerOption(value, label, selected string) {
	if value == selected {
		<option value={ value } selected>{ label }</option>
	} else {
		<option value={ value }>{ label }</option>
	}
}

templ presetOption(name, selected string) {
	if name == selected {
		<option value={ name } selected>{ name }</option>
	} else {
		<option value={ name }>{ name }</option>
	}
}
