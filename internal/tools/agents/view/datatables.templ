package view

import (
	"fmt"
	"strconv"
	"strings"
	"time"

	"github.com/yogasw/wick/internal/agents/workflow/datatable"
)

// DataTablesVM is the model for the Data Tables list page.
type DataTablesVM struct {
	Layout AgentsLayoutVM
	Base   string
	Tables []DataTableRow
	Flash  string
}

// DataTableRow summarises one data table on the list page.
type DataTableRow struct {
	Slug        string
	Name        string
	RowCount    int
	Columns     int
	SizeBytes   int64
	UpdatedAt   time.Time
	CreatedAt   time.Time
}

// DataTableDetailVM is the per-table page model.
//
// SortCol/SortDir + Filters drive the spreadsheet header indicators
// (active sort arrow + funnel highlight) and let the filter popover
// pre-fill its inputs from the live URL. Both are populated by the
// handler from query params; an empty SortCol means "default id ASC".
type DataTableDetailVM struct {
	Layout  AgentsLayoutVM
	Base    string
	Slug    string
	Schema  datatable.Schema
	Rows    []map[string]any
	Flash   string
	SortCol string
	SortDir string                // "asc" | "desc"
	Filters map[string]FilterChip // keyed by column name
}

// FilterChip is one applied filter for a column. Op is one of the
// datatable.Op* constants; Value is "" for is_empty / is_not_empty.
type FilterChip struct {
	Op    string
	Value string
}

templ DataTablesPage(vm DataTablesVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-5 p-6">
			<!-- Header -->
			<div class="flex items-start justify-between">
				<div>
					<h1 class="text-xl font-semibold text-black-900 dark:text-white-100">Personal</h1>
					<p class="text-xs text-black-700 dark:text-black-600 mt-0.5">Workflows, credentials and data tables owned by you</p>
				</div>
				<button
					type="button"
					onclick="document.getElementById('new-table-modal').classList.remove('hidden'); document.querySelector('#new-table-modal input[name=name]').focus();"
					class="rounded-lg bg-green-500 px-4 py-2 text-sm font-semibold text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors shadow-sm"
				>Create data table</button>
			</div>
			<!-- Tabs -->
			<div class="border-b border-white-300 dark:border-navy-600">
				<nav class="flex gap-6 -mb-px">
					<a href={ templ.SafeURL(vm.Base + "/workflows") } class="px-1 py-3 text-sm text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">Workflows</a>
					<a href={ templ.SafeURL(vm.Base + "/data-tables") } class="px-1 py-3 text-sm font-semibold text-green-700 dark:text-green-400 border-b-2 border-green-500">Data tables</a>
				</nav>
			</div>
			if vm.Flash != "" {
				<div class="rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-2 text-sm text-amber-900 dark:text-amber-200">
					{ vm.Flash }
				</div>
			}
			<!-- Create data table modal -->
			@createDataTableModal(vm.Base)
			<!-- Tables list (card style) -->
			if len(vm.Tables) == 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-5 py-16 text-center text-sm text-black-700 dark:text-black-600">
					No data tables yet.
					<button
						type="button"
						onclick="document.getElementById('new-table-modal').classList.remove('hidden')"
						class="text-green-600 dark:text-green-400 hover:underline"
					>Create one</button>
				</div>
			} else {
				<div class="space-y-2">
					for _, r := range vm.Tables {
						@dataTableCard(vm.Base, r)
					}
				</div>
				<div class="flex items-center justify-end gap-3 text-xs text-black-700 dark:text-black-600 pt-2">
					<span>Total { strconv.Itoa(len(vm.Tables)) }</span>
					<div class="flex items-center gap-1">
						<button class="rounded border border-white-400 dark:border-navy-600 px-2 py-0.5 disabled:opacity-40" disabled>&lt;</button>
						<span class="rounded bg-white-200 dark:bg-navy-800 px-2 py-0.5 font-medium text-black-900 dark:text-white-100">1</span>
						<button class="rounded border border-white-400 dark:border-navy-600 px-2 py-0.5 disabled:opacity-40" disabled>&gt;</button>
					</div>
					<span>25/page</span>
				</div>
			}
		</div>
		<script>
			(function() {
				const csv = document.querySelector('[data-csv-upload]');
				if (csv) {
					csv.addEventListener('change', () => {
						if (!csv.files || !csv.files.length) return;
						const fd = new FormData();
						fd.append('file', csv.files[0]);
						fetch(csv.dataset.importUrl, { method: 'POST', body: fd })
							.then(r => r.redirected ? window.location.href = r.url : window.location.reload())
							.catch(err => alert('CSV upload failed: ' + err.message));
					});
				}
				// Modal: toggle scratch / CSV inputs based on radio.
				const radios = document.querySelectorAll('input[name=create_mode]');
				const scratchFields = document.getElementById('create-scratch-fields');
				const csvField = document.getElementById('create-csv-field');
				function syncMode() {
					const v = document.querySelector('input[name=create_mode]:checked')?.value;
					if (v === 'csv') {
						scratchFields?.classList.add('hidden');
						csvField?.classList.remove('hidden');
					} else {
						scratchFields?.classList.remove('hidden');
						csvField?.classList.add('hidden');
					}
				}
				radios.forEach(r => r.addEventListener('change', syncMode));
				syncMode();
				// Three-dot menu open/close. `data-menu` on the button must
				// match `data-card-menu` on the menu div (different dataset
				// keys: btn.dataset.menu vs menu.dataset.cardMenu).
				document.querySelectorAll('[data-card-menu-btn]').forEach(btn => {
					btn.addEventListener('click', e => {
						e.preventDefault();
						e.stopPropagation();
						const id = btn.dataset.menu;
						document.querySelectorAll('[data-card-menu]').forEach(m => {
							if (m.dataset.cardMenu === id) m.classList.toggle('hidden');
							else m.classList.add('hidden');
						});
					});
				});
				// Close menus on outside click. Don't close when the click
				// originated inside an open menu (so Download CSV / Delete
				// stay clickable).
				document.addEventListener('click', e => {
					document.querySelectorAll('[data-card-menu]').forEach(m => {
						if (m.contains(e.target)) return;
						m.classList.add('hidden');
					});
				});

				// Forms tagged `data-confirm-form` route through the
				// shared wickConfirm dialog before POSTing. Falls back
				// to native confirm() when the dialog shell isn't on
				// the page.
				document.querySelectorAll('form[data-confirm-form]').forEach(form => {
					form.addEventListener('submit', async e => {
						if (form.dataset.confirmed === '1') return;
						e.preventDefault();
						const msg   = form.dataset.confirmMessage || 'Continue?';
						const title = form.dataset.confirmTitle   || 'Confirm';
						const ok    = form.dataset.confirmOk      || 'OK';
						const proceed = window.wickConfirm
							? await window.wickConfirm(msg, { title, danger: true, ok })
							: window.confirm(msg);
						if (!proceed) return;
						form.dataset.confirmed = '1';
						form.submit();
					});
				});
			})();
		</script>
	}
}

// dataTableCard renders one card row in the list.
templ dataTableCard(base string, r DataTableRow) {
	<div class="group rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 hover:border-green-500/60 dark:hover:border-green-500/60 hover:shadow-sm transition-all">
		<div class="flex items-center gap-4 px-5 py-3.5">
			<div class="flex-shrink-0 rounded-md p-1.5 text-black-700 dark:text-black-600 group-hover:text-green-700 dark:group-hover:text-green-400">
				<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5">
					<rect x="3" y="4" width="18" height="16" rx="2"></rect>
					<path d="M3 9h18M3 14h18M9 4v16" stroke-linecap="round"></path>
				</svg>
			</div>
			<a href={ templ.SafeURL(base + "/data-tables/" + r.Slug) } class="flex-1 min-w-0">
				<div class="font-semibold text-sm text-black-900 dark:text-white-100 group-hover:text-green-700 dark:group-hover:text-green-400 truncate">
					if r.Name != "" {
						{ r.Name }
					} else {
						{ r.Slug }
					}
				</div>
				<div class="text-xs text-black-700 dark:text-black-600 mt-0.5">
					{ formatSize(r.SizeBytes) } | { strconv.Itoa(r.Columns) } columns | Last updated { relTimeDT(r.UpdatedAt) } | Created { relTimeDT(r.CreatedAt) }
				</div>
			</a>
			<div class="relative">
				<button
					type="button"
					data-card-menu-btn
					data-menu={ r.Slug }
					title="More"
					class="rounded-md p-1.5 text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100"
				>
					<svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor">
						<circle cx="8" cy="3" r="1.5"></circle>
						<circle cx="8" cy="8" r="1.5"></circle>
						<circle cx="8" cy="13" r="1.5"></circle>
					</svg>
				</button>
				<div data-card-menu={ r.Slug } class="hidden absolute right-0 top-9 z-30 w-44 rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-lg py-1">
					<a href={ templ.SafeURL(base + "/data-tables/" + r.Slug + "/export.csv") } class="block px-3 py-1.5 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100">Download CSV</a>
					<form
						method="POST"
						action={ templ.SafeURL(base + "/data-tables/" + r.Slug + "/delete") }
						data-confirm-form
						data-confirm-message={ "Delete data table " + r.Slug + " and all its rows?" }
						data-confirm-title="Delete data table"
						data-confirm-ok="Delete"
					>
						<button type="submit" class="w-full text-left px-3 py-1.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Delete</button>
					</form>
				</div>
			</div>
		</div>
	</div>
}

// createDataTableModal — n8n parity: name + (From scratch | Import CSV).
templ createDataTableModal(base string) {
	<div id="new-table-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
		<div class="w-full max-w-md rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6 shadow-2xl mx-4">
			<div class="flex items-start justify-between mb-4">
				<h2 class="text-lg font-semibold text-black-900 dark:text-white-100">Create new data table</h2>
				<button
					type="button"
					onclick="document.getElementById('new-table-modal').classList.add('hidden')"
					class="text-black-600 dark:text-black-700 hover:text-black-900 dark:hover:text-white-100"
				>
					<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3l10 10M13 3L3 13" stroke-linecap="round"></path></svg>
				</button>
			</div>
			<form method="POST" action={ templ.SafeURL(base + "/data-tables") } enctype="multipart/form-data" class="space-y-4">
				<div>
					<label class="block text-sm font-medium text-black-800 dark:text-white-100 mb-1.5">Data table name <span class="text-red-500">*</span></label>
					<input
						type="text"
						name="name"
						required
						placeholder="Enter data table name"
						class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
					/>
				</div>
				<div class="space-y-2.5">
					<label class="flex items-center gap-2.5 cursor-pointer">
						<input type="radio" name="create_mode" value="scratch" checked class="h-4 w-4 text-green-500 focus:ring-green-500"/>
						<span class="text-sm text-black-900 dark:text-white-100">From scratch</span>
					</label>
					<label class="flex items-center gap-2.5 cursor-pointer">
						<input type="radio" name="create_mode" value="csv" class="h-4 w-4 text-green-500 focus:ring-green-500"/>
						<span class="text-sm text-black-900 dark:text-white-100">Import CSV</span>
					</label>
				</div>
				<div id="create-scratch-fields" class="hidden space-y-3 rounded-lg bg-white-200/50 dark:bg-navy-800/40 p-3">
					<details>
						<summary class="text-xs font-medium text-black-700 dark:text-black-600 cursor-pointer hover:text-black-900 dark:hover:text-white-100">Advanced (columns, primary key, mode)</summary>
						<div class="space-y-3 pt-3">
							<div>
								<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Primary key column</label>
								<input
									type="text"
									name="primary_key"
									value="id"
									class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-1.5 text-sm font-mono text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
								/>
							</div>
							<div>
								<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Columns (one per line, name:type)</label>
								<textarea
									name="columns"
									rows="4"
									placeholder="id:string&#10;status:string&#10;created_at:timestamp"
									class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-1.5 text-xs font-mono text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
								></textarea>
								<p class="text-[11px] text-black-600 dark:text-black-700 mt-1">Empty = single <code class="font-mono">id:string</code> column. Add more columns later via the table page.</p>
							</div>
							<div>
								<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Mode</label>
								<select
									name="mode"
									class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-1.5 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
								>
									<option value="strict">strict (reject extra keys)</option>
									<option value="lax">lax (accept extra keys)</option>
								</select>
							</div>
						</div>
					</details>
				</div>
				<div id="create-csv-field" class="hidden space-y-2 rounded-lg bg-white-200/50 dark:bg-navy-800/40 p-3">
					<label class="block text-xs font-medium text-black-800 dark:text-black-600">CSV file <span class="text-red-500">*</span></label>
					<input
						type="file"
						name="csv"
						accept=".csv"
						class="block w-full text-xs text-black-800 dark:text-black-600 file:mr-3 file:rounded file:border-0 file:bg-white-300 dark:file:bg-navy-600 file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-black-900 dark:file:text-white-100 hover:file:bg-white-400 dark:hover:file:bg-navy-500"
					/>
					<p class="text-[11px] text-black-600 dark:text-black-700">First row = headers; subsequent rows = string-typed data. First column becomes the primary key.</p>
				</div>
				<div class="flex justify-end gap-2 pt-2">
					<button
						type="button"
						onclick="document.getElementById('new-table-modal').classList.add('hidden')"
						class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
					>Cancel</button>
					<button
						type="submit"
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-semibold text-white-100 hover:bg-green-600 transition-colors"
					>Create</button>
				</div>
			</form>
		</div>
	</div>
}

templ DataTableDetailPage(vm DataTableDetailVM) {
	@AgentsLayout(vm.Layout) {
		<style>
			/* n8n-style spreadsheet header: icons hidden by default,
			   revealed on hover or when the column has an active filter.
			   Whole header acts like a button (cursor pointer) so the
			   sort affordance is obvious; rename / delete live in the
			   kebab menu only. */
			.wf-dt-th { cursor: pointer; }
			.wf-dt-th[data-col-system="true"] { cursor: default; }
			.wf-dt-icon { opacity: 0; transition: opacity .15s ease; }
			.wf-dt-th:hover .wf-dt-icon { opacity: 1; }
			.wf-dt-icon-active { opacity: 1 !important; }
			/* Rename is committed by the menu; the contenteditable
			   field still gets the n8n blue outline while it is open. */
			.wf-dt-name { display: inline-block; min-width: 1em; padding: 1px 3px; margin: 0 -3px; border-radius: 4px; }
			.wf-dt-name[contenteditable] {
				border: 1px solid #3b82f6;
				background: rgba(59, 130, 246, .12);
				outline: none;
				cursor: text;
			}
		</style>
		<div class="space-y-4 p-6">
			<!-- Breadcrumb + toolbar (n8n spreadsheet header) -->
			<div class="flex items-center justify-between">
				<div class="flex items-center gap-1.5 text-sm">
					<span class="text-black-700 dark:text-black-600">Personal</span>
					<span class="text-black-500 dark:text-black-700">/</span>
					<a href={ templ.SafeURL(vm.Base + "/data-tables") } class="text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">Data tables</a>
					<span class="text-black-500 dark:text-black-700">/</span>
					<span class="font-semibold text-black-900 dark:text-white-100">{ vm.Slug }</span>
				</div>
				<div class="flex items-center gap-2">
					if hasUserCols(vm.Schema) {
						<button
							type="button"
							onclick="document.getElementById('new-row-modal').classList.remove('hidden')"
							class="rounded-lg bg-green-500 px-4 py-1.5 text-sm font-semibold text-white-100 hover:bg-green-600"
						>Add Row</button>
					} else {
						<form method="POST" action={ templ.SafeURL(vm.Base + "/data-tables/" + vm.Slug + "/rows") } class="inline">
							<button
								type="submit"
								title="No user columns yet — id/created_at/updated_at are filled by the system"
								class="rounded-lg bg-green-500 px-4 py-1.5 text-sm font-semibold text-white-100 hover:bg-green-600"
							>Add Row</button>
						</form>
					}
					<button
						type="button"
						onclick="document.getElementById('new-col-modal').classList.remove('hidden')"
						class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-1.5 text-sm font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800"
					>Add Column</button>
					<a
						href={ templ.SafeURL(vm.Base + "/data-tables/" + vm.Slug + "/export.csv") }
						class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800"
					>Export CSV</a>
				</div>
			</div>
			if vm.Flash != "" {
				<div class="rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-2 text-sm text-amber-900 dark:text-amber-200">{ vm.Flash }</div>
			}
			<!-- Spreadsheet grid -->
			<div class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 overflow-hidden">
				<div class="overflow-x-auto">
					<!-- Bulk-selection toolbar. Hidden while no row is
						 checked; the JS at the bottom flips its visibility
						 and keeps the counter in sync with the checkbox set.
						 Delete posts a single bulk-delete request with the
						 selected ids; Clear unticks every checkbox. -->
					<form
						id="wf-dt-bulk"
						method="POST"
						action={ templ.SafeURL(vm.Base + "/data-tables/" + vm.Slug + "/rows/bulk-delete") }
						class="hidden flex items-center gap-3 px-3 py-2 border-b border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-xs"
					>
						<span class="font-medium text-black-900 dark:text-white-100"><span data-bulk-count>0</span> selected</span>
						<button
							type="submit"
							class="inline-flex items-center gap-1.5 rounded border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 px-2.5 py-1 text-red-700 dark:text-red-300 hover:bg-red-100 dark:hover:bg-red-900/40"
						>
							<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h8M5 4l1-2h4l1 2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke-linejoin="round"></path></svg>
							Delete
						</button>
						<button
							type="button"
							data-bulk-clear
							class="text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100"
						>Clear selection</button>
						<!-- Hidden input slots get filled by JS from ticked
							 checkboxes right before submit. -->
					</form>
					<table class="w-full text-sm border-collapse">
						<thead>
							<tr class="bg-white-200 dark:bg-navy-800 border-b border-white-300 dark:border-navy-600 text-xs font-medium text-black-700 dark:text-black-600">
								<th class="w-10 px-3 py-2.5 text-left">
									<input type="checkbox" data-bulk-select-all class="h-3.5 w-3.5"/>
								</th>
								for _, col := range vm.Schema.Columns {
									@spreadsheetHeaderCell(vm, col)
								}
							</tr>
						</thead>
						<tbody>
							if len(vm.Rows) == 0 {
								<tr>
									<td colspan={ strconv.Itoa(len(vm.Schema.Columns) + 1) } class="px-5 py-12 text-center text-sm text-black-700 dark:text-black-600">
										No rows yet.
										<button
											type="button"
											onclick="document.getElementById('new-row-modal').classList.remove('hidden')"
											class="text-green-600 dark:text-green-400 hover:underline"
										>Add the first row</button>
									</td>
								</tr>
							}
							for _, row := range vm.Rows {
								<tr class="border-b border-white-300/60 dark:border-navy-600/60 hover:bg-white-200/50 dark:hover:bg-navy-800/40">
									<td class="px-3 py-2.5">
										<input
											type="checkbox"
											data-bulk-row
											value={ pkVal(vm.Schema, row) }
											class="h-3.5 w-3.5"
										/>
									</td>
									for _, col := range vm.Schema.Columns {
										<td class="px-4 py-2.5 font-mono text-xs text-black-800 dark:text-black-600 whitespace-nowrap">
											{ formatCell(row[col.Name]) }
										</td>
									}
								</tr>
							}
						</tbody>
					</table>
				</div>
				<!-- Footer pagination -->
				<div class="flex items-center justify-end gap-3 px-4 py-2 border-t border-white-300 dark:border-navy-600 text-xs text-black-700 dark:text-black-600">
					<span>Total { strconv.Itoa(len(vm.Rows)) }</span>
					<div class="flex items-center gap-1">
						<button class="rounded border border-white-400 dark:border-navy-600 px-2 py-0.5 disabled:opacity-40" disabled>&lt;</button>
						<span class="rounded bg-white-200 dark:bg-navy-800 px-2 py-0.5 font-medium text-black-900 dark:text-white-100">1</span>
						<button class="rounded border border-white-400 dark:border-navy-600 px-2 py-0.5 disabled:opacity-40" disabled>&gt;</button>
					</div>
					<span>25/page</span>
				</div>
			</div>
			<!-- Add row modal -->
			<div id="new-row-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
				<div class="w-full max-w-md rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6 shadow-2xl mx-4">
					<div class="flex items-start justify-between mb-4">
						<h2 class="text-lg font-semibold text-black-900 dark:text-white-100">Add row</h2>
						<button type="button" onclick="document.getElementById('new-row-modal').classList.add('hidden')" class="text-black-600 dark:text-black-700 hover:text-black-900 dark:hover:text-white-100">
							<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3l10 10M13 3L3 13" stroke-linecap="round"></path></svg>
						</button>
					</div>
					<form method="POST" action={ templ.SafeURL(vm.Base + "/data-tables/" + vm.Slug + "/rows") } class="space-y-3">
						for _, col := range vm.Schema.Columns {
							if !col.System {
								<div>
									<label class="block text-xs font-medium text-black-800 dark:text-white-100 mb-1 font-mono">
										{ col.Name } <span class="text-black-600 dark:text-black-700">({ col.Type })</span>
									</label>
									<input
										type="text"
										name={ "col_" + col.Name }
										class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
									/>
								</div>
							}
						}
						<p class="text-[11px] text-black-600 dark:text-black-700">
							<code class="font-mono">id</code>, <code class="font-mono">created_at</code>, <code class="font-mono">updated_at</code> are managed by the system.
						</p>
						<div class="flex justify-end gap-2 pt-2">
							<button type="button" onclick="document.getElementById('new-row-modal').classList.add('hidden')" class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Cancel</button>
							<button type="submit" class="rounded-lg bg-green-500 px-4 py-2 text-sm font-semibold text-white-100 hover:bg-green-600">Insert</button>
						</div>
					</form>
				</div>
			</div>
			<!-- Add column modal -->
			<div id="new-col-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
				<div class="w-full max-w-md rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6 shadow-2xl mx-4">
					<div class="flex items-start justify-between mb-4">
						<h2 class="text-lg font-semibold text-black-900 dark:text-white-100">Add column</h2>
						<button type="button" onclick="document.getElementById('new-col-modal').classList.add('hidden')" class="text-black-600 dark:text-black-700 hover:text-black-900 dark:hover:text-white-100">
							<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3l10 10M13 3L3 13" stroke-linecap="round"></path></svg>
						</button>
					</div>
					<form method="POST" action={ templ.SafeURL(vm.Base + "/data-tables/" + vm.Slug + "/columns") } class="space-y-3">
						<div>
							<label class="block text-xs font-medium text-black-800 dark:text-white-100 mb-1">Column name <span class="text-red-500">*</span></label>
							<input
								type="text"
								name="name"
								required
								placeholder="e.g. status"
								class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
							/>
						</div>
						<div>
							<label class="block text-xs font-medium text-black-800 dark:text-white-100 mb-1">Type</label>
							<select
								name="type"
								class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
							>
								<option value="string">string</option>
								<option value="int">int</option>
								<option value="float">float</option>
								<option value="bool">bool</option>
								<option value="timestamp">timestamp</option>
								<option value="json">json</option>
								<option value="enum">enum</option>
							</select>
						</div>
						<div class="flex justify-end gap-2 pt-2">
							<button type="button" onclick="document.getElementById('new-col-modal').classList.add('hidden')" class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Cancel</button>
							<button type="submit" class="rounded-lg bg-green-500 px-4 py-2 text-sm font-semibold text-white-100 hover:bg-green-600">Add</button>
						</div>
					</form>
				</div>
			</div>
			<!-- Column header action menu (kebab ⋯) -->
			<div id="col-action-menu" class="hidden fixed z-50 min-w-[180px] rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-lg py-1">
				<button type="button" data-action="rename" class="w-full text-left px-3 py-1.5 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100">
					<span class="inline-flex items-center gap-2">
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 3.5l1.5 1.5-6.5 6.5H4.5v-1.5L11 3.5z" stroke-linejoin="round"></path></svg>
						Rename column
					</span>
				</button>
				<button type="button" data-action="delete" class="w-full text-left px-3 py-1.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
					<span class="inline-flex items-center gap-2">
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h8M5 4l1-2h4l1 2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke-linejoin="round"></path></svg>
						Delete column
					</span>
				</button>
			</div>
			<!-- Column filter popover (funnel) -->
			<div id="col-filter-popover" class="hidden fixed z-50 w-64 rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-lg p-3 space-y-2">
				<select data-filter-op class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none">
					<option value="contains">Contains</option>
					<option value="equals">Equals</option>
					<option value="not_equals">Not equals</option>
					<option value="gt">Greater than</option>
					<option value="gte">Greater or equal</option>
					<option value="lt">Less than</option>
					<option value="lte">Less or equal</option>
					<option value="in">In list (comma-separated)</option>
					<option value="is_empty">Is empty</option>
					<option value="is_not_empty">Is not empty</option>
				</select>
				<input
					data-filter-value
					type="text"
					placeholder="Filter…"
					class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
				/>
				<div class="flex justify-between gap-2">
					<button type="button" data-filter-reset class="text-xs text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">Reset</button>
					<button type="button" data-filter-apply class="rounded-lg bg-green-500 px-3 py-1 text-xs font-semibold text-white-100 hover:bg-green-600">Apply</button>
				</div>
			</div>
		</div>
		<script>
			(function () {
				const menu     = document.getElementById('col-action-menu');
				const popover  = document.getElementById('col-filter-popover');
				if (!menu || !popover) return;

				let activeHeader = null;
				let activePanel  = null; // 'menu' | 'filter' | null

				function closeAll() {
					menu.classList.add('hidden');
					popover.classList.add('hidden');
					activeHeader = null;
					activePanel  = null;
				}

				function showAt(panel, header, anchor) {
					closeAll();
					activeHeader = header;
					activePanel  = panel === menu ? 'menu' : 'filter';
					const rect = anchor.getBoundingClientRect();
					panel.style.left = (rect.right - (panel === popover ? 240 : 180)) + 'px';
					panel.style.top  = (rect.bottom + 4) + 'px';
					panel.classList.remove('hidden');
				}

				// ── inline rename via contenteditable on name span ─────────
				function rename(header, nextName) {
					const name = header.dataset.colHeader;
					const next = (nextName || '').trim();
					if (!next || next === name) return;
					const fd = new FormData();
					fd.append('name', next);
					fetch(header.dataset.renameUrl, { method: 'POST', body: fd })
						.then(r => r.redirected ? window.location.href = r.url : window.location.reload())
						.catch(err => alert('Rename failed: ' + err.message));
				}

				function startEdit(span) {
					const th = span.closest('th[data-col-header]');
					if (!th) return;
					const original = span.textContent;
					span.setAttribute('contenteditable', 'plaintext-only');
					span.dataset.editing = '1';
					span.focus();
					const range = document.createRange();
					range.selectNodeContents(span);
					const sel = window.getSelection();
					sel.removeAllRanges();
					sel.addRange(range);
					function finish(commit) {
						if (!span.dataset.editing) return;
						delete span.dataset.editing;
						span.removeAttribute('contenteditable');
						span.removeEventListener('keydown', onKey);
						span.removeEventListener('blur', onBlur);
						const next = span.textContent;
						if (commit && next !== original) rename(th, next);
						else span.textContent = original;
					}
					function onKey(e) {
						if (e.key === 'Enter') { e.preventDefault(); finish(true); }
						else if (e.key === 'Escape') { e.preventDefault(); finish(false); }
					}
					function onBlur() { finish(true); }
					span.addEventListener('keydown', onKey);
					span.addEventListener('blur', onBlur);
				}

				async function dropCol(header) {
					const name = header.dataset.colHeader;
					const ok = window.wickConfirm
						? await window.wickConfirm('Delete column "' + name + '"? Data in this column will be stripped from every row.', { title: 'Delete column', danger: true, ok: 'Delete' })
						: window.confirm('Delete column "' + name + '"? Data in this column will be stripped from every row.');
					if (!ok) return;
					fetch(header.dataset.deleteUrl, { method: 'POST' })
						.then(r => r.redirected ? window.location.href = r.url : window.location.reload())
						.catch(err => alert('Delete failed: ' + err.message));
				}

				// ── URL query helpers (sort + per-column filters) ──────────
				function currentURL() { return new URL(window.location.href); }

				function applySort(col, dir) {
					const u = currentURL();
					if (!dir) u.searchParams.delete('sort');
					else      u.searchParams.set('sort', col + ':' + dir);
					window.location.href = u.toString();
				}

				function applyFilter(col, op, value) {
					const u = currentURL();
					const opKey = 'f.' + col + '.op';
					const vKey  = 'f.' + col + '.v';
					if (!op) {
						u.searchParams.delete(opKey);
						u.searchParams.delete(vKey);
					} else {
						u.searchParams.set(opKey, op);
						if (op === 'is_empty' || op === 'is_not_empty') {
							u.searchParams.delete(vKey);
						} else {
							u.searchParams.set(vKey, value || '');
						}
					}
					window.location.href = u.toString();
				}

				// 3-state sort: ASC → DESC → off.
				function nextSortDir(cur) {
					if (cur === 'asc')  return 'desc';
					if (cur === 'desc') return '';
					return 'asc';
				}

				// Name span only enters edit mode when the kebab menu's
				// Rename action triggers startEdit — clicking the name
				// itself just falls through to the sort handler below.
				// We still stop propagation while editing so typing the
				// new name doesn't re-trigger a sort.
				document.querySelectorAll('th[data-col-header] [data-col-name]').forEach(span => {
					span.addEventListener('click', e => {
						if (span.dataset.editing) e.stopPropagation();
					});
				});

				// ── wire funnel + kebab buttons ────────────────────────────
				document.querySelectorAll('th[data-col-header]').forEach(th => {
					const funnel = th.querySelector('[data-funnel]');
					const kebab  = th.querySelector('[data-kebab]');

					if (kebab) {
						kebab.addEventListener('click', e => {
							e.stopPropagation();
							showAt(menu, th, kebab);
						});
					}

					if (funnel) {
						funnel.addEventListener('click', e => {
							e.stopPropagation();
							const opSel = popover.querySelector('[data-filter-op]');
							const vIn   = popover.querySelector('[data-filter-value]');
							opSel.value = th.dataset.filterOp || 'contains';
							vIn.value   = th.dataset.filterValue || '';
							showAt(popover, th, funnel);
							setTimeout(() => vIn.focus(), 0);
						});
					}

					// Click anywhere on the header (incl. type icon and
					// name) → cycle sort. Funnel / kebab handle their own
					// stopPropagation; rename mode is signalled by the
					// editing flag on the name span.
					th.addEventListener('click', e => {
						if (e.target.closest('[data-funnel],[data-kebab]')) return;
						const span = th.querySelector('[data-col-name]');
						if (span && span.dataset.editing === '1') return;
						const col = th.dataset.sortCol;
						const cur = th.dataset.sortDir || '';
						applySort(col, nextSortDir(cur));
					});
				});

				// ── menu actions (rename / delete) ─────────────────────────
				menu.querySelectorAll('button[data-action]').forEach(btn => {
					btn.addEventListener('click', e => {
						e.stopPropagation();
						if (!activeHeader) return;
						const action = btn.dataset.action;
						const header = activeHeader;
						closeAll();
						if (header.dataset.colSystem === 'true') {
							alert('System column — managed automatically, cannot be renamed or deleted.');
							return;
						}
						if (header.dataset.colPk === 'true') {
							alert('Primary key column is locked.');
							return;
						}
						if (action === 'rename') {
							const span = header.querySelector('[data-col-name]');
							if (span) startEdit(span);
						} else if (action === 'delete') dropCol(header);
					});
				});

				// ── filter popover actions ─────────────────────────────────
				popover.querySelector('[data-filter-apply]').addEventListener('click', () => {
					if (!activeHeader) return;
					const op  = popover.querySelector('[data-filter-op]').value;
					const v   = popover.querySelector('[data-filter-value]').value;
					const col = activeHeader.dataset.colHeader;
					closeAll();
					applyFilter(col, op, v);
				});
				popover.querySelector('[data-filter-reset]').addEventListener('click', () => {
					if (!activeHeader) return;
					const col = activeHeader.dataset.colHeader;
					closeAll();
					applyFilter(col, '', '');
				});
				popover.querySelector('[data-filter-value]').addEventListener('keydown', e => {
					if (e.key === 'Enter') popover.querySelector('[data-filter-apply]').click();
					else if (e.key === 'Escape') closeAll();
				});

				// ── close on outside click / escape / scroll ───────────────
				document.addEventListener('click', e => {
					if (menu.contains(e.target) || popover.contains(e.target)) return;
					closeAll();
				});
				document.addEventListener('scroll', closeAll, true);
				document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAll(); });

				// ── bulk row selection toolbar ─────────────────────────────
				// Reveal the toolbar whenever any row checkbox is ticked,
				// keep the count + master select-all box in sync, and on
				// submit synthesise <input name="ids" value="..."> entries
				// inside the form so the bulk-delete handler reads the
				// selection without coupling the table markup to the form.
				const bulkForm  = document.getElementById('wf-dt-bulk');
				const boxes     = document.querySelectorAll('input[data-bulk-row]');
				const masterBox = document.querySelector('input[data-bulk-select-all]');
				if (bulkForm) {
					const countEl = bulkForm.querySelector('[data-bulk-count]');
					function selected() {
						return Array.from(boxes).filter(b => b.checked);
					}
					function refresh() {
						const n = selected().length;
						if (countEl) countEl.textContent = String(n);
						bulkForm.classList.toggle('hidden', n === 0);
						bulkForm.classList.toggle('flex',   n > 0);
						if (masterBox) {
							masterBox.indeterminate = n > 0 && n < boxes.length;
							masterBox.checked = n > 0 && n === boxes.length;
						}
					}
					boxes.forEach(b => b.addEventListener('change', refresh));
					if (masterBox) {
						masterBox.addEventListener('change', () => {
							boxes.forEach(b => { b.checked = masterBox.checked; });
							refresh();
						});
					}
					const clearBtn = bulkForm.querySelector('[data-bulk-clear]');
					if (clearBtn) {
						clearBtn.addEventListener('click', () => {
							boxes.forEach(b => { b.checked = false; });
							if (masterBox) masterBox.checked = false;
							refresh();
						});
					}
					// Submit flow:
					//   1. Stop the native submit so we can await the
					//      confirm modal first.
					//   2. Ask wickConfirm (or fall back to native) with
					//      the live selection count — counter lives in
					//      JS state so we don't depend on form fields
					//      we haven't injected yet.
					//   3. On confirm, inject hidden ids and resubmit
					//      via .submit() (skips listeners → no loop).
					bulkForm.addEventListener('submit', async e => {
						e.preventDefault();
						const sel = selected();
						if (sel.length === 0) return;
						const ok = window.wickConfirm
							? await window.wickConfirm('Delete ' + sel.length + ' row(s)?', { title: 'Delete rows', danger: true, ok: 'Delete' })
							: window.confirm('Delete ' + sel.length + ' row(s)?');
						if (!ok) return;
						bulkForm.querySelectorAll('input[name="ids"]').forEach(n => n.remove());
						sel.forEach(b => {
							const hidden = document.createElement('input');
							hidden.type = 'hidden';
							hidden.name = 'ids';
							hidden.value = b.value;
							bulkForm.appendChild(hidden);
						});
						bulkForm.submit();
					});
					refresh();
				}
			})();
		</script>
	}
}

// spreadsheetHeaderCell renders one <th> in the rows grid. The cell
// is built from four interactive zones so click targets stay
// unambiguous: column-name span (rename), funnel (filter popover),
// kebab (rename/delete menu), and the surrounding header (sort
// toggle). System columns expose only the name + lock icon — no
// rename / delete / filter on id/created_at/updated_at.
templ spreadsheetHeaderCell(vm DataTableDetailVM, col datatable.Column) {
	<th
		class={ "wf-dt-th group relative px-3 py-2 text-left font-mono whitespace-nowrap select-none align-middle",
			templ.KV("cursor-pointer", !col.System) }
		data-col-header={ col.Name }
		data-col-pk={ boolStr(isPK(vm.Schema, col.Name)) }
		data-col-system={ boolStr(col.System) }
		data-col-type={ col.Type }
		data-rename-url={ vm.Base + "/data-tables/" + vm.Slug + "/columns/" + col.Name + "/rename" }
		data-delete-url={ vm.Base + "/data-tables/" + vm.Slug + "/columns/" + col.Name + "/delete" }
		data-sort-col={ col.Name }
		data-sort-dir={ headerSortDir(vm, col.Name) }
		data-filter-op={ headerFilterOp(vm, col.Name) }
		data-filter-value={ headerFilterValue(vm, col.Name) }
	>
		<div class="flex items-center gap-1.5">
			@colTypeIcon(col.Type)
			if col.System {
				<span class="text-black-800 dark:text-black-600" title="System column — managed automatically">{ col.Name }</span>
				<svg viewBox="0 0 16 16" class="h-3 w-3 text-black-600 dark:text-black-700" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="7" width="8" height="6" rx="1"></rect><path d="M6 7V5a2 2 0 014 0v2" stroke-linecap="round"></path></svg>
			} else {
				<span
					class="wf-dt-name text-black-900 dark:text-white-100"
					data-col-name
					spellcheck="false"
				>{ col.Name }</span>
			}
			@headerSortIndicator(vm, col.Name)
			<!-- spacer pushes funnel + kebab right -->
			<span class="flex-1"></span>
			if !col.System {
				<button
					type="button"
					data-funnel
					title="Filter"
					class={ "wf-dt-icon rounded p-0.5 text-black-600 dark:text-black-700 hover:bg-white-300 dark:hover:bg-navy-600 hover:text-black-900 dark:hover:text-white-100",
						templ.KV("text-green-600 dark:text-green-400 wf-dt-icon-active", hasFilter(vm, col.Name)) }
				>
					<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5">
						<path d="M2 3h12l-4.5 6v4l-3 1.5V9L2 3z" stroke-linejoin="round"></path>
					</svg>
				</button>
				<button
					type="button"
					data-kebab
					title="More"
					class="wf-dt-icon rounded p-0.5 text-black-600 dark:text-black-700 hover:bg-white-300 dark:hover:bg-navy-600 hover:text-black-900 dark:hover:text-white-100"
				>
					<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="currentColor">
						<circle cx="3" cy="8" r="1.3"></circle>
						<circle cx="8" cy="8" r="1.3"></circle>
						<circle cx="13" cy="8" r="1.3"></circle>
					</svg>
				</button>
			}
		</div>
	</th>
}

// headerSortIndicator renders the asc/desc arrow when this column is
// the active sort target. n8n uses a thin chevron next to the column
// name; we mirror that with stroke-width 1.5 and slate-500 stroke.
templ headerSortIndicator(vm DataTableDetailVM, name string) {
	if vm.SortCol == name {
		if vm.SortDir == "desc" {
			<svg viewBox="0 0 16 16" class="h-3.5 w-3.5 text-black-800 dark:text-black-500" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
		} else {
			<svg viewBox="0 0 16 16" class="h-3.5 w-3.5 text-black-800 dark:text-black-500" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 10l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
		}
	}
}

// headerSortDir returns the active sort direction for a column, or "" when
// the column isn't sorted. Used as a data-* attribute for the JS toggle.
func headerSortDir(vm DataTableDetailVM, name string) string {
	if vm.SortCol == name {
		return vm.SortDir
	}
	return ""
}

// headerFilterOp returns the active filter op for a column, "" when none.
func headerFilterOp(vm DataTableDetailVM, name string) string {
	if c, ok := vm.Filters[name]; ok {
		return c.Op
	}
	return ""
}

// headerFilterValue returns the active filter value for a column.
func headerFilterValue(vm DataTableDetailVM, name string) string {
	if c, ok := vm.Filters[name]; ok {
		return c.Value
	}
	return ""
}

// hasFilter reports whether a column has an applied filter chip.
func hasFilter(vm DataTableDetailVM, name string) bool {
	c, ok := vm.Filters[name]
	return ok && c.Op != ""
}

// colTypeIcon renders the n8n-style 1-char type prefix.
templ colTypeIcon(t string) {
	switch t {
		case "int", "float":
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-sm bg-blue-100 dark:bg-blue-900/40 text-[10px] font-bold text-blue-700 dark:text-blue-300">#</span>
		case "bool":
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-sm bg-purple-100 dark:bg-purple-900/40 text-[10px] font-bold text-purple-700 dark:text-purple-300">B</span>
		case "timestamp":
			<svg viewBox="0 0 16 16" class="h-3.5 w-3.5 text-amber-700 dark:text-amber-400" fill="none" stroke="currentColor" stroke-width="1.5">
				<rect x="2" y="3" width="12" height="11" rx="1"></rect>
				<path d="M2 6h12M6 1v3M10 1v3" stroke-linecap="round"></path>
			</svg>
		case "json":
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-sm bg-pink-100 dark:bg-pink-900/40 text-[10px] font-bold text-pink-700 dark:text-pink-300">{ "{}" }</span>
		case "enum":
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-sm bg-emerald-100 dark:bg-emerald-900/40 text-[10px] font-bold text-emerald-700 dark:text-emerald-300">≡</span>
		default:
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-sm bg-white-300 dark:bg-navy-600 text-[10px] font-bold text-black-700 dark:text-black-600">T</span>
	}
}

// isPK reports whether `col` is part of the schema's primary key list.
func isPK(sc datatable.Schema, col string) bool {
	for _, k := range sc.PrimaryKey {
		if k == col {
			return true
		}
	}
	return false
}

// pkVal extracts the row's PK as a single string (joined when composite).
func pkVal(sc datatable.Schema, row map[string]any) string {
	parts := make([]string, 0, len(sc.PrimaryKey))
	for _, k := range sc.PrimaryKey {
		parts = append(parts, fmt.Sprintf("%v", row[k]))
	}
	return strings.Join(parts, "|")
}

// hasUserCols reports whether the schema has any non-system columns.
func hasUserCols(sc datatable.Schema) bool {
	for _, c := range sc.Columns {
		if !c.System {
			return true
		}
	}
	return false
}

// boolStr returns "true" / "false" for use in data-* attributes.
func boolStr(b bool) string {
	if b {
		return "true"
	}
	return "false"
}

func formatCell(v any) string {
	if v == nil {
		return ""
	}
	return fmt.Sprintf("%v", v)
}

// formatSize returns "0.01MB" / "0MB" — n8n-style.
func formatSize(b int64) string {
	if b <= 0 {
		return "0MB"
	}
	mb := float64(b) / 1024.0 / 1024.0
	if mb < 0.01 {
		return "0.01MB"
	}
	return fmt.Sprintf("%.2fMB", mb)
}

// relTime renders a coarse "N units ago" label. Empty time = "—".
func relTimeDT(t time.Time) string {
	if t.IsZero() {
		return "—"
	}
	d := time.Since(t)
	switch {
	case d < time.Minute:
		return "just now"
	case d < time.Hour:
		return fmt.Sprintf("%d minutes ago", int(d.Minutes()))
	case d < 24*time.Hour:
		return fmt.Sprintf("%d hours ago", int(d.Hours()))
	case d < 30*24*time.Hour:
		return fmt.Sprintf("%d days ago", int(d.Hours()/24))
	case d < 365*24*time.Hour:
		return fmt.Sprintf("%d months ago", int(d.Hours()/(24*30)))
	}
	return fmt.Sprintf("%d years ago", int(d.Hours()/(24*365)))
}
