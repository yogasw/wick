package view

import (
	"fmt"
	"strings"
)

templ SkillsPage(vm SkillsPageVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<!-- Header -->
			<div class="flex items-center justify-between gap-3 flex-wrap">
				<div>
					<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">Skills</h1>
					<p class="text-xs text-black-700 dark:text-black-600 mt-0.5">Skill files are synced across all agent dirs. Upload once → available everywhere.</p>
				</div>
				<div class="flex items-center gap-2">
					<form method="POST" action={ templ.SafeURL(vm.Base + "/skills/sync") }>
						<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Sync All</button>
					</form>
					<button
						onclick="document.getElementById('upload-skill-modal').classList.remove('hidden')"
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors"
					>+ Upload Skill</button>
				</div>
			</div>
			<!-- Result banner -->
			if vm.Flash != "" {
				<div class="rounded-lg border border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20 px-4 py-3 text-sm text-green-700 dark:text-green-400">{ vm.Flash }</div>
			}
			if vm.Error != "" {
				<div class="rounded-lg border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 px-4 py-3 text-sm text-red-700 dark:text-red-400">{ vm.Error }</div>
			}
			<!-- Dirs legend -->
			if len(vm.Dirs) > 0 {
				<div class="flex flex-wrap gap-2 items-center">
					<span class="text-xs text-black-700 dark:text-black-600">Skill dirs:</span>
					for _, d := range vm.Dirs {
						<span class="rounded-full border border-white-400 dark:border-navy-600 px-2.5 py-0.5 font-mono text-xs text-black-800 dark:text-black-600" data-tooltip={ d }>{ skillDirLabel(d) }</span>
					}
				</div>
			} else {
				<div class="rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-3 text-sm text-amber-700 dark:text-amber-400">
					No skill directories found. Create at least one of: <code class="font-mono">~/.agents/skills</code>, <code class="font-mono">~/.claude/skills</code>, <code class="font-mono">~/.codex/skills</code>, <code class="font-mono">~/.gemini/skills</code>.
				</div>
			}
			<!-- File list -->
			if len(vm.Files) == 0 && len(vm.Dirs) > 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-6 py-12 text-center text-sm text-black-700 dark:text-black-600">
					No skill files yet. Upload one above.
				</div>
			} else if len(vm.Files) > 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
					<table class="w-full text-sm">
						<thead>
							<tr class="border-b border-white-300 dark:border-navy-600 text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">
								<th class="px-5 py-3 text-left">Name</th>
								<th class="px-5 py-3 text-left">Present In</th>
								<th class="px-5 py-3 text-left">Status</th>
								<th class="px-5 py-3 text-right">Actions</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-white-300 dark:divide-navy-600">
							for _, f := range vm.Files {
								<tr
									data-row-link={ vm.Base + "/skills/" + f.Name }
									class="cursor-pointer hover:bg-white-200 dark:hover:bg-navy-800 transition-colors group"
								>
									<td class="px-5 py-3">
										<div class="flex items-center gap-2">
											if f.IsDir {
												<svg class="w-4 h-4 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }/</span>
											} else {
												<svg class="w-4 h-4 text-black-500 dark:text-black-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }</span>
											}
										</div>
									</td>
									<td class="px-5 py-3">
										<div class="flex flex-wrap gap-1">
											for _, d := range f.InDirs {
												<span class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-300 dark:border-green-700 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400" data-tooltip={ d }>{ skillDirLabel(d) }</span>
											}
											for _, d := range f.Missing {
												<span class="rounded-full bg-white-300 dark:bg-navy-600 border border-white-400 dark:border-navy-500 px-2 py-0.5 text-xs text-black-600 dark:text-black-500 line-through" data-tooltip={ d + " (missing)" }>{ skillDirLabel(d) }</span>
											}
										</div>
									</td>
									<td class="px-5 py-3">
										if len(f.Missing) == 0 {
											<span class="inline-flex items-center gap-1 text-xs text-green-600 dark:text-green-400">
												<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
												synced
											</span>
										} else {
											<span class="inline-flex items-center gap-1 text-xs text-amber-600 dark:text-amber-400">
												<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
												missing { fmt.Sprintf("%d", len(f.Missing)) } dir(s)
											</span>
										}
									</td>
									<td class="px-5 py-3 text-right" data-row-action>
										if f.IsDir {
											@kebabMenuMulti([]kebabAction{
												{Label: "Sync to all", DataAttr: "data-sync-skill", DataVal: vm.Base + "/skills/" + f.Name + "/sync"},
												{Label: "Download zip", Href: vm.Base + "/skills/" + f.Name + "/download"},
												{Label: "Delete", Variant: "danger", DataAttr: "data-delete-skill", DataVal: vm.Base + "/skills/" + f.Name + "/delete"},
											})
										} else {
											@kebabMenuMulti([]kebabAction{
												{Label: "Sync to all", DataAttr: "data-sync-skill", DataVal: vm.Base + "/skills/" + f.Name + "/sync"},
												{Label: "Delete", Variant: "danger", DataAttr: "data-delete-skill", DataVal: vm.Base + "/skills/" + f.Name + "/delete"},
											})
										}
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		</div>
		<div id="upload-skill-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
			<div class="w-full max-w-lg rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-xl p-6">
				<div class="flex items-center justify-between mb-4">
					<h2 class="text-base font-semibold text-black-900 dark:text-white-100">Upload Skill File</h2>
					<button onclick="document.getElementById('upload-skill-modal').classList.add('hidden')" class="text-black-600 dark:text-black-500 hover:text-black-900 dark:hover:text-white-100">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
					</button>
				</div>
				<form method="POST" action={ templ.SafeURL(vm.Base + "/skills/upload") } enctype="multipart/form-data" class="space-y-4">
					<div>
						<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">File</label>
						<input type="file" name="file" accept=".md,.txt,.zip,.skills" required class="block w-full text-sm text-black-800 dark:text-black-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border file:border-white-400 dark:file:border-navy-600 file:text-xs file:bg-white-200 dark:file:bg-navy-800 file:text-black-800 dark:file:text-black-600 hover:file:bg-white-300 dark:hover:file:bg-navy-700"/>
						<p class="mt-1 text-xs text-black-600 dark:text-black-500">
							<strong>.md / .txt</strong> — wrapped in a folder named after the file stem.<br/>
							<strong>.zip / .skills</strong> — extracted as-is if it has a single root folder, otherwise wrapped under the zip name.
						</p>
					</div>
					<div class="flex justify-end gap-2">
						<button type="button" onclick="document.getElementById('upload-skill-modal').classList.add('hidden')" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Cancel</button>
						<button type="submit" class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600">Upload &amp; Sync</button>
					</div>
				</form>
			</div>
		</div>
		<script src={ vm.Base + "/static/js/skills.js" }></script>
	}
}

templ SkillDetailPage(vm SkillDetailVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<div class="flex items-center justify-between gap-3 flex-wrap">
				<div class="flex items-center gap-3">
					<a href={ templ.SafeURL(vm.Base + "/skills") } class="text-sm text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">← Skills</a>
					<h1 class="font-mono text-base font-semibold text-black-900 dark:text-white-100">{ vm.Filename }</h1>
				</div>
				<div class="flex items-center gap-2">
					<div class="flex flex-wrap gap-1">
						for _, d := range vm.InDirs {
							<span class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-300 dark:border-green-700 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400" data-tooltip={ d }>{ skillDirLabel(d) }</span>
						}
					</div>
					<form method="POST" action={ templ.SafeURL(vm.Base + "/skills/" + vm.Filename + "/delete") } onsubmit="return confirm('Delete from all dirs?')">
						<button type="submit" class="rounded-lg border border-red-300 dark:border-red-700 px-3 py-2 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Delete</button>
					</form>
				</div>
			</div>
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden flex flex-col" style="min-height: calc(100vh - 180px)">
				<div class="px-4 py-2 border-b border-white-300 dark:border-navy-600 text-xs text-black-600 dark:text-black-500 shrink-0">{ vm.SourcePath }</div>
				<div data-md class="px-5 py-4 space-y-1 overflow-x-auto flex-1">{ vm.Content }</div>
			</div>
		</div>
		<script src={ vm.Base + "/static/js/skills.js" }></script>
	}
}

templ SkillFolderPage(vm SkillFolderVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<!-- Header / breadcrumb -->
			<div class="flex items-center justify-between gap-3 flex-wrap">
				<div class="flex items-center gap-3">
					<a href={ templ.SafeURL(vm.Base + "/skills") } class="text-sm text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">← Skills</a>
					<span class="text-black-500 dark:text-black-600">/</span>
					<h1 class="font-mono text-base font-semibold text-black-900 dark:text-white-100">{ vm.FolderName }</h1>
				</div>
				<div class="flex items-center gap-2">
					<!-- per-dir delete badges -->
					for _, d := range vm.InDirs {
						<form method="POST" action={ templ.SafeURL(vm.Base + "/skills/" + vm.FolderName + "/delete-from/" + skillDirLabel(d)) }>
							<button type="submit" onclick={ templ.ComponentScript{Call: "return confirm('Remove from " + skillDirLabel(d) + "?')"} } class="rounded-full border border-red-300 dark:border-red-700 px-2.5 py-0.5 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">✕ { skillDirLabel(d) }</button>
						</form>
					}
					<a href={ templ.SafeURL(vm.Base + "/skills/" + vm.FolderName + "/download") } class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Download zip</a>
					<form method="POST" action={ templ.SafeURL(vm.Base + "/skills/" + vm.FolderName + "/delete") }>
						<button type="submit" onclick="return confirm('Delete from all dirs?')" class="rounded-lg border border-red-300 dark:border-red-700 px-3 py-2 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Delete all</button>
					</form>
				</div>
			</div>
			<!-- Dir presence badges — clickable → provider-scoped view -->
			<div class="flex flex-wrap gap-2 items-center">
				<span class="text-xs text-black-700 dark:text-black-600">Present in:</span>
				for _, d := range vm.InDirs {
					<a href={ templ.SafeURL(vm.Base + "/skills/" + skillDirLabel(d) + "/" + vm.FolderName) } data-tooltip={ d } class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-300 dark:border-green-700 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/50">{ skillDirLabel(d) }</a>
				}
				for _, d := range vm.Missing {
					<span class="rounded-full bg-white-300 dark:bg-navy-600 border border-white-400 dark:border-navy-500 px-2 py-0.5 text-xs text-black-600 dark:text-black-500 line-through" data-tooltip={ d + " (missing)" }>{ skillDirLabel(d) }</span>
				}
			</div>
			<!-- Entries table -->
			if len(vm.Entries) == 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-6 py-12 text-center text-sm text-black-700 dark:text-black-600">
					Folder is empty.
				</div>
			} else {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
					<table class="w-full text-sm">
						<thead>
							<tr class="border-b border-white-300 dark:border-navy-600 text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">
								<th class="px-5 py-3 text-left">Name</th>
								<th class="px-5 py-3 text-left">Present In</th>
								<th class="px-5 py-3 text-right">Actions</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-white-300 dark:divide-navy-600">
							for _, f := range vm.Entries {
								<tr
								data-row-link={ func() string { if f.IsDir { return vm.Base + "/skills/" + vm.FolderName + "/" + f.Name } else { return vm.Base + "/skills/" + vm.FolderName + "/files/" + f.Name } }() }
									class="cursor-pointer hover:bg-white-200 dark:hover:bg-navy-800 transition-colors group"
								>
									<td class="px-5 py-3">
										<div class="flex items-center gap-2">
											if f.IsDir {
												<svg class="w-4 h-4 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }/</span>
											} else {
												<svg class="w-4 h-4 text-black-500 dark:text-black-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }</span>
											}
										</div>
									</td>
									<td class="px-5 py-3">
										<div class="flex flex-wrap gap-1">
											for _, d := range f.InDirs {
												<span class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-300 dark:border-green-700 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400" data-tooltip={ d }>{ skillDirLabel(d) }</span>
											}
											for _, d := range f.Missing {
												<span class="rounded-full bg-white-300 dark:bg-navy-600 border border-white-400 dark:border-navy-500 px-2 py-0.5 text-xs text-black-600 dark:text-black-500 line-through" data-tooltip={ d + " (missing)" }>{ skillDirLabel(d) }</span>
											}
										</div>
									</td>
									<td class="px-5 py-3 text-right" data-row-action>
										@kebabMenuMulti([]kebabAction{
											{Label: "Delete", Variant: "danger", DataAttr: "data-delete-skill", DataVal: vm.Base + "/skills/" + vm.FolderName + "/files/" + f.Name + "/delete"},
										})
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		</div>
		<script src={ vm.Base + "/static/js/skills.js" }></script>
	}
}

templ SkillProviderFolderPage(vm SkillProviderFolderVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<!-- Breadcrumb -->
			<div class="flex items-center justify-between gap-3 flex-wrap">
				<div class="flex items-center gap-2 text-sm flex-wrap">
					<a href={ templ.SafeURL(vm.Base + "/skills") } class="text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">← Skills</a>
					<span class="text-black-500">/</span>
					<span class="font-mono font-semibold text-black-900 dark:text-white-100">{ vm.FolderName }</span>
				</div>
				<!-- Provider tab switcher -->
				<div class="flex items-center gap-1">
					for _, p := range vm.AllProviders {
						if p == vm.Provider {
							<span class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-600 px-3 py-0.5 text-xs font-semibold text-green-700 dark:text-green-400">{ p }</span>
						} else {
							<a href={ templ.SafeURL(vm.Base + "/skills/" + p + "/" + vm.FolderName) } class="rounded-full border border-white-400 dark:border-navy-600 px-3 py-0.5 text-xs text-black-700 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-700">{ p }</a>
						}
					}
					<form method="POST" action={ templ.SafeURL(vm.Base + "/skills-sync/" + vm.Provider + "/" + vm.FolderName) } class="ml-2">
						<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Sync to all</button>
					</form>
				</div>
			</div>
			<!-- File list -->
			if len(vm.Entries) == 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-6 py-12 text-center text-sm text-black-700 dark:text-black-600">Folder is empty.</div>
			} else {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
					<table class="w-full text-sm">
						<thead>
							<tr class="border-b border-white-300 dark:border-navy-600 text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">
								<th class="px-5 py-3 text-left">Name</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-white-300 dark:divide-navy-600">
							for _, f := range vm.Entries {
								<tr
									data-row-link={ vm.Base + "/skills/" + vm.Provider + "/" + vm.FolderName + "/files/" + f.Name }
									class="cursor-pointer hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
								>
									<td class="px-5 py-3">
										<div class="flex items-center gap-2">
											if f.IsDir {
												<svg class="w-4 h-4 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }/</span>
											} else {
												<svg class="w-4 h-4 text-black-500 dark:text-black-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
												<span class="font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }</span>
											}
										</div>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		</div>
		<script src={ vm.Base + "/static/js/skills.js" }></script>
	}
}

templ SkillProviderFilePage(vm SkillProviderFileVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-4">
			<!-- Breadcrumb + provider tabs -->
			<div class="flex items-center justify-between gap-3 flex-wrap">
				<div class="flex items-center gap-2 text-sm flex-wrap">
					<a href={ templ.SafeURL(vm.Base + "/skills") } class="text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">← Skills</a>
					<span class="text-black-500">/</span>
					<a href={ templ.SafeURL(vm.Base + "/skills/" + vm.Provider + "/" + vm.FolderName) } class="text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100 font-mono">{ vm.FolderName }</a>
					<span class="text-black-500">/</span>
					<span class="font-mono font-semibold text-black-900 dark:text-white-100">{ vm.Filename }</span>
				</div>
				<!-- Provider tab switcher -->
				<div class="flex items-center gap-1">
					for _, p := range vm.AllProviders {
						if !vm.HasFile[p] {
							<span class="rounded-full border border-white-300 dark:border-navy-700 px-3 py-0.5 text-xs text-black-500 dark:text-black-600 line-through" title="not present">{ p }</span>
						} else if p == vm.Provider {
							<span class="rounded-full bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-600 px-3 py-0.5 text-xs font-semibold text-green-700 dark:text-green-400">{ p }</span>
						} else {
							<a href={ templ.SafeURL(vm.Base + "/skills/" + p + "/" + vm.FolderName + "/files/" + vm.Filename) } class="rounded-full border border-white-400 dark:border-navy-600 px-3 py-0.5 text-xs text-black-700 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-700">{ p }</a>
						}
					}
				</div>
			</div>
			<!-- Content -->
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden flex flex-col" style="min-height: calc(100vh - 160px)">
				<div class="px-4 py-2 border-b border-white-300 dark:border-navy-600 text-xs text-black-600 dark:text-black-500 shrink-0">{ vm.SourcePath }</div>
				<div data-md class="px-5 py-4 space-y-1 overflow-x-auto flex-1">{ vm.Content }</div>
			</div>
		</div>
		<script src={ vm.Base + "/static/js/skills.js" }></script>
	}
}

// skillDirLabel returns a short label from a full dir path.
func skillDirLabel(dir string) string {
	// dir like /home/user/.claude/skills → "claude"
	// dir like C:\Users\user\.codex\skills → "codex"
	// walk backwards: skip last segment ("skills"), take segment before it
	clean := strings.TrimRight(strings.ReplaceAll(dir, "\\", "/"), "/")
	parts := strings.Split(clean, "/")
	for i := len(parts) - 1; i >= 0; i-- {
		seg := strings.TrimLeft(parts[i], ".")
		if seg != "" && seg != "skills" {
			return seg
		}
	}
	return dir
}
