package view

// ProcessPanel renders the right-side slide-over showing active spawn
// processes for the current session. Tab handle sits above the Context
// tab. All live updates come via SSE through process.js.
templ ProcessPanel(base, sessionID string) {
	<!-- Process tab handle -->
	<button
		type="button"
		data-process-open
		title="Active processes"
		class="group fixed z-20 right-0 inline-flex flex-col items-center justify-center gap-1.5 rounded-l-xl border border-r-0 border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-1.5 py-3 shadow-md hover:bg-white-200 dark:hover:bg-navy-800 hover:pr-2 transition-all"
		style="top: calc(50% - 140px)"
	>
		<svg viewBox="0 0 16 16" class="h-4 w-4 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5">
			<rect x="2" y="2" width="12" height="12" rx="1.5" stroke-linejoin="round"/>
			<path d="M5 8h6M5 5.5h4M5 10.5h3" stroke-linecap="round"/>
		</svg>
		<span class="text-[10px] font-medium text-black-700 dark:text-black-600 [writing-mode:vertical-rl] [transform:rotate(180deg)] tracking-wide">Process</span>
		<span
			data-process-fab-count
			class="hidden items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-green-500 text-white-100 text-[10px] font-semibold"
		>0</span>
	</button>
	<!-- Backdrop -->
	<div
		data-process-backdrop
		class="hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm"
	></div>
	<!-- Slide-over -->
	<aside
		data-process-panel
		data-session-id={ sessionID }
		data-base={ base }
		class="hidden fixed top-0 right-0 z-40 h-full w-full sm:w-[420px] bg-white-100 dark:bg-navy-700 border-l border-white-300 dark:border-navy-600 shadow-xl flex flex-col"
	>
		<!-- Header -->
		<div class="flex items-center justify-between px-4 py-3 border-b border-white-300 dark:border-navy-600 shrink-0">
			<div class="flex items-center gap-2">
				<svg viewBox="0 0 16 16" class="h-4 w-4 text-green-500 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5">
					<rect x="2" y="2" width="12" height="12" rx="1.5" stroke-linejoin="round"/>
					<path d="M5 8h6M5 5.5h4M5 10.5h3" stroke-linecap="round"/>
				</svg>
				<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Active Processes</h2>
				<span data-process-count class="rounded-full bg-green-500 text-white-100 text-[10px] font-semibold min-w-[18px] h-[18px] px-1 inline-flex items-center justify-center hidden">0</span>
			</div>
			<button type="button" data-process-close class="rounded-lg p-1.5 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
				<svg viewBox="0 0 16 16" class="h-4 w-4 text-black-700 dark:text-black-600" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M3 3l10 10M13 3L3 13" stroke-linecap="round"/>
				</svg>
			</button>
		</div>
		<!-- Process list -->
		<div data-process-list class="flex-1 overflow-y-auto p-4 space-y-3">
			<p class="text-xs text-black-700 dark:text-black-600">Loading…</p>
		</div>
	</aside>
}
