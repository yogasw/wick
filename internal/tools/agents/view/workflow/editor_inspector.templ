package workflow

// EditorInspector — right sidebar. Theme palette matches agents.
templ EditorInspector(vm EditorVM) {
	<aside class="w-80 shrink-0 border-l border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 p-4 text-sm overflow-y-auto" id="wf-inspector">
		<div class="text-[11px] uppercase tracking-wider text-black-700 dark:text-black-600 font-semibold mb-3">Inspector</div>

		<div id="inspector-empty" class="text-sm text-black-600 dark:text-black-700 italic">
			Click a node to edit its fields.<br/>
			Drag from palette to add a new node.
		</div>

		<div id="inspector-node" class="hidden">
			<div class="bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-3 mb-3">
				<div class="text-[11px] uppercase tracking-wider text-black-700 dark:text-black-600 mb-1">Selected node</div>
				<div class="font-semibold text-black-900 dark:text-white-100" id="ins-id"></div>
				<div class="text-xs text-black-700 dark:text-black-600 mt-0.5">type: <span id="ins-type" class="font-mono"></span></div>
			</div>

			<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Label</label>
			<input id="ins-label" type="text" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none"/>

			<div id="ins-prompt-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Prompt</label>
				<textarea id="ins-prompt" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 font-mono text-xs text-black-900 dark:text-white-100 focus:border-green-500 focus:outline-none" rows="4"></textarea>
			</div>

			<div id="ins-cases-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Cases (branches)</label>
				<div id="ins-cases" class="space-y-1 text-xs"></div>
				<button type="button" id="ins-add-case" class="mt-1 text-xs text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300">+ add case</button>
			</div>

			<div id="ins-preset-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Provider</label>
				<select id="ins-provider" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100 mb-2">
					<option value="">(default)</option>
				</select>
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Preset</label>
				<input id="ins-preset" type="text" placeholder="(default)" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100"/>
			</div>

			<div id="ins-command-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Command (one arg per line)</label>
				<textarea id="ins-command" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 font-mono text-xs text-black-900 dark:text-white-100" rows="3"></textarea>
			</div>

			<div id="ins-url-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">URL</label>
				<input id="ins-url" type="text" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 font-mono text-xs text-black-900 dark:text-white-100"/>
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Method</label>
				<select id="ins-method" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100">
					<option>GET</option>
					<option>POST</option>
					<option>PUT</option>
					<option>DELETE</option>
					<option>PATCH</option>
				</select>
			</div>

			<div id="ins-channel-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Channel</label>
				<select id="ins-channel" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100">
					<option value="">(select channel)</option>
				</select>
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Op</label>
				<select id="ins-op" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100">
					<option value="">(select op)</option>
				</select>
				<div id="ins-channel-empty" class="hidden mt-2 text-xs text-amber-600 dark:text-amber-400">No channel registered. Configure one in Channels tab first.</div>
			</div>

			<div id="ins-connector-panel" class="hidden">
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Module</label>
				<select id="ins-module" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100">
					<option value="">(select module)</option>
				</select>
				<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1 mt-3">Op</label>
				<select id="ins-conn-op" class="w-full bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg p-2 text-xs text-black-900 dark:text-white-100">
					<option value="">(select op)</option>
				</select>
			</div>

			<div class="mt-4 p-3 bg-green-500/10 dark:bg-green-500/15 border border-green-500/30 dark:border-green-500/20 rounded-lg text-xs text-green-800 dark:text-green-300">
				<strong>Output refs available:</strong>
				<div id="ins-refs" class="mt-1 space-y-0.5 font-mono text-green-700 dark:text-green-400"></div>
			</div>

			<button type="button" id="ins-delete" class="mt-4 w-full text-xs text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-900/20 border border-rose-300 dark:border-rose-700 rounded-lg py-1.5 transition-colors">Delete node</button>
		</div>
	</aside>
}
