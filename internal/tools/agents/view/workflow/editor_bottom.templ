package workflow

// EditorBottom — tabbed pane under canvas with a collapse toggle so
// the bottom area doesn't eat the canvas vertical space. Default
// state: collapsed (just tab bar visible); user clicks any tab to
// expand. Theme palette matches agents.
templ EditorBottom(vm EditorVM) {
	<div class="shrink-0 border-t border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700" id="wf-bottom">
		<div class="flex items-center border-b border-white-300 dark:border-navy-600 text-sm">
			<button type="button" data-bottom-tab="logs" class="px-4 py-2 border-b-2 border-green-500 text-green-700 dark:text-green-400 font-medium">
				Logs <span id="wf-logs-counter" class="ml-1 text-xs text-black-600 dark:text-black-700">(0)</span>
			</button>
			<button type="button" data-bottom-tab="yaml" class="px-4 py-2 text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">YAML preview</button>
			<button type="button" data-bottom-tab="runs" class="px-4 py-2 text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">Runs ({ runsLabel(len(vm.Runs)) })</button>
			<button type="button" data-bottom-tab="guard" class="px-4 py-2 text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">Guard</button>
			<span id="wf-run-cancel-host" class="ml-auto"></span>
			<button type="button" id="wf-bottom-toggle" class="px-3 py-2 text-xs text-black-600 dark:text-black-700 hover:text-black-900 dark:hover:text-white-100" data-collapsed="true">▴ expand</button>
		</div>
		<div id="wf-bottom-body" class="hidden">
			// Logs is the default — empty state until a run kicks off,
			// SSE events fill it in as nodes complete. Each row expands
			// to show input/output JSON + latency.
			<div data-bottom-panel="logs" class="p-3 max-h-72 overflow-y-auto text-xs">
				<div id="wf-logs-list" class="space-y-1"></div>
				<p id="wf-logs-empty" class="text-black-600 dark:text-black-700 italic">No run yet. Click Run Now to execute the workflow.</p>
			</div>
			<div data-bottom-panel="yaml" class="hidden">
				<pre id="wf-yaml" class="p-4 font-mono text-xs text-white-100 bg-navy-800 dark:bg-black-900 overflow-x-auto leading-relaxed max-h-48">{ vm.YAML }</pre>
			</div>
			<div data-bottom-panel="runs" class="hidden p-4 max-h-48 overflow-y-auto">
				@bottomRuns(vm.Base, vm.Slug, vm.Runs)
			</div>
			<div data-bottom-panel="guard" class="hidden p-4 max-h-48 overflow-y-auto">
				@bottomGuard(vm.GuardReport)
			</div>
		</div>
	</div>
}

templ bottomRuns(base, slug string, runs []string) {
	if len(runs) == 0 {
		<p class="text-sm text-black-600 dark:text-black-700">No runs yet.</p>
	} else {
		<ul class="space-y-1 font-mono text-xs">
			for _, rid := range runs {
				<li>
					<a href={ templ.SafeURL(base + "/workflows/edit/" + slug + "/runs/" + rid) } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300">{ rid }</a>
				</li>
			}
		</ul>
	}
}

templ bottomGuard(rep *guardReportLike) {
	if rep == nil || rep.OK {
		<p class="text-sm text-green-700 dark:text-green-400">No guard violations.</p>
	} else {
		<ul class="space-y-1 text-sm text-red-800 dark:text-red-300">
			for _, v := range rep.Violations {
				<li>
					<span class="font-mono text-xs bg-red-50 dark:bg-red-900/30 px-1.5 py-0.5 rounded">{ v.Rule }</span>
					<span class="ml-2">{ v.Message }</span>
					<span class="text-xs text-black-700 dark:text-black-600"> ({ v.Severity })</span>
				</li>
			}
		</ul>
	}
}
