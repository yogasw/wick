package workflow

// EditorPalette renders the palette as a left-side slide-in drawer.
// Opens when the user clicks the "+" pill in the top-right canvas
// controls — keeps the main canvas full-width by default and only
// surfaces palette items on demand (n8n's "Add node" pattern). The
// drawer closes via the X button, ESC, or clicking outside.
templ EditorPalette(sections []PaletteSection) {
	<aside class="wf-palette-drawer hidden" id="wf-palette">
		<div class="wf-palette-shell">
			<div class="wf-palette-header">
				<div class="text-sm font-semibold text-black-900 dark:text-white-100">Add node</div>
				<button type="button" class="wf-palette-close" data-palette-close aria-label="Close palette">×</button>
			</div>
			<input type="text" id="wf-palette-search" placeholder="Search nodes…" class="wf-palette-search"/>
			<div class="wf-palette-list">
				for _, section := range sections {
					<div class="text-[11px] uppercase tracking-wider text-black-700 dark:text-black-600 font-semibold mb-2 mt-2" data-palette-section>{ section.Title }</div>
					<div class="space-y-1 mb-4">
						for _, item := range section.Items {
							@paletteRow(item)
						}
					</div>
				}
			</div>
		</div>
	</aside>
}

// paletteRow is one draggable palette entry.
templ paletteRow(item PaletteItem) {
	<div
		class="wf-palette-item flex items-center gap-2 px-3 py-2 bg-white-100 dark:bg-navy-700 border border-white-300 dark:border-navy-600 rounded-lg text-black-900 dark:text-white-100 hover:border-green-500/40 dark:hover:border-green-500/40 transition-colors"
		draggable="true"
		data-node-type={ item.Type }
	>
		<span class={ "h-2 w-2 rounded-full", item.Dot }></span>
		<span class="text-sm">{ item.Label }</span>
		if item.Hint != "" {
			<span class="ml-auto text-[10px] text-black-600 dark:text-black-700">{ item.Hint }</span>
		}
	</div>
}
