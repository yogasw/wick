package workflow

import (
	"strconv"
	"time"

	"github.com/yogasw/wick/internal/agents/workflow/mcp"
)

// Runs tab — server-rendered list of recent runs with collapsible
// detail rows + a pager. Live runs prepend via bottom_tab_runs.js.
templ bottomTabRuns(vm EditorVM) {
	<div data-bottom-panel="runs" class="hidden p-4 max-h-72 overflow-y-auto">
		@bottomRuns(vm.Base, vm.ID, vm.Runs, vm.RunsPage, vm.RunsHasMore)
	</div>
}

// bottomRuns renders the recent runs list. Each row shows the
// human-readable timestamp by default; clicking expands a detail
// line with the full run ID + status (mirrors the n8n executions
// panel). The link target is the run detail page; the click toggle
// is wired in editor.js so we don't pull a stylesheet just for the
// expand state.
templ bottomRuns(base, id string, runs []mcp.RunSummary, page int, hasMore bool) {
	if len(runs) == 0 && page <= 1 {
		<p class="text-sm text-black-600 dark:text-black-700">No runs yet.</p>
	} else {
		<ul class="space-y-1 text-xs" id="wf-runs-list">
			for _, r := range runs {
				<li class="wf-run-row" data-run-id={ r.ID }>
					<button type="button" class="wf-run-head" data-run-toggle>
						<span class={ "wf-run-status wf-run-status-" + runStatusKey(r.Status) }>{ runStatusKey(r.Status) }</span>
						<span class="wf-run-time">{ formatRunTime(r.StartedAt) }</span>
						<span class="wf-run-dur">{ formatRunDuration(r) }</span>
					</button>
					<div class="wf-run-detail hidden">
						<div class="flex items-center gap-2">
							<div class="flex-1 font-mono text-[11px] text-black-700 dark:text-black-600 break-all">{ r.ID }</div>
							<button type="button" data-run-copy-id={ r.ID } class="text-[11px] text-green-600 dark:text-green-400 hover:underline" title="Copy run ID">copy</button>
						</div>
						<div class="mt-2 flex gap-3 text-xs">
							<button type="button" data-run-replay={ r.ID } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300 font-medium" title="Load this run's events + node outputs into the editor for debugging">↻ Replay in editor</button>
							<button
								type="button"
								data-run-copy-to-editor={ r.ID }
								data-copy-url={ base + "/workflows/edit/" + id + "/runs/" + r.ID + "/copy-to-editor" }
								class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium"
								title="Restore this run's workflow graph as the current draft"
							>⤴ Copy to editor</button>
							<button type="button" data-run-export={ r.ID } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300" title="Copy full run state (events + outputs) as JSON">Export JSON</button>
							<a href={ templ.SafeURL(base + "/workflows/edit/" + id + "/runs/" + r.ID) } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300">Open run detail →</a>
						</div>
					</div>
				</li>
			}
		</ul>
		// Pager — prev/next link bound to `runs_page` query.
		<div class="mt-3 flex items-center gap-3 text-xs">
			if page > 1 {
				<a href={ templ.SafeURL(base + "/workflows/edit/" + id + "?runs_page=" + pageStr(page-1)) } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300">← Newer</a>
			} else {
				<span class="text-black-700 dark:text-black-600 opacity-50 cursor-not-allowed">← Newer</span>
			}
			<span class="text-black-700 dark:text-black-600">Page { pageStr(page) }</span>
			if hasMore {
				<a href={ templ.SafeURL(base + "/workflows/edit/" + id + "?runs_page=" + pageStr(page+1)) } class="text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300">Older →</a>
			} else {
				<span class="text-black-700 dark:text-black-600 opacity-50 cursor-not-allowed">Older →</span>
			}
		</div>
	}
}

func pageStr(n int) string {
	return strconv.Itoa(n)
}

// runStatusKey normalises an empty status to "queued" so the CSS
// selector class stays valid.
func runStatusKey(s string) string {
	if s == "" {
		return "queued"
	}
	return s
}

// formatRunTime renders a started-at timestamp like
// "2026-05-15 14:23:47" — local time, second precision (per user
// request). UTC fields are rendered in local TZ so operators can
// match against their wall clock.
func formatRunTime(t time.Time) string {
	if t.IsZero() {
		return "—"
	}
	return t.Local().Format("2006-01-02 15:04:05")
}

// formatRunDuration shows wall-clock duration when both start and
// end are known. Empty otherwise — caller's CSS hides the slot via
// :empty so the row layout stays tight.
func formatRunDuration(r mcp.RunSummary) string {
	if r.EndedAt == nil || r.StartedAt.IsZero() {
		return ""
	}
	d := r.EndedAt.Sub(r.StartedAt)
	if d < time.Second {
		return d.Truncate(time.Millisecond).String()
	}
	return d.Truncate(time.Second).String()
}
