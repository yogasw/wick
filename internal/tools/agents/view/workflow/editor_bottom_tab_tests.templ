package workflow

// Tests tab — wraps the test results panel + the per-test modal shell.
// Modal body fields are always present; the case list is loaded into
// #wf-test-results on tab click (editor.js → bindTestManager).
templ bottomTabTests(vm EditorVM) {
	<div data-bottom-panel="tests" class="hidden max-h-72 overflow-y-auto">
		<div id="wf-test-results" class="text-xs">
			<div class="p-3 italic text-black-600 dark:text-black-700">Click <strong>Tests</strong> tab to load test cases.</div>
		</div>
	</div>
	@testCaseModal(vm)
}

templ testCaseModal(vm EditorVM) {
	<div class="wf-tc-modal hidden" id="wf-tc-modal" data-id={ vm.ID } data-base={ vm.Base }>
		<div class="wf-tc-backdrop" data-wf-tc-cancel></div>
		<div class="wf-tc-shell">
			<div class="wf-tc-header">
				<span id="wf-tc-modal-title" class="font-semibold text-black-900 dark:text-white-100">New Test Case</span>
				<button type="button" class="ml-auto text-black-600 dark:text-black-500 hover:text-black-900 dark:hover:text-white-100 text-xl leading-none" data-wf-tc-cancel>×</button>
			</div>
			<div class="wf-tc-body">
				<input type="hidden" id="wf-tc-edit-name"/>
				<label class="block text-xs font-semibold text-black-800 dark:text-black-300 mb-1">Name <span class="text-red-500">*</span></label>
				<input id="wf-tc-name" type="text" class="wf-input w-full mb-4" placeholder="test-bug-flow"/>
				<div class="grid grid-cols-3 gap-2 mb-3">
					<div>
						<label class="block text-xs font-semibold text-black-800 dark:text-black-300 mb-1">Trigger type</label>
						<select id="wf-tc-evt-type" class="wf-input w-full">
							<option value="manual">manual</option>
							<option value="channel">channel</option>
							<option value="webhook">webhook</option>
							<option value="cron">cron</option>
						</select>
					</div>
					<div id="wf-tc-channel-col">
						<label class="block text-xs font-semibold text-black-800 dark:text-black-300 mb-1">Channel</label>
						<select id="wf-tc-channel" class="wf-input w-full">
							<option value="slack">slack</option>
							<option value="telegram">telegram</option>
						</select>
					</div>
					<div id="wf-tc-subtype-col">
						<label class="block text-xs font-semibold text-black-800 dark:text-black-300 mb-1">Subtype</label>
						<select id="wf-tc-subtype" class="wf-input w-full">
							<option value="message">message</option>
							<option value="action">action</option>
							<option value="submission">submission</option>
						</select>
					</div>
				</div>
				<label class="block text-xs font-semibold text-black-800 dark:text-black-300 mb-1">Payload <span class="text-black-500 dark:text-black-600 font-normal">(JSON)</span></label>
				<textarea id="wf-tc-payload" class="wf-input w-full font-mono text-xs mb-4" rows="5" placeholder={ `{ "text": "ada bug di checkout" }` }></textarea>
				<div class="flex items-center mb-2">
					<label class="text-xs font-semibold text-black-800 dark:text-black-300 flex-1">Assertions</label>
					<button type="button" class="text-xs text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300" id="wf-tc-add-assertion">+ Add</button>
				</div>
				<div id="wf-tc-assertions" class="space-y-1.5 mb-4"></div>
				<div id="wf-tc-error" class="hidden text-xs text-red-600 dark:text-red-400 mb-2"></div>
			</div>
			<div class="wf-tc-footer">
				<button type="button" class="wf-tc-footer-btn wf-tc-footer-cancel" data-wf-tc-cancel>Cancel</button>
				<button type="button" class="wf-tc-footer-btn wf-tc-footer-save" id="wf-tc-save">Save Test Case</button>
			</div>
		</div>
	</div>
}
