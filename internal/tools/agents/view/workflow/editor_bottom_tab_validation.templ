package workflow

// Validation tab — explains every error/warning the parser surfaces
// for the current draft. Draft save is intentionally lenient (the
// server always writes draft.yaml even when validation fails); Publish
// is the strict gate that blocks on errors. This tab is where the
// operator looks to learn *what* the publish gate will reject and
// *why* — without having to scan node badges one at a time.
//
// Initial render uses the server-side validation report; live updates
// arrive via bottom_tab_validation.js after every auto-save.
templ bottomTabValidation() {
	<div data-bottom-panel="validation" class="hidden p-4 max-h-72 overflow-y-auto text-sm">
		<div id="wf-validation-summary" class="mb-3 hidden">
			<span class="font-semibold" data-wf-validation-headline></span>
			<span class="ml-2 text-xs text-black-700 dark:text-black-600" data-wf-validation-subtext></span>
		</div>
		<div id="wf-validation-empty" class="text-green-700 dark:text-green-400">
			✓ No validation issues. Draft is ready to publish.
		</div>
		<ul id="wf-validation-errors" class="hidden space-y-2"></ul>
		<div id="wf-validation-warnings-wrap" class="hidden mt-4">
			<div class="text-xs font-semibold text-amber-700 dark:text-amber-400 mb-1">Warnings</div>
			<ul id="wf-validation-warnings" class="space-y-2"></ul>
		</div>
	</div>
}
