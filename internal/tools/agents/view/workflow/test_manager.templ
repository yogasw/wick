package workflow

import (
	"encoding/json"
	"fmt"
	"strings"

	"github.com/yogasw/wick/internal/agents/workflow/wftest"
)

// TestCaseItem is one row in the manager list.
type TestCaseItem struct {
	Name   string           // slug-safe name (no path, no .json)
	Case   wftest.Case      // parsed fixture
	Result *wftest.Result   // nil = not yet run
}

// TestManagerVM is the view model for the full tests tab panel.
type TestManagerVM struct {
	ID    string
	Base  string
	Items []TestCaseItem
}

// TestCaseRowVM is the view model for a single result row (returned
// after running one case).
type TestCaseRowVM struct {
	ID   string
	Base string
	Item TestCaseItem
}

// tcStatusIcon returns the icon for a case item.
func tcStatusIcon(item TestCaseItem) string {
	if item.Result == nil {
		return "○"
	}
	if item.Result.Pass {
		return "✓"
	}
	return "✗"
}

func tcStatusClass(item TestCaseItem) string {
	if item.Result == nil {
		return "text-black-500 dark:text-black-600"
	}
	if item.Result.Pass {
		return "text-green-600 dark:text-green-400"
	}
	return "text-red-600 dark:text-red-400"
}

func tcRowBg(item TestCaseItem) string {
	if item.Result == nil {
		return "bg-white-100 dark:bg-navy-800 border border-white-300 dark:border-navy-600"
	}
	if item.Result.Pass {
		return "bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-800"
	}
	return "bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800"
}

func tcDuration(item TestCaseItem) string {
	if item.Result == nil {
		return ""
	}
	return fmt.Sprintf("%dms", item.Result.Duration.Milliseconds())
}

func tcCaseJSON(c wftest.Case) string {
	b, _ := json.MarshalIndent(c, "", "  ")
	return string(b)
}

func tcAssertionCount(c wftest.Case) string {
	n := len(c.Assertions)
	if n == 0 {
		return "no assertions"
	}
	if n == 1 {
		return "1 assertion"
	}
	return fmt.Sprintf("%d assertions", n)
}

func tcSafeName(name string) string {
	return strings.ReplaceAll(name, "/", "_")
}

// TestManager renders the test case list panel (injected into #wf-test-results).
// The modal lives in EditorBottom so it's present in the DOM at page load.
templ TestManager(vm TestManagerVM) {
	<div class="flex flex-col" id="wf-test-manager">
		<!-- header bar -->
		<div class="flex items-center gap-2 px-3 py-2 border-b border-white-300 dark:border-navy-600">
			<span class="text-xs font-semibold text-black-800 dark:text-black-200 flex-1">
				{ fmt.Sprintf("%d test case(s)", len(vm.Items)) }
			</span>
			<button
				type="button"
				class="px-2.5 py-1 text-xs rounded-md bg-white-200 dark:bg-navy-700 border border-white-400 dark:border-navy-500 text-black-700 dark:text-black-400 hover:border-green-500 dark:hover:border-green-500 hover:text-green-700 dark:hover:text-green-400 transition-colors"
				data-wf-tc-new
			>+ New</button>
			if len(vm.Items) > 0 {
				<button
					type="button"
					class="px-2.5 py-1 text-xs rounded-md bg-green-600 hover:bg-green-700 text-white-100 font-medium transition-colors"
					data-wf-tc-run-all={ vm.Base + "/workflows/edit/" + vm.ID + "/test" }
				>▶ Run All</button>
			}
		</div>
		<!-- case list -->
		<div class="overflow-y-auto p-2 space-y-1 max-h-56">
			if len(vm.Items) == 0 {
				<div class="p-4 text-center text-xs text-black-600 dark:text-black-700">
					<div class="text-2xl mb-2">🧪</div>
					<div class="font-medium text-black-800 dark:text-black-400 mb-1">No test cases yet</div>
					<div>Click <strong>+ New</strong> to add your first test case.</div>
				</div>
			} else {
				for _, item := range vm.Items {
					@TestCaseRow(TestCaseRowVM{ID: vm.ID, Base: vm.Base, Item: item})
				}
			}
		</div>
	</div>
}

// TestCaseRow renders one test case row. Used standalone for per-case run result injection.
templ TestCaseRow(vm TestCaseRowVM) {
	<div
		class={ "rounded-lg p-2 " + tcRowBg(vm.Item) }
		id={ "wf-tc-row-" + tcSafeName(vm.Item.Name) }
	>
		<div class="flex items-center gap-2">
			<span class={ "font-bold text-sm shrink-0 " + tcStatusClass(vm.Item) }>
				{ tcStatusIcon(vm.Item) }
			</span>
			<span class="font-mono text-xs flex-1 text-black-800 dark:text-black-300 truncate" title={ vm.Item.Name }>
				{ vm.Item.Name }
			</span>
			if vm.Item.Result != nil && !vm.Item.Result.Pass {
				<span class="text-xs text-red-600 dark:text-red-400 shrink-0">fail</span>
			}
			if tcDuration(vm.Item) != "" {
				<span class="text-xs text-black-500 dark:text-black-600 shrink-0 font-mono">
					{ tcDuration(vm.Item) }
				</span>
			}
			<button
				type="button"
				title="Run this test"
				class="shrink-0 text-xs px-2 py-0.5 rounded bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors"
				data-wf-tc-run={ vm.Base + "/workflows/edit/" + vm.ID + "/test-cases/" + vm.Item.Name + "/run" }
				data-wf-tc-row={ tcSafeName(vm.Item.Name) }
			>▶</button>
			<button
				type="button"
				title="Edit"
				class="shrink-0 text-xs px-2 py-0.5 rounded bg-white-300 dark:bg-navy-700 text-black-600 dark:text-black-500 hover:text-black-900 dark:hover:text-white-100 transition-colors"
				data-wf-tc-edit={ vm.Item.Name }
				data-wf-tc-json={ tcCaseJSON(vm.Item.Case) }
			>✏</button>
			<button
				type="button"
				title="Delete"
				class="shrink-0 text-xs px-2 py-0.5 rounded bg-white-300 dark:bg-navy-700 text-red-500 hover:text-red-700 dark:hover:text-red-400 transition-colors"
				data-wf-tc-delete={ vm.Base + "/workflows/edit/" + vm.ID + "/test-cases/" + vm.Item.Name }
				data-wf-tc-row={ tcSafeName(vm.Item.Name) }
			>✕</button>
		</div>
		<!-- failure detail -->
		if vm.Item.Result != nil && !vm.Item.Result.Pass {
			<ul class="mt-1 ml-5 space-y-0.5">
				for _, f := range vm.Item.Result.Failures {
					<li class="text-[11px] font-mono text-red-600 dark:text-red-400">{ f }</li>
				}
			</ul>
		}
		<!-- assertion hint when not run yet -->
		if vm.Item.Result == nil {
			<div class="ml-5 mt-0.5 text-[11px] text-black-500 dark:text-black-600">
				{ tcAssertionCount(vm.Item.Case) }
			</div>
		}
	</div>
}
