package view

import (
	"fmt"
	"strings"
	"time"

	"github.com/yogasw/wick/internal/agents/session"
)

// SessionsList renders the full "All chats" page with search.
templ SessionsList(vm SessionsListVM) {
	@AgentsLayout(vm.Layout) {
		<div class="max-w-5xl mx-auto space-y-5" data-base={ vm.Base }>
			<!-- Header -->
			if vm.ScopedProjectID != "" {
				<!-- Claude-style project landing: big title → compose → chats -->
				<a href={ templ.SafeURL(vm.Base + "/sessions") } class="inline-flex items-center gap-1 text-xs text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100 transition-colors">← All chats</a>
				<div class="flex items-start gap-3">
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white-200 dark:bg-navy-800 text-2xl select-none">{ vm.Layout.ProjectIcon(vm.ScopedProjectID) }</div>
					<div class="min-w-0 flex-1">
						<h1 class="text-2xl font-bold text-black-900 dark:text-white-100 truncate">{ vm.ProjectName(vm.ScopedProjectID) }</h1>
						<p class="mt-0.5 flex items-center gap-2 text-xs text-black-700 dark:text-black-600">
							<span>{ fmtCount(vm.Layout.ProjectCounts[vm.ScopedProjectID]) } chats</span>
							if folder := vm.Layout.ScopedFolder(); folder != "" {
								<span class="text-black-600 dark:text-black-700">·</span>
								<span class="font-mono truncate">{ folder }</span>
							}
						</p>
					</div>
					{{ isPinned := vm.Layout.PinnedProjectID == vm.ScopedProjectID }}
					<button
						type="button"
						data-pin-project={ vm.ScopedProjectID }
						title={ pinTitle(isPinned) }
						class={
							"shrink-0 inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors",
							templ.KV("border-green-500/40 bg-green-500/10 text-green-700 dark:text-green-300", isPinned),
							templ.KV("border-white-400 dark:border-navy-600 text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100", !isPinned),
						}
					>
						if isPinned {
							📌 Pinned
						} else {
							📌 Pin as default
						}
					</button>
					<a href={ templ.SafeURL(vm.Base + "/projects/" + vm.ScopedProjectID) } title="Project settings" class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100 transition-colors">⚙ Settings</a>
				</div>
				<!-- Compose box scoped to this project -->
				@composerCard(vm.Composer)
				<!-- Chats in this project -->
				<div class="relative">
					<svg viewBox="0 0 16 16" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-black-600 dark:text-black-700 pointer-events-none" fill="none" stroke="currentColor" stroke-width="1.5">
						<circle cx="6.5" cy="6.5" r="4.5"></circle>
						<path d="M10.5 10.5l3 3" stroke-linecap="round"></path>
					</svg>
					<input
						type="text"
						placeholder="Search chats in this project..."
						data-session-search
						class="w-full rounded-xl border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-700 pl-9 pr-4 py-2.5 text-sm text-black-900 dark:text-white-100 placeholder-black-600 dark:placeholder-black-700 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
					/>
				</div>
				@sessionsFullList(vm)
			} else {
				<div class="flex items-center justify-between">
					<h1 class="text-xl font-semibold text-black-900 dark:text-white-100">All chats</h1>
					<button
						onclick="document.getElementById('create-session-modal').classList.remove('hidden')"
						class="inline-flex items-center gap-2 rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors"
					>
						<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M8 3v10M3 8h10" stroke-linecap="round"></path>
						</svg>
						New chat
					</button>
				</div>
				<!-- Search -->
				<div class="relative">
					<svg viewBox="0 0 16 16" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-black-600 dark:text-black-700 pointer-events-none" fill="none" stroke="currentColor" stroke-width="1.5">
						<circle cx="6.5" cy="6.5" r="4.5"></circle>
						<path d="M10.5 10.5l3 3" stroke-linecap="round"></path>
					</svg>
					<input
						type="text"
						placeholder="Search chats..."
						data-session-search
						class="w-full rounded-xl border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-700 pl-9 pr-4 py-2.5 text-sm text-black-900 dark:text-white-100 placeholder-black-600 dark:placeholder-black-700 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
					/>
				</div>
				@sessionCreateModal(vm)
				@sessionsFullList(vm)
			}
		</div>
		<script src={ vm.Base + "/static/js/agents.js" }></script>
	}
}

templ sessionCreateModal(vm SessionsListVM) {
	<div id="create-session-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
		<div class="w-full max-w-md rounded-2xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6 shadow-2xl mx-4">
			<div class="flex items-center justify-between mb-5">
				<h2 class="text-base font-semibold text-black-900 dark:text-white-100">New Session</h2>
				<button
					type="button"
					onclick="document.getElementById('create-session-modal').classList.add('hidden')"
					class="rounded-lg p-1 text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
				>
					<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M4 4l8 8M12 4l-8 8" stroke-linecap="round"></path>
					</svg>
				</button>
			</div>
			<form method="POST" action={ templ.SafeURL(vm.Base + "/sessions") } class="space-y-4">
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1.5">Project <span class="font-normal text-black-600 dark:text-black-700">(optional)</span></label>
					<select
						name="project_id"
						class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
					>
						<option value="">— no project —</option>
						for _, pid := range vm.ProjectList {
							<option value={ pid }>{ vm.ProjectName(pid) }</option>
						}
					</select>
				</div>
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1.5">Provider</label>
					if len(vm.Providers) == 0 {
						<div class="rounded-lg border border-neg-300 dark:border-neg-700 bg-neg-50 dark:bg-neg-900/20 px-3 py-2.5">
							<p class="text-xs text-neg-600 dark:text-neg-400">
								No healthy providers found. Configure one in <a class="underline font-medium" href={ templ.SafeURL(vm.Base + "/providers") }>Providers</a>.
							</p>
						</div>
					} else {
						<select
							name="provider"
							class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
						>
							for _, p := range vm.Providers {
								<option value={ p.Type }>{ p.Type }/{ p.Name } — { p.Version }</option>
							}
						</select>
					}
				</div>
				<div class="flex justify-end gap-3 pt-1">
					<button
						type="button"
						onclick="document.getElementById('create-session-modal').classList.add('hidden')"
						class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
					>Cancel</button>
					<button
						type="submit"
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 transition-colors disabled:opacity-50"
					>Create</button>
				</div>
			</form>
		</div>
	</div>
}

// sessionsFullList renders the "All chats" list with search-filterable rows.
templ sessionsFullList(vm SessionsListVM) {
	if len(vm.IDs) == 0 {
		<div class="flex flex-col items-center py-16 text-center">
			<p class="text-sm text-black-700 dark:text-black-600">No sessions yet.</p>
		</div>
	} else {
		<div data-session-list data-page-size="10" class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 overflow-hidden divide-y divide-white-300 dark:divide-navy-600">
			for _, id := range vm.IDs {
				if sess, ok := vm.Sessions[id]; ok {
					@sessionsFullRow(vm, id, sess)
				}
			}
			<p data-search-empty class="hidden px-5 py-8 text-center text-sm text-black-600 dark:text-black-700">No chats match your search.</p>
		</div>
		<!-- Client-side pager: pages the rows above 10/page without a reload
		     so the compose box + search text are never lost. Hidden when a
		     single page covers everything; populated by agents.js. -->
		<div data-client-pager class="hidden items-center justify-between pt-2">
			<button type="button" data-pager-prev class="inline-flex items-center gap-1 text-sm text-green-600 dark:text-green-400 hover:underline disabled:opacity-40 disabled:cursor-default disabled:no-underline" disabled>
				<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4L6 8l4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				Prev
			</button>
			<span class="text-xs text-black-700 dark:text-black-600" data-pager-label>Page 1</span>
			<button type="button" data-pager-next class="inline-flex items-center gap-1 text-sm text-green-600 dark:text-green-400 hover:underline disabled:opacity-40 disabled:cursor-default disabled:no-underline">
				Next
				<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
			</button>
		</div>
	}
}

templ sessionsFullRow(vm SessionsListVM, id string, sess session.Session) {
	{{ label := vm.Labels[id] }}
	{{ projectName := vm.ProjectName(sess.Meta.ProjectID) }}
	<div
		data-row-link={ vm.Base + "/sessions/" + id }
		draggable="true"
		data-session-drag={ id }
		title="Drag onto a project in the sidebar to move"
		data-search-row
		data-search-text={
			func() string {
				s := label
				if projectName != "" {
					s += " " + projectName
				}
				return s
			}(),
		}
		class="flex items-center justify-between gap-4 px-5 py-3.5 cursor-pointer hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
	>
		<div class="flex-1 min-w-0">
			<p class="truncate text-sm font-medium text-black-900 dark:text-white-100">
				if label != "" {
					{ label }
				} else if projectName != "" {
					{ projectName }
				} else {
					New session
				}
			</p>
			<div class="flex items-center gap-2 mt-0.5">
				if projectName != "" && label != "" {
					<span class="text-xs text-black-700 dark:text-black-600">{ projectName }</span>
					<span class="text-black-400 dark:text-black-700">·</span>
				}
				<span class="text-xs text-black-600 dark:text-black-700">{ relTime(sess.Meta.LastActive) }</span>
				@statusDot(effectiveStatus(vm.Lifecycle[id].Lifecycle, string(sess.Meta.Status)))
			</div>
		</div>
		<div data-row-action>
			@kebabMenu(kebabAction{Label: "Delete", Variant: "danger", DataAttr: "data-delete-session", DataVal: id})
		</div>
	</div>
}

// SessionsTable is the reusable sessions card list. The Sessions full page
// renders it with paging; the Overview "Active Sessions" panel renders
// it without paging.
templ SessionsTable(vm SessionsTableVM) {
	if len(vm.IDs) == 0 {
		@sessionEmptyState(vm.EmptyText)
	} else {
		<div class="space-y-2">
			for _, id := range vm.IDs {
				if sess, ok := vm.Sessions[id]; ok {
					@sessionCard(vm, id, sess)
				}
			}
		</div>
		if vm.ShowPaging && (vm.Page > 1 || vm.HasNext) {
			@sessionPager(vm)
		}
	}
}

templ sessionEmptyState(text string) {
	<div class="flex flex-col items-center justify-center rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 py-16 text-center">
		<div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-white-200 dark:bg-navy-800">
			<svg viewBox="0 0 24 24" class="h-6 w-6 text-black-600 dark:text-black-700" fill="none" stroke="currentColor" stroke-width="1.5">
				<path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</div>
		<p class="text-sm font-medium text-black-800 dark:text-black-600">{ text }</p>
	</div>
}

templ sessionCard(vm SessionsTableVM, id string, sess session.Session) {
	<div
		data-row-link={ vm.Base + "/sessions/" + id }
		class="group cursor-pointer rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-5 py-4 shadow-sm hover:border-green-400 dark:hover:border-green-700 hover:shadow-md transition-all"
	>
		<div class="flex items-start justify-between gap-4">
			<div class="min-w-0 flex-1">
				<div class="flex flex-wrap items-center gap-2 mb-1.5">
					if pn := vm.ProjectName(sess.Meta.ProjectID); pn != "" {
						<span class="font-semibold text-sm text-black-900 dark:text-white-100">{ pn }</span>
					} else {
						<span class="font-medium text-sm text-black-700 dark:text-black-600 italic">No project</span>
					}
					if lc, ok := vm.Lifecycle[id]; ok {
						@lifecycleBadge(lc.Lifecycle, lc.PID, lc.LastActiveMs, vm.IdleTimeoutMs)
					} else {
						@lifecycleBadge(rowFallbackLifecycle(string(sess.Meta.Status)), 0, 0, vm.IdleTimeoutMs)
					}
				</div>
				<div class="flex flex-wrap items-center gap-3 text-xs text-black-700 dark:text-black-600">
					<span class="font-mono truncate max-w-[160px]" title={ id }>{ id[:min(len(id), 12)] }…</span>
					if sess.Meta.Origin != "" {
						<span class="inline-flex items-center gap-1">
							<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5">
								<circle cx="6" cy="6" r="4.5"></circle>
								<path d="M6 3.5v2.5l1.5 1.5" stroke-linecap="round"></path>
							</svg>
							{ string(sess.Meta.Origin) }
						</span>
					}
					<span class="inline-flex items-center gap-1 text-black-600 dark:text-black-700">
						<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5">
							<path d="M6 1.5v5l3 2" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
						{ relTime(sess.Meta.LastActive) }
					</span>
				</div>
			</div>
			<div class="flex items-center gap-2 shrink-0" data-row-action>
				@kebabMenu(kebabAction{Label: "Delete", Variant: "danger", DataAttr: "data-delete-session", DataVal: id})
			</div>
		</div>
	</div>
}

templ sessionPager(vm SessionsTableVM) {
	<div class="flex items-center justify-between pt-2">
		if vm.Page > 1 {
			<a href={ templ.SafeURL(fmt.Sprintf("%s/sessions?page=%d", vm.Base, vm.Page-1)) } class="inline-flex items-center gap-1 text-sm text-green-600 dark:text-green-400 hover:underline">
				<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4L6 8l4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				Prev
			</a>
		} else {
			<span></span>
		}
		<span class="text-xs text-black-700 dark:text-black-600">Page { fmt.Sprintf("%d", vm.Page) }</span>
		if vm.HasNext {
			<a href={ templ.SafeURL(fmt.Sprintf("%s/sessions?page=%d", vm.Base, vm.Page+1)) } class="inline-flex items-center gap-1 text-sm text-green-600 dark:text-green-400 hover:underline">
				Next
				<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
			</a>
		} else {
			<span></span>
		}
	</div>
}

// ── Session Detail ─────────────────────────────────────────────────────────

// SessionDetail renders the session detail page with tabs and composer.
templ SessionDetail(vm SessionDetailVM) {
	{{
		activeAgent := ""
		activeProvider := ""
		if len(vm.Session.Agents) > 0 {
			activeAgent = vm.Session.Agents[0].Name
			activeProvider = vm.Session.Agents[0].Provider
		}
	}}
	@AgentsLayout(vm.Layout) {
		<!-- Row wrapper: chat column + docked SCM sidebar (push, not overlay).
		     The SCM aside is width-0/hidden until pinned; scm-dock.js flips
		     data-scm-pinned + the width so the chat column reflows. -->
		<div class="flex h-full min-w-0" data-scm-row>
		<div class="relative flex flex-col flex-1 min-w-0" data-session-id={ vm.Session.ID } data-base={ vm.Base } data-active-agent={ activeAgent } data-active-provider={ activeProvider }>
			<!-- Zone 1: transparent overlay bar -->
			<div class="absolute top-0 left-0 right-0 z-20 flex flex-wrap items-center justify-between gap-2 pl-12 pr-2 md:px-4 py-2">
				<!-- Left: tab dropdown -->
				@sessionDetailTabs(vm)
				<!-- Right: info + actions -->
				<div class="flex items-center gap-2 shrink-0">
					if pn := vm.ProjectName(vm.Session.Meta.ProjectID); pn != "" {
						<span class="hidden md:inline text-xs font-medium text-black-700 dark:text-black-600">{ pn }</span>
					}
					if activeAgent != "" || activeProvider != "" {
						<span class="hidden md:inline text-xs text-black-500 dark:text-black-600">{ formatTurnLabel(activeAgent, activeProvider) }</span>
					}
					<span data-sse-status class="hidden inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[10px] font-medium" data-state="">
						<svg data-sse-spin viewBox="0 0 16 16" class="h-2.5 w-2.5 hidden animate-spin" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2a6 6 0 016 6" stroke-linecap="round"></path></svg>
						<svg data-sse-dot viewBox="0 0 8 8" class="h-1.5 w-1.5 hidden" fill="currentColor"><circle cx="4" cy="4" r="3"></circle></svg>
						<span data-sse-label></span>
					</span>
					@lifecycleBadge(effectiveStatus(vm.Lifecycle, string(vm.Session.Meta.Status)), vm.PID, vm.LastActiveMs, vm.IdleTimeoutMs)
					<button data-kill={ vm.Session.ID } aria-label="Kill session" class="inline-flex items-center gap-1.5 rounded-lg border border-cau-400 dark:border-cau-600 px-2 md:px-3 py-1.5 text-xs font-medium text-cau-600 dark:text-cau-400 hover:bg-cau-50 dark:hover:bg-cau-900/20 transition-colors">
						<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4.5"></circle><path d="M4 4l4 4M8 4L4 8" stroke-linecap="round"></path></svg>
						<span class="hidden md:inline">Kill</span>
					</button>
					<button data-delete-session={ vm.Session.ID } aria-label="Delete session" class="inline-flex items-center gap-1.5 rounded-lg border border-neg-300 dark:border-neg-700 px-2 md:px-3 py-1.5 text-xs font-medium text-neg-600 dark:text-neg-400 hover:bg-neg-50 dark:hover:bg-neg-900/20 transition-colors">
						<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M4 3V2h4v1M5 5.5v3M7 5.5v3M3 3l.5 7h5L9 3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
						<span class="hidden md:inline">Delete</span>
					</button>
				</div>
			</div>
			<div class="absolute top-12 left-4 right-4 z-10">
				@GateDisabledBanner(vm.Gate)
			</div>
			<!-- Zone 2: scroll area full width, content centered -->
			<div class="flex-1 overflow-y-auto" data-chat-panel>
				@sessionDetailContent(vm)
			</div>
			<!-- Zone 3: composer fixed at bottom, centered. Floating
			     scroll-to-bottom pill sits just above the top edge. -->
			<div class="relative shrink-0 px-6 pb-6 pt-2 bg-white-200 dark:bg-navy-800">
				<button
					type="button"
					data-scroll-bottom
					class="hidden absolute left-1/2 -translate-x-1/2 -top-3 z-30 inline-flex items-center gap-1.5 rounded-full border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 px-3 py-1 text-[11px] font-medium text-black-700 dark:text-black-600 shadow-sm hover:bg-white-200 dark:hover:bg-navy-800 hover:text-black-900 dark:hover:text-white-100 transition-colors"
					title="Scroll to latest (Ctrl+↓)"
				>
					<svg viewBox="0 0 16 16" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.75">
						<path d="M8 3v9M4 9l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>Jump to latest</span>
					<kbd class="rounded border border-white-400 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-1 text-[10px] font-mono text-black-600 dark:text-black-700">Ctrl+↓</kbd>
				</button>
				<div class="max-w-4xl mx-auto">
					@AskUserCard(vm.Base)
					@chatComposer(vm)
				</div>
			</div>
		</div>
		<!-- Docked SCM sidebar. Hidden until opened from the rail tab.
		     Mobile (below lg): full-screen overlay, not resizable, not pinnable.
		     Desktop (lg and up): resizable push dock; width comes from the
		     scm-w CSS var set by scm-dock.js (drag + persisted). Pin state
		     persisted by scm-dock.js (desktop only). -->
		<aside
			data-scm-dock
			data-scm-session={ vm.Session.ID }
			data-scm-base={ vm.Base }
			data-scm-asset={ vm.SCMAssetURL }
			class="hidden h-full bg-white-100 dark:bg-navy-700 border-white-300 dark:border-navy-600 fixed inset-0 z-40 w-full lg:static lg:inset-auto lg:z-auto lg:w-[var(--scm-w)] lg:shrink-0 lg:border-l lg:relative"
			style="--scm-w: 260px;"
		>
			<!-- Drag handle to resize the dock (desktop only). -->
			<div data-scm-resize class="hidden lg:block absolute left-0 top-0 h-full w-1 cursor-col-resize hover:bg-green-400/40 z-10"></div>
			<div data-scm-host class="h-full w-full">
				<div data-scm-loading class="flex h-full items-center justify-center text-xs text-black-700 dark:text-black-600">Loading source control…</div>
			</div>
		</aside>
		</div>
		@ApprovalModal(vm.Base)
		@ContextPanel(vm.Base, vm.Session.ID)
		<script src={ vm.Base + "/static/js/agents.js" }></script>
		<script src={ vm.Base + "/static/js/context.js" }></script>
		<script src={ vm.Base + "/static/js/process.js" }></script>
		<script src={ vm.Base + "/static/js/scm-dock.js" }></script>
	}
}

templ sessionDetailHeader(vm SessionDetailVM) {
	<div class="flex items-center gap-3 min-w-0">
		<!-- Left: project/agent + badge, session ID as tooltip -->
		<div class="flex items-center gap-2 min-w-0 flex-1">
			if pn := vm.ProjectName(vm.Session.Meta.ProjectID); pn != "" {
				<span class="font-semibold text-sm text-black-900 dark:text-white-100" data-tooltip={ vm.Session.ID }>{ pn }</span>
			} else {
				<span class="font-mono text-xs text-black-600 dark:text-black-700 truncate" data-tooltip={ vm.Session.ID }>{ vm.Session.ID[:12] }…</span>
			}
			if len(vm.Session.Agents) > 0 {
				<span class="text-xs text-black-600 dark:text-black-700">{ vm.Session.Agents[0].Name } · { vm.Session.Agents[0].Provider }</span>
			}
			@lifecycleBadge(effectiveStatus(vm.Lifecycle, string(vm.Session.Meta.Status)), vm.PID, vm.LastActiveMs, vm.IdleTimeoutMs)
		</div>
		<!-- Right: actions -->
		<div class="flex gap-2 shrink-0">
			<button
				data-kill={ vm.Session.ID }
				class="inline-flex items-center gap-1.5 rounded-lg border border-cau-400 dark:border-cau-600 px-3 py-1.5 text-xs font-medium text-cau-600 dark:text-cau-400 hover:bg-cau-50 dark:hover:bg-cau-900/20 transition-colors"
			>
				<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4.5"></circle><path d="M4 4l4 4M8 4L4 8" stroke-linecap="round"></path></svg>
				Kill
			</button>
			<button
				data-delete-session={ vm.Session.ID }
				class="inline-flex items-center gap-1.5 rounded-lg border border-neg-300 dark:border-neg-700 px-3 py-1.5 text-xs font-medium text-neg-600 dark:text-neg-400 hover:bg-neg-50 dark:hover:bg-neg-900/20 transition-colors"
			>
				<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M4 3V2h4v1M5 5.5v3M7 5.5v3M3 3l.5 7h5L9 3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				Delete
			</button>
		</div>
	</div>
}

templ sessionDetailTabs(vm SessionDetailVM) {
	<details class="relative" data-row-action>
		<summary class="list-none cursor-pointer inline-flex items-center gap-1.5 rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-1.5 text-xs font-medium text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors select-none">
			<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h10M1 6h10M1 9h6" stroke-linecap="round"></path></svg>
			{ tabLabel(vm.Tab) }
			<svg viewBox="0 0 12 12" class="h-3 w-3 opacity-50" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
		</summary>
		<div class="absolute top-full left-0 mt-1 z-30 min-w-[140px] rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-lg py-1">
			<a href={ templ.SafeURL(vm.Base+"/sessions/"+vm.Session.ID+"?tab=conversation") } class={ tabDropdownItem(vm.Tab == "conversation") }>Conversation</a>
			<a href={ templ.SafeURL(vm.Base+"/sessions/"+vm.Session.ID+"?tab=commands") } class={ tabDropdownItem(vm.Tab == "commands") }>Commands</a>
			<a href={ templ.SafeURL(vm.Base+"/sessions/"+vm.Session.ID+"?tab=approvals") } class={ tabDropdownItem(vm.Tab == "approvals") }>Approvals</a>
			<a href={ templ.SafeURL(vm.Base+"/sessions/"+vm.Session.ID+"?tab=raw") } class={ tabDropdownItem(vm.Tab == "raw") }>Raw</a>
		</div>
	</details>
}

func tabLabel(tab string) string {
	switch tab {
	case "commands":
		return "Commands"
	case "approvals":
		return "Approvals"
	case "raw":
		return "Raw"
	default:
		return "Conversation"
	}
}

func tabDropdownItem(active bool) string {
	base := "block px-3 py-2 text-xs transition-colors "
	if active {
		return base + "text-green-600 dark:text-green-400 font-medium bg-green-50 dark:bg-green-900/20"
	}
	return base + "text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-800"
}

templ sessionDetailContent(vm SessionDetailVM) {
	<div class="max-w-4xl mx-auto w-full px-6 pt-14 pb-4 flex flex-col gap-4">
		if vm.Tab == "conversation" {
			@sessionConversationTab(vm)
		} else if vm.Tab == "commands" {
			@sessionCommandsTab(vm)
		} else if vm.Tab == "approvals" {
			@sessionApprovalsTab(vm)
		} else {
			@sessionRawTab()
		}
	</div>
}

templ sessionConversationTab(vm SessionDetailVM) {
	<div class="space-y-5" data-turns id="chat-turns">
		if len(vm.Turns) == 0 {
			@chatEmptyState()
		}
		for _, t := range vm.Turns {
			@conversationTurn(t)
		}
		<div id="chat-bottom"></div>
	</div>
}

templ chatEmptyState() {
	<div class="flex flex-col items-center justify-center h-full py-12 text-center">
		<div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-green-50 dark:bg-green-900/20">
			<svg viewBox="0 0 24 24" class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5">
				<path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</div>
		<p class="text-sm font-medium text-black-800 dark:text-black-600">No messages yet</p>
		<p class="mt-1 text-xs text-black-600 dark:text-black-700">Send a message to start.</p>
	</div>
}

templ chatComposer(vm SessionDetailVM) {
	<div class="rounded-2xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 shadow-md" data-composer-drop>
		<form data-send-form>
			<div data-attach-chips class="hidden flex-wrap gap-2 px-3 pt-3"></div>
			<input type="file" multiple class="hidden" data-attach-input/>
			<textarea
				name="text"
				rows="1"
				placeholder="Message the agent…"
				class="w-full resize-none bg-transparent px-4 pt-3 pb-2 text-sm text-black-900 dark:text-white-100 placeholder-black-600 dark:placeholder-black-700 focus:outline-none leading-relaxed"
				style="max-height:160px; overflow-y:auto"
				data-auto-resize
			></textarea>
			<div class="flex items-center justify-between px-3 pb-3 pt-1">
				<div class="flex items-center gap-2">
					<!-- Per-session subscribe bell. push.js owns visibility
					     and icon state via data-state:
					       setup   — browser push not enabled; click jumps
					                 to /profile.
					       off     — push on, this session NOT subscribed;
					                 click POSTs subscribe.
					       on      — green-dot bell; click POSTs unsubscribe.
					       blocked — slash icon; click toasts site-settings
					                 hint.
					     Hidden when the browser doesn't support push.
					     Session id is read from the wrapping
					     data-session-id ancestor. -->
					<button
						type="button"
						id="push-bell-btn"
						data-push-bell
						data-state="off"
						aria-label="Notifications"
						title="Notifications"
						class="hidden relative inline-flex items-center justify-center h-7 w-7 rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-700 text-black-700 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-600 transition-colors"
					>
						<svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path d="M8 2.25c-2.07 0-3.75 1.68-3.75 3.75v2.25L3 9.75v.75h10v-0.75L11.75 8.25V6c0-2.07-1.68-3.75-3.75-3.75z" stroke-linejoin="round"></path>
							<path d="M6.5 12a1.5 1.5 0 0 0 3 0" stroke-linecap="round"></path>
							<path d="M3 3l10 10" stroke-linecap="round" class="hidden" data-push-bell-slash></path>
						</svg>
						<span class="hidden absolute -top-0.5 -right-0.5 h-2 w-2 rounded-full bg-green-500 ring-2 ring-white-200 dark:ring-navy-700" data-push-bell-dot aria-hidden="true"></span>
					</button>
					<button
						type="button"
						data-attach-toggle
						class="inline-flex items-center justify-center h-7 w-7 rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-700 text-black-700 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-600 transition-colors"
						title="Attach file"
					>
						<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 7.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
						</svg>
					</button>
					if len(vm.Providers) > 0 {
						<div class="relative" data-row-action="">
							<button
								type="button"
								data-provider-menu-toggle
								class="inline-flex items-center gap-1.5 rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-700 px-2.5 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-600 transition-colors"
							>
								<svg viewBox="0 0 12 12" class="h-3 w-3 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="4.5" r="2"></circle><path d="M2 10c0-2.21 1.79-4 4-4s4 1.79 4 4" stroke-linecap="round"></path></svg>
								<span data-active-provider-label>{ vm.ActiveProvider }</span>
								<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
							</button>
							<div data-provider-menu class="hidden absolute bottom-full left-0 mb-1 z-20 min-w-[140px] rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 shadow-lg py-1">
								for _, p := range vm.Providers {
									<button
										type="button"
										data-provider-choice={ p.Type }
										class="w-full text-left px-3 py-2 text-xs text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors flex items-center justify-between gap-2"
									>
										{ p.Type }
										if p.Name != "" && p.Name != p.Type {
											<span class="text-black-600 dark:text-black-700">{ p.Name }</span>
										}
									</button>
								}
							</div>
						</div>
					}
					if len(vm.ProjectList) > 0 {
						<div class="relative" data-row-action="">
							<button
								type="button"
								data-project-menu-toggle
								class="inline-flex items-center gap-1.5 rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-700 px-2.5 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-300 dark:hover:bg-navy-600 transition-colors"
							>
								<svg viewBox="0 0 12 12" class="h-3 w-3 text-black-600 dark:text-black-700" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="10" height="8" rx="1"></rect><path d="M4 3V2.5a.5.5 0 01.5-.5h3a.5.5 0 01.5.5V3" stroke-linecap="round"></path></svg>
								<span data-active-project-label>
									if pn := vm.ProjectName(vm.ActiveProjectID); pn != "" {
										{ pn }
									} else {
										default
									}
								</span>
								<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
							</button>
							<div data-project-menu class="hidden absolute bottom-full left-0 mb-1 z-20 min-w-[160px] rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 shadow-lg py-1">
								<button
									type="button"
									data-project-choice=""
									class="w-full text-left px-3 py-2 text-xs text-black-700 dark:text-black-600 italic hover:bg-white-200 dark:hover:bg-navy-700 transition-colors"
								>
									— no project —
								</button>
								for _, pid := range vm.ProjectList {
									<button
										type="button"
										data-project-choice={ pid }
										class="w-full text-left px-3 py-2 text-xs text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors"
									>
										{ vm.ProjectName(pid) }
									</button>
								}
							</div>
						</div>
					}
				</div>
				<div class="flex items-center gap-2">
					<span class="text-[10px] text-black-600 dark:text-black-700 hidden sm:block">Shift+Enter for newline</span>
					<button
						type="submit"
						class="flex items-center justify-center h-8 w-8 rounded-xl bg-green-500 text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
						title="Send (Enter)"
					>
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M13 8L3 3l2.5 5L3 13l10-5z" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
					</button>
				</div>
			</div>
		</form>
	</div>
}

templ sessionCommandsTab(vm SessionDetailVM) {
	<div class="flex-1 overflow-y-auto" style="max-height:70vh">
		if len(vm.CmdLines) == 0 {
			<div class="flex flex-col items-center justify-center py-16 text-center">
				<div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-white-200 dark:bg-navy-800">
					<svg viewBox="0 0 24 24" class="h-6 w-6 text-black-600 dark:text-black-700" fill="none" stroke="currentColor" stroke-width="1.5">
						<path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</div>
				<p class="text-sm text-black-700 dark:text-black-600">No commands logged yet.</p>
			</div>
		} else {
			<div class="font-mono text-xs">
				<div class="sticky top-0 border-b border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-4 py-2 flex items-center justify-between">
					<span class="text-black-700 dark:text-black-600 font-sans text-xs">{ fmt.Sprintf("%d command(s)", len(vm.CmdLines)) }</span>
				</div>
				for i, line := range vm.CmdLines {
					<div class="flex items-start gap-0 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors group">
						<span class="w-12 shrink-0 px-4 py-2 text-right text-black-600 dark:text-black-700 select-none border-r border-white-300 dark:border-navy-600 group-hover:text-black-700 dark:group-hover:text-black-600">{ fmt.Sprintf("%d", i+1) }</span>
						<span class="flex-1 px-4 py-2 text-black-900 dark:text-white-100 whitespace-pre-wrap break-all">{ line }</span>
					</div>
				}
			</div>
		}
	</div>
}

templ sessionApprovalsTab(vm SessionDetailVM) {
	<div class="flex-1 overflow-y-auto p-5">
		@ApprovedCommandsPanel(vm.Base, vm.Session.ID)
	</div>
}

templ sessionRawTab() {
	<div class="flex-1 p-6">
		<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 p-4">
			<div class="flex items-start gap-3">
				<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white-300 dark:bg-navy-600">
					<svg viewBox="0 0 16 16" class="h-4 w-4 text-black-700 dark:text-black-600" fill="none" stroke="currentColor" stroke-width="1.5">
						<path d="M13 4H3a1 1 0 00-1 1v7a1 1 0 001 1h10a1 1 0 001-1V5a1 1 0 00-1-1z"></path>
						<path d="M10 8H6M8 6v4" stroke-linecap="round"></path>
					</svg>
				</div>
				<div>
					<p class="text-sm font-medium text-black-900 dark:text-white-100">Raw event log</p>
					<p class="mt-1 text-xs text-black-700 dark:text-black-600">
						Stored at <code class="font-mono bg-white-300 dark:bg-navy-600 px-1.5 py-0.5 rounded text-[11px]">raw.jsonl</code> in the session directory when recording is enabled.
					</p>
				</div>
			</div>
		</div>
	</div>
}

templ sessionTab(href, label string, active bool) {
	<a
		href={ templ.SafeURL(href) }
		class={
			"rounded-lg px-4 py-1.5 text-sm font-medium transition-colors",
			templ.KV("bg-white-100 dark:bg-navy-700 text-black-900 dark:text-white-100 shadow-sm", active),
			templ.KV("text-black-800 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100", !active),
		}
	>{ label }</a>
}

// ── Conversation Turn ──────────────────────────────────────────────────────

templ conversationTurn(t TurnVM) {
	switch t.Role {
		case "user":
			@userTurn(t)
		case "assistant":
			@assistantTurn(t)
		default:
			@systemTurn(t)
	}
}

templ userTurn(t TurnVM) {
	<div class="flex justify-end gap-2 group">
		<div class="flex flex-col items-end gap-1 max-w-[80%] min-w-0">
			if !t.Time.IsZero() {
				<span class="text-[10px] text-black-600 dark:text-black-700 opacity-0 group-hover:opacity-100 transition-opacity px-1">{ relTime(t.Time) }</span>
			}
			if len(t.Attachments) > 0 {
				<div class="flex flex-wrap justify-end gap-1.5 max-w-full">
					for _, a := range t.Attachments {
						@attachmentChip(a)
					}
				</div>
			}
			if t.Text != "" {
				<div class="rounded-2xl rounded-tr-sm bg-green-500 px-4 py-3 text-sm text-white-100 whitespace-pre-wrap break-words [overflow-wrap:anywhere] leading-relaxed shadow-sm user-bubble">
					<span data-linkify>{ t.Text }</span>
				</div>
			}
		</div>
	</div>
}

// attachmentChip renders one user-uploaded file as a clickable button.
// Clicking opens the shared preview modal (data-context-modal from
// ContextPanel) via window.AgentContext.previewExternal. Images get an
// inline thumbnail; everything else shows as a compact file row.
templ attachmentChip(a AttachmentVM) {
	if a.IsImage {
		<button
			type="button"
			data-attach-preview
			data-attach-url={ a.URL }
			data-attach-name={ a.Name }
			data-attach-mime={ a.MIME }
			data-attach-size={ fmt.Sprintf("%d", a.Size) }
			class="block rounded-xl overflow-hidden border border-white-300 dark:border-navy-600 shadow-sm bg-white-100 dark:bg-navy-800 hover:shadow-md transition-shadow cursor-pointer"
			title={ a.Name }
		>
			<img src={ a.URL } alt={ a.Name } class="block max-h-56 max-w-[240px] object-contain bg-white-200 dark:bg-navy-900"/>
		</button>
	} else {
		<button
			type="button"
			data-attach-preview
			data-attach-url={ a.URL }
			data-attach-name={ a.Name }
			data-attach-mime={ a.MIME }
			data-attach-size={ fmt.Sprintf("%d", a.Size) }
			class="inline-flex items-center gap-2 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-xs text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors max-w-[240px] cursor-pointer text-left"
			title={ a.Name }
		>
			<svg viewBox="0 0 16 16" class="h-4 w-4 shrink-0 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5">
				<path d="M9 2H4a1 1 0 00-1 1v10a1 1 0 001 1h8a1 1 0 001-1V6L9 2z" stroke-linejoin="round"></path>
				<path d="M9 2v4h4" stroke-linejoin="round"></path>
			</svg>
			<span class="truncate">{ a.Name }</span>
			if a.Size > 0 {
				<span class="text-black-600 dark:text-black-700 shrink-0">{ formatSize(a.Size) }</span>
			}
		</button>
	}
}

templ assistantTurn(t TurnVM) {
	{{ label := formatTurnLabel(t.Agent, t.Provider) }}
	<div class="flex justify-start group">
		<div class="flex flex-col gap-1.5 max-w-[92%] min-w-0" data-turn-events>
			if label != "" {
				<span class="text-xs font-medium text-black-800 dark:text-black-600">{ label }</span>
			}
			if len(t.Events) > 0 || t.HasTrace {
				<div class="flex flex-col gap-1" data-trace-container data-turn-id={ t.TurnID }>
					<button
						type="button"
						data-trace-toggle
						onclick="window.wickToggleTrace(this);"
						class="self-start flex items-center gap-1.5 text-[11px] text-black-500 dark:text-black-600 hover:text-black-700 dark:hover:text-black-500 transition-colors py-0.5"
					>
						<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5.5"></circle><path d="M6 8h4M8 6v4" stroke-linecap="round"></path></svg>
						<span data-trace-label>show trace</span>
						<svg data-chevron viewBox="0 0 16 16" class="h-3 w-3 shrink-0 transition-transform" style="transform:rotate(-90deg)" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
					<div data-trace-wrap class="hidden gap-1">
						for _, ev := range t.Events {
							@turnEventCard(ev)
						}
					</div>
					<button
						type="button"
						data-trace-toggle-bottom
						onclick="window.wickToggleTrace(this);"
						class="hidden self-start items-center gap-1.5 text-[11px] text-black-500 dark:text-black-600 hover:text-black-700 dark:hover:text-black-500 transition-colors py-0.5"
					>
						<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5.5"></circle><path d="M6 8h4M8 6v4" stroke-linecap="round"></path></svg>
						<span>hide trace</span>
						<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
				</div>
			}
			if t.Text != "" {
				<div class="rounded-2xl rounded-tl-sm border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-4 py-3 text-sm text-black-900 dark:text-white-100 break-words leading-relaxed shadow-sm">
					<div class="prose-turn" data-md>{ t.Text }</div>
					if t.Interrupted {
						<div class="mt-2 flex items-center gap-1.5 border-t border-white-300 dark:border-navy-600 pt-2">
							<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2L1.5 13.5h13L8 2z" stroke-linejoin="round"></path><path d="M8 6v4M8 11.5v.5" stroke-linecap="round"></path></svg>
							<span class="text-xs text-amber-600 dark:text-amber-400">Interrupted — response was cut off</span>
						</div>
					} else if t.Truncated {
						<p class="mt-2 text-xs text-black-600 dark:text-black-700 italic border-t border-white-300 dark:border-navy-600 pt-2">Output truncated — see raw.jsonl for full content.</p>
					}
				</div>
			} else if t.Interrupted {
				<div class="rounded-2xl rounded-tl-sm border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-4 py-3 text-sm shadow-sm">
					<p class="text-xs text-black-600 dark:text-black-700 italic">Interrupted — response was cut off</p>
				</div>
			}
			if !t.Time.IsZero() {
				<span class="text-[10px] text-black-600 dark:text-black-700 opacity-0 group-hover:opacity-100 transition-opacity px-1">{ relTime(t.Time) }</span>
			}
		</div>
	</div>
}

templ turnEventCard(ev TurnEventVM) {
	switch ev.Type {
		case "thinking":
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 overflow-hidden text-xs">
				<button
					type="button"
					onclick="var b=this.parentElement.querySelector('[data-thinking-body]');b.classList.toggle('hidden');this.querySelector('[data-chevron]').style.transform=b.classList.contains('hidden')?'rotate(-90deg)':'';"
					class="flex w-full items-center gap-2 px-3 py-2 text-left hover:bg-white-200 dark:hover:bg-navy-800 transition-colors text-black-600 dark:text-black-700"
				>
					<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5.5"></circle><path d="M8 5.5v3l1.5 1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					<span class="italic">thinking</span>
					<svg data-chevron viewBox="0 0 16 16" class="ml-auto h-3 w-3 shrink-0 text-black-500 transition-transform" style="transform:rotate(-90deg)" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				</button>
				<div data-thinking-body class="hidden border-t border-white-300 dark:border-navy-600 px-3 py-2 italic text-black-600 dark:text-black-700 leading-relaxed break-words text-xs">{ ev.Text }</div>
			</div>
		case "tool_use":
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 overflow-hidden text-xs">
				<button
					type="button"
					onclick="var b=this.parentElement.querySelector('[data-tool-body]');b.classList.toggle('hidden');this.querySelector('[data-chevron]').style.transform=b.classList.contains('hidden')?'rotate(-90deg)':'';"
					class="flex w-full items-center gap-2 px-3 py-2 text-left hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
				>
					<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4h4v8H2zM10 4h4v8h-4z" stroke-linejoin="round"></path><path d="M6 8h4" stroke-linecap="round"></path></svg>
					<span class="font-mono font-medium text-black-900 dark:text-white-100">{ ev.ToolName }</span>
					<span class="ml-auto text-[10px] text-black-500 dark:text-black-600 uppercase tracking-wide shrink-0">tool call</span>
					<svg data-chevron viewBox="0 0 16 16" class="h-3 w-3 shrink-0 text-black-500 transition-transform" style="transform:rotate(-90deg)" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				</button>
				if ev.ToolInput != "" {
					<div data-tool-body class="hidden border-t border-white-300 dark:border-navy-600">
						<pre class="overflow-x-auto px-3 py-2 font-mono text-[11px] text-black-900 dark:text-white-100 leading-relaxed whitespace-pre-wrap break-words">{ ev.ToolInput }</pre>
					</div>
				}
			</div>
		case "tool_result":
			<div class={ "rounded-xl border overflow-hidden text-xs", templ.KV("border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20", ev.IsError), templ.KV("border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800", !ev.IsError) }>
				<button
					type="button"
					onclick="var b=this.parentElement.querySelector('[data-result-body]');b.classList.toggle('hidden');this.querySelector('[data-chevron]').style.transform=b.classList.contains('hidden')?'rotate(-90deg)':'';"
					class={ "flex w-full items-center gap-2 px-3 py-1.5 text-left hover:bg-white-200 dark:hover:bg-navy-800 transition-colors", templ.KV("text-red-600 dark:text-red-400", ev.IsError), templ.KV("text-black-600 dark:text-black-700", !ev.IsError) }
				>
					if ev.IsError {
						<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5.5"></circle><path d="M8 5v4M8 11v.5" stroke-linecap="round"></path></svg>
						<span class="text-[10px] uppercase tracking-wide shrink-0">error</span>
					} else {
						<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l3 3 7-7" stroke-linecap="round" stroke-linejoin="round"></path></svg>
						<span class="text-[10px] uppercase tracking-wide shrink-0">result</span>
					}
					<svg data-chevron viewBox="0 0 16 16" class="ml-auto h-3 w-3 shrink-0 text-black-500 transition-transform" style="transform:rotate(-90deg)" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
				</button>
				<div data-result-body class="hidden border-t border-white-300 dark:border-navy-600">
					<pre class="overflow-x-auto px-3 py-2 font-mono text-[11px] text-black-900 dark:text-white-100 leading-relaxed whitespace-pre-wrap break-words">{ ev.Text }</pre>
				</div>
			</div>
	}
}

templ systemTurn(t TurnVM) {
	<div class="flex justify-center py-1">
		<div class="flex flex-col items-center gap-1 max-w-full">
			<div class="inline-flex items-start gap-1.5 rounded-2xl border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 px-3 py-1 text-xs text-black-700 dark:text-black-600 max-w-full">
				<svg viewBox="0 0 12 12" class="h-3 w-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="6" cy="6" r="4.5"></circle>
					<path d="M6 4v2l1 1" stroke-linecap="round"></path>
				</svg>
				<span class="whitespace-pre-wrap break-words min-w-0">{ t.Text }</span>
			</div>
			if len(t.Events) > 0 {
				<div class="flex flex-col items-center gap-0.5 mt-0.5">
					for _, ev := range t.Events {
						<div class="inline-flex items-center gap-1 text-xs text-black-600 dark:text-black-500">
							<svg viewBox="0 0 12 12" class="h-2.5 w-2.5 text-green-500" fill="currentColor">
								<path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							{ ev.Text }
						</div>
					}
				</div>
			}
		</div>
	</div>
}

// ── Helpers ────────────────────────────────────────────────────────────────

// formatTurnLabel builds the chat-bubble header for an assistant turn.
// Format: "{agent}.{providerName}" — provider type is dropped (caller
// can still look it up in the session header); provider name is the
// part after the slash in "type/name". Default agent "main" is hidden
// so the label collapses to just the provider name in the common
// single-agent case.
func formatTurnLabel(agent, provider string) string {
	name := provider
	if i := strings.LastIndex(provider, "/"); i >= 0 {
		name = provider[i+1:]
	}
	switch {
	case agent == "" || agent == "main":
		return name
	case name == "":
		return agent
	default:
		return agent + "." + name
	}
}

// rowFallbackLifecycle maps the persisted session.Meta.Status (used
// when the pool has no live entry for a row) onto a lifecycle the
// badge renderer understands.
func rowFallbackLifecycle(status string) string {
	switch status {
	case "running":
		return "working"
	case "queued":
		return "spawning"
	}
	return "killed"
}

// relTime returns a short human-readable relative time string.
func relTime(t time.Time) string {
	if t.IsZero() {
		return "—"
	}
	d := time.Since(t)
	switch {
	case d < time.Minute:
		return "just now"
	case d < time.Hour:
		return fmt.Sprintf("%dm ago", int(d.Minutes()))
	case d < 24*time.Hour:
		return fmt.Sprintf("%dh ago", int(d.Hours()))
	default:
		return fmt.Sprintf("%dd ago", int(d.Hours()/24))
	}
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}
