package view

import (
	"fmt"
	"strings"

	"github.com/yogasw/wick/internal/agents/provider"
)

// ProvidersPage renders the Providers overview: per-instance status
// cards, pool capacity, and recent spawn logs. Static — user reloads
// to refresh.
templ ProvidersPage(vm ProvidersVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<div class="flex items-center justify-between gap-3">
				<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">Providers</h1>
				<div class="flex items-center gap-2">
					<form method="POST" action={ templ.SafeURL(vm.Base + "/providers/auto-rescan/toggle") }>
						if vm.AutoRescan {
							<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800" data-tooltip="Auto-rescan stale entries every 24h. Click to disable.">Auto-rescan: on</button>
						} else {
							<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800" data-tooltip="Auto-rescan disabled — refresh manually only. Click to enable.">Auto-rescan: off</button>
						}
					</form>
					<form method="POST" action={ templ.SafeURL(vm.Base + "/providers/rescan") }>
						<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-2 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Rescan all</button>
					</form>
					<button
						onclick="document.getElementById('add-provider-modal').classList.remove('hidden')"
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors"
					>+ Add Custom</button>
				</div>
			</div>
			<!-- Pool stats -->
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm">
					<p class="text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">Active Slots</p>
					<p id="pool-active-slots" class="mt-1 text-3xl font-bold text-blue-600 dark:text-blue-400">{ fmt.Sprintf("%d / %d", vm.PoolActive, vm.PoolMax) }</p>
				</div>
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm">
					<p class="text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">Queued</p>
					<p id="pool-queue-len" class="mt-1 text-3xl font-bold text-amber-600 dark:text-amber-400">{ fmt.Sprintf("%d", vm.PoolQueueLen) }</p>
				</div>
				@statCard("Configured", fmt.Sprintf("%d", len(vm.Statuses)), "default")
			</div>
			<!-- Active processes (always rendered; JS shows/hides via id) -->
			<div id="live-processes-panel" style={ func() templ.SafeCSS { if len(vm.LiveProcesses) == 0 { return "display:none" }; return "" }() } class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
				<div class="px-5 py-3 flex items-center justify-between border-b border-white-300 dark:border-navy-600">
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Active Processes</h2>
					<span data-pool-badge class="rounded bg-blue-100 dark:bg-blue-900 px-2 py-0.5 text-xs font-medium text-blue-700 dark:text-blue-300">{ fmt.Sprintf("%d / %d", len(vm.LiveProcesses), vm.PoolMax) }</span>
				</div>
				<table class="w-full text-xs">
					<thead>
						<tr class="border-b border-white-300 dark:border-navy-600 text-black-700 dark:text-black-600">
							<th class="px-5 py-2 text-left font-medium">Session</th>
							<th class="px-5 py-2 text-left font-medium">Agent</th>
							<th class="px-5 py-2 text-left font-medium">PID</th>
							<th class="px-5 py-2 text-left font-medium">State</th>
							<th class="px-5 py-2 text-right font-medium">Action</th>
						</tr>
					</thead>
					<tbody>
						for _, p := range vm.LiveProcesses {
							<tr class="border-b border-white-300 dark:border-navy-600 last:border-0 hover:bg-white-200 dark:hover:bg-navy-800">
								<td class="px-5 py-2 font-mono text-black-900 dark:text-white-100">{ p.SessionID[:min(8, len(p.SessionID))] }</td>
								<td class="px-5 py-2 text-black-900 dark:text-white-100">{ p.AgentName }</td>
								<td class="px-5 py-2 font-mono text-black-700 dark:text-black-600">
									if p.PID > 0 {
										{ fmt.Sprintf("%d", p.PID) }
									} else {
										—
									}
								</td>
								<td class="px-5 py-2">
									@lifecycleBadge(p.Lifecycle, p.PID, 0, 0)
								</td>
								<td class="px-5 py-2 text-right">
									<button
										data-kill-session={ p.SessionID }
										class="kill-process-btn rounded px-2 py-1 text-xs font-medium bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300 hover:bg-red-200 dark:hover:bg-red-800 transition-colors"
									>Kill</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
			<!-- Provider cards -->
			<div class="grid grid-cols-1 gap-4 lg:grid-cols-2 overflow-x-clip">
				for _, st := range vm.Statuses {
					{{ cap := vm.ProviderCaps[string(st.Instance.Type)+"/"+st.Instance.Name] }}
					@providerCard(vm.Base, st, vm.Gate, cap)
				}
			</div>
			<!-- Command Gate master switch -->
			@gateStatusCard(vm.Gate, vm.Base)
			<!-- MCP Wick install status -->
			@mcpWickCard(vm.MCP, vm.Base)
			<!-- Recent spawns -->
			<!-- Add custom modal -->
			@addProviderModal(vm)
		</div>
		<script src={ vm.Base + "/static/js/agents.js" }></script>
		<script>
		(function() {
			var base = document.querySelector('meta[name="wick-base"]')?.content || '';
			var worker;
			try { worker = new SharedWorker(base + '/static/js/sse-worker.js'); worker.port.start(); } catch(_) {}
			if (!worker) return;

			worker.port.postMessage({ type: 'subscribe', sessionID: '', base: base + '/tools/agents' });

			worker.port.onmessage = function(msg) {
				var d = msg.data;
				if (!d || d.type !== 'event') return;
				var ev = d.event;
				if (!ev || ev.type !== 'pool_stats') return;
				var stats;
				try { stats = JSON.parse(ev.data); } catch(_) { return; }
				updatePoolPanel(stats);
			};

			function lifecycleBadgeHTML(lc) {
				var colors = { working: 'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300', idle: 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300', spawning: 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300', killed: 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300' };
				var cls = colors[lc] || 'bg-white-300 dark:bg-navy-600 text-black-700 dark:text-black-600';
				return '<span class="rounded px-2 py-0.5 text-xs font-medium ' + cls + '">' + (lc || '—') + '</span>';
			}

			function updatePoolPanel(stats) {
				// Update stat cards
				var slotEl = document.getElementById('pool-active-slots');
				if (slotEl) slotEl.textContent = stats.active + ' / ' + stats.max;
				var queueEl = document.getElementById('pool-queue-len');
				if (queueEl) queueEl.textContent = stats.queue_len;

				// Rebuild active processes panel
				var panel = document.getElementById('live-processes-panel');
				var procs = stats.live_processes || [];
				if (!panel) return;

				if (procs.length === 0) {
					panel.style.display = 'none';
					return;
				}
				panel.style.display = '';

				var badge = panel.querySelector('[data-pool-badge]');
				if (badge) badge.textContent = procs.length + ' / ' + stats.max;

				var tbody = panel.querySelector('tbody');
				if (!tbody) return;
				tbody.innerHTML = procs.map(function(p) {
					var sid = p.session_id || '';
					var shortSid = sid.substring(0, 8);
					var pid = p.pid > 0 ? p.pid : '—';
					return '<tr class="border-b border-white-300 dark:border-navy-600 last:border-0 hover:bg-white-200 dark:hover:bg-navy-800">' +
						'<td class="px-5 py-2 font-mono text-black-900 dark:text-white-100">' + shortSid + '</td>' +
						'<td class="px-5 py-2 text-black-900 dark:text-white-100">' + (p.agent_name || '—') + '</td>' +
						'<td class="px-5 py-2 font-mono text-black-700 dark:text-black-600">' + pid + '</td>' +
						'<td class="px-5 py-2">' + lifecycleBadgeHTML(p.lifecycle) + '</td>' +
						'<td class="px-5 py-2 text-right"><button data-kill-session="' + sid + '" class="kill-process-btn rounded px-2 py-1 text-xs font-medium bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300 hover:bg-red-200 dark:hover:bg-red-800 transition-colors">Kill</button></td>' +
						'</tr>';
				}).join('');
			}

			document.addEventListener('click', function(e) {
				var btn = e.target.closest('.kill-process-btn');
				if (!btn) return;
				var sid = btn.dataset.killSession;
				if (!sid || !confirm('Kill this process?')) return;
				fetch(base + '/tools/agents/sessions/' + encodeURIComponent(sid) + '/kill', { method: 'POST', credentials: 'include' });
			});

			window.addEventListener('beforeunload', function() {
				if (worker) worker.port.postMessage({ type: 'unsubscribe', sessionID: '' });
			});
		})();
		</script>
	}
}

// gateStatusCard renders the global Command Gate master switch. ON
// means per-provider Hooks intents take effect; OFF disables every
// hook installation regardless of per-instance state. The Note field
// carries the operator-facing behavior summary.
templ gateStatusCard(g GateStatusVM, base string) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
		<div class="border-b border-white-300 dark:border-navy-600 px-5 py-3 flex items-center justify-between gap-3">
			<div class="flex items-center gap-2">
				if g.BypassLocked {
					<span class="inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Command Gate</h2>
					<span class="rounded bg-amber-500 px-2 py-0.5 text-xs font-medium text-white-100">locked (bypass)</span>
				} else if g.Enabled {
					<span class="inline-flex h-2 w-2 rounded-full bg-green-500"></span>
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Command Gate</h2>
					<span class="rounded bg-green-500 px-2 py-0.5 text-xs font-medium text-white-100">enabled</span>
				} else {
					<span class="inline-flex h-2 w-2 rounded-full bg-red-500 animate-pulse"></span>
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Command Gate</h2>
					<span class="rounded bg-red-500 px-2 py-0.5 text-xs font-medium text-white-100">⚠ not configured</span>
				}
			</div>
			<div class="flex items-center gap-3">
				if g.Source != "" {
					<span class="font-mono text-xs text-black-700 dark:text-black-600">resolved via { g.Source }</span>
				}
				if g.BypassLocked {
					<button type="button" disabled class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1 text-xs font-medium text-black-700 dark:text-black-600 opacity-60 cursor-not-allowed" data-tooltip="Disabled because bypass permissions is on. Turn bypass off in agents settings first.">Locked</button>
				} else {
					<form method="POST" action={ templ.SafeURL(base + "/providers/gate/toggle") }>
						if g.Enabled {
							<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Turn off</button>
						} else {
							<button type="submit" class="rounded-lg bg-green-500 px-3 py-1 text-xs font-medium text-white-100 hover:bg-green-600">Turn on</button>
						}
					</form>
				}
			</div>
		</div>
		<div class="px-5 py-3 space-y-3 text-xs">
			if g.Enabled {
				<div class="flex gap-2">
					<dt class="w-24 shrink-0 text-black-700 dark:text-black-600">binary</dt>
					<dd class="font-mono text-black-900 dark:text-white-100 break-all">{ g.Binary }</dd>
				</div>
			} else if g.Reason != "" {
				<div class="flex gap-2">
					<dt class="w-24 shrink-0 text-black-700 dark:text-black-600">error</dt>
					<dd class="font-mono text-red-600 dark:text-red-400 break-all">{ g.Reason }</dd>
				</div>
			}
			<form method="POST" action={ templ.SafeURL(base + "/providers/gate/modes") } class="flex items-center justify-between gap-3 pt-1">
				<div class="flex flex-col">
					<span class="text-xs font-medium text-black-900 dark:text-white-100">Prompt per tool call</span>
					<span class="text-xs text-black-700 dark:text-black-600">Off = run unguarded (Slack / HTTP)</span>
				</div>
				if g.PermissionMode == "bypass" {
					<input type="hidden" name="permission_mode" value="on"/>
					<button type="submit" role="switch" aria-checked="false" class="relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-white-400 dark:bg-navy-600 transition-colors hover:bg-white-500 dark:hover:bg-navy-500">
						<span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white-100 shadow ring-0 transition translate-x-0"></span>
					</button>
				} else {
					<input type="hidden" name="permission_mode" value="bypass"/>
					<button type="submit" role="switch" aria-checked="true" class="relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-green-500 transition-colors hover:bg-green-600">
						<span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white-100 shadow ring-0 transition translate-x-4"></span>
					</button>
				}
			</form>
			<p class="pt-1 text-black-800 dark:text-black-600 leading-relaxed">{ g.Note }</p>
		</div>
	</div>
}

// mcpWickCard renders the MCP Wick install status card. Collapsed by
// default — header shows aggregate dot counts. Expand to see per-client
// rows with Install / Uninstall buttons.
templ mcpWickCard(mcp MCPStatusVM, base string) {
	{{ installed, detected := mcpCounts(mcp.Clients) }}
	<details class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden group">
		<summary class="px-5 py-3 flex items-center justify-between gap-3 cursor-pointer list-none select-none hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
			<div class="flex items-center gap-2 flex-wrap">
				<svg class="w-3.5 h-3.5 text-black-700 dark:text-black-600 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
				<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">MCP Wick</h2>
				<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600 font-mono">{ mcp.AppName }</span>
				if installed == detected && detected > 0 {
					<span class="rounded bg-green-500 px-2 py-0.5 text-xs font-medium text-white-100">{ fmt.Sprintf("%d / %d installed", installed, detected) }</span>
				} else if installed > 0 {
					<span class="rounded bg-amber-500 px-2 py-0.5 text-xs font-medium text-white-100">{ fmt.Sprintf("%d / %d installed", installed, detected) }</span>
				} else if detected > 0 {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">{ fmt.Sprintf("0 / %d installed", detected) }</span>
				} else {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">no clients detected</span>
				}
				<span class="text-xs text-black-700 dark:text-black-600">— registers this app as an MCP server so AI clients can call its tools directly. Auto-installs once on first load.</span>
			</div>
		</summary>
		<div class="border-t border-white-300 dark:border-navy-600 divide-y divide-white-300 dark:divide-navy-600">
			for _, cl := range mcp.Clients {
				<div class="px-5 py-3 flex items-center justify-between gap-3">
					<div class="flex items-center gap-3 min-w-0">
						if cl.Installed {
							<span class="inline-flex h-2 w-2 rounded-full bg-green-500 shrink-0"></span>
						} else {
							<span class="inline-flex h-2 w-2 rounded-full bg-amber-500 animate-pulse shrink-0"></span>
						}
						<div class="min-w-0">
							<span class="text-xs font-medium text-black-900 dark:text-white-100">{ cl.Label }</span>
							if cl.Installed {
								<span class="ml-2 text-xs text-green-600 dark:text-green-400">installed</span>
							} else if cl.Blocklisted {
								<span class="ml-2 text-xs text-black-600 dark:text-black-700">skipped (manually uninstalled)</span>
							} else {
								<span class="ml-2 text-xs text-amber-600 dark:text-amber-400">not installed</span>
							}
							<p class="font-mono text-xs text-black-600 dark:text-black-700 truncate mt-0.5" data-tooltip={ cl.ConfigPath }>{ cl.ConfigPath }</p>
						</div>
					</div>
					<div class="flex items-center gap-1 shrink-0">
						if cl.Installed {
							<form method="POST" action={ templ.SafeURL(base + "/providers/mcp/" + cl.ID + "/uninstall") }>
								<button type="submit" class="rounded-lg border border-red-400 dark:border-red-700 px-2 py-1 text-xs text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" data-tooltip="Remove wick from this client's mcpServers (won't auto-reinstall)">Uninstall</button>
							</form>
						} else {
							<form method="POST" action={ templ.SafeURL(base + "/providers/mcp/" + cl.ID + "/install") }>
								<button type="submit" class="rounded-lg bg-green-500 px-3 py-1 text-xs font-medium text-white-100 hover:bg-green-600" data-tooltip="Write wick entry into this client's mcpServers">Install</button>
							</form>
						}
					</div>
				</div>
			}
		</div>
	</details>
}

// mcpCounts returns (installed, detected) counts across all clients.
func mcpCounts(clients []MCPClientStatusVM) (installed, detected int) {
	for _, c := range clients {
		if c.Detected {
			detected++
			if c.Installed {
				installed++
			}
		}
	}
	return
}

templ providerCard(base string, st provider.Status, gate GateStatusVM, cap ProviderCapVM) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm space-y-3">
		<div class="flex items-start justify-between gap-3">
			<div>
				<div class="flex items-center gap-2">
					<p class="text-base font-semibold text-black-900 dark:text-white-100">{ string(st.Instance.Type) }/{ st.Instance.Name }</p>
					<span class={ "rounded px-1.5 py-0.5 text-xs font-medium", templ.KV("bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300", cap.Used > 0), templ.KV("bg-white-300 dark:bg-navy-600 text-black-600 dark:text-black-500", cap.Used == 0) }>
						if cap.Unlimited {
							{ fmt.Sprintf("%d / ∞", cap.Used) }
						} else {
							{ fmt.Sprintf("%d / %d", cap.Used, cap.Max) }
						}
					</span>
				</div>
				if st.Instance.Disabled {
					<p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">disabled</p>
				} else if !st.PathFound {
					<p class="text-xs text-red-600 dark:text-red-400 mt-0.5">not found on PATH</p>
				} else if st.VersionErr != "" {
					<p class="text-xs text-red-600 dark:text-red-400 mt-0.5">version probe failed</p>
				} else {
					<p class="text-xs text-green-600 dark:text-green-400 mt-0.5">{ st.Version }</p>
				}
			</div>
			<div class="flex items-center gap-2">
				<form method="POST" action={ templ.SafeURL(base + "/providers/rescan/" + string(st.Instance.Type) + "/" + st.Instance.Name) } class="text-xs">
					<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800" data-tooltip="Re-probe this provider's binary + version">Rescan</button>
				</form>
				<a href={ templ.SafeURL(base + "/providers/detail/" + string(st.Instance.Type) + "/" + st.Instance.Name) } class="text-xs rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Detail</a>
			</div>
		</div>
		<dl class="text-xs space-y-1">
			<div class="flex gap-2">
				<dt class="w-20 text-black-700 dark:text-black-600">resolved</dt>
				if st.Path != "" {
					<dd class="font-mono text-black-900 dark:text-white-100 break-all">{ st.Path }</dd>
				} else {
					<dd class="text-black-600 dark:text-black-700">—</dd>
				}
			</div>
			if st.VersionErr != "" {
				<div class="flex gap-2">
					<dt class="w-20 text-black-700 dark:text-black-600">error</dt>
					<dd class="font-mono text-red-600 dark:text-red-400 break-all">{ st.VersionErr }</dd>
				</div>
			}
			if len(st.Instance.ExtraArgs) > 0 {
				<div class="flex gap-2">
					<dt class="w-20 text-black-700 dark:text-black-600">extra</dt>
					<dd class="font-mono text-black-900 dark:text-white-100 break-all">{ strings.Join(st.Instance.ExtraArgs, " ") }</dd>
				</div>
			}
			if len(st.Instance.Env) > 0 {
				<div class="flex gap-2">
					<dt class="w-20 text-black-700 dark:text-black-600">env</dt>
					<dd class="font-mono text-black-900 dark:text-white-100 break-all">{ fmt.Sprintf("%d entries", len(st.Instance.Env)) }</dd>
				</div>
			}
		</dl>
		@hookCapabilitySection(base, st, gate)
		if st.Instance.Name != string(st.Instance.Type) {
			<div class="pt-2 border-t border-white-300 dark:border-navy-600">
				<button
					data-delete-provider
					data-type={ string(st.Instance.Type) }
					data-name={ st.Instance.Name }
					class="text-xs text-red-600 dark:text-red-400 hover:underline"
				>Delete instance</button>
			</div>
		}
	</div>
}

// hookCapabilitySection renders the per-instance Command Gate
// controls: status badge from the persisted capability probe + an
// Enable / Disable / Test button trio. Enable runs the probe and
// flips the user's intent in one click. Disable just flips intent
// off. Test re-runs the probe without touching intent.
// providerGateCard is hookCapabilitySection wrapped in a standalone card
// for the detail page — no border-t/pt-3 since it's not inside another card.
templ providerGateCard(base string, st provider.Status, gate GateStatusVM) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden px-5 py-4 space-y-2">
		{{ hc, _ := st.Hooks[provider.HookEventPreToolUse] }}
		{{ intent := st.Instance.HookEnabled(provider.HookEventPreToolUse) }}
		{{ urlBase := base + "/providers/" + string(st.Instance.Type) + "/" + st.Instance.Name + "/hooks/" + provider.HookEventPreToolUse }}
		{{ masterOn := gate.Enabled }}
		<div class="flex items-center justify-between gap-2">
			<div class="flex items-center gap-2 flex-wrap">
				<span class="text-xs font-semibold text-black-900 dark:text-white-100">Command Gate</span>
				if gate.BypassLocked {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">locked (bypass)</span>
				} else if !masterOn {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">locked</span>
				} else if st.Probing {
					<span class="rounded bg-blue-500 px-2 py-0.5 text-xs font-medium text-white-100 animate-pulse">testing…</span>
				} else if intent && hc.Verified {
					<span class="rounded bg-green-500 px-2 py-0.5 text-xs font-medium text-white-100">enabled ✓</span>
				} else if intent && !hc.Verified {
					<span class="rounded bg-amber-500 px-2 py-0.5 text-xs font-medium text-white-100">enabled (unverified)</span>
				} else if hc.Verified {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-800 dark:text-black-600">ready</span>
				} else {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-800 dark:text-black-600">disabled</span>
				}
			</div>
			if masterOn {
				<div class="flex items-center gap-1 shrink-0">
					if st.Probing {
						<button type="button" disabled class="rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-xs text-black-700 dark:text-black-600 opacity-60 cursor-not-allowed">Testing…</button>
					} else if intent {
						<button type="button" class="rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-xs text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800" data-check-hook data-check-url={ urlBase + "/check" }>Test</button>
						<button type="button" class="rounded-lg border border-red-400 dark:border-red-700 px-2 py-1 text-xs text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" data-hook-action data-action-url={ urlBase + "/disable" }>Disable</button>
					} else {
						<button type="button" class="rounded-lg bg-green-500 px-3 py-1 text-xs font-medium text-white-100 hover:bg-green-600" data-hook-action data-action-url={ urlBase + "/enable" }>Enable</button>
					}
				</div>
			}
		</div>
		if hc.Error != "" {
			<p class="font-mono text-xs text-red-600 dark:text-red-400 break-all">{ hc.Error }</p>
		}
		if !hc.ProbedAt.IsZero() {
			<p class="font-mono text-xs text-black-700 dark:text-black-600">last probed: { hc.ProbedAt.Local().Format("2006-01-02 15:04:05") }</p>
		}
	</div>
}

templ hookCapabilitySection(base string, st provider.Status, gate GateStatusVM) {
	{{ hc, _ := st.Hooks[provider.HookEventPreToolUse] }}
	{{ intent := st.Instance.HookEnabled(provider.HookEventPreToolUse) }}
	{{ urlBase := base + "/providers/" + string(st.Instance.Type) + "/" + st.Instance.Name + "/hooks/" + provider.HookEventPreToolUse }}
	{{ masterOn := gate.Enabled }}
	<div class="pt-3 border-t border-white-300 dark:border-navy-600 space-y-2">
		<div class="flex items-center justify-between gap-2">
			<div class="flex items-center gap-2 flex-wrap">
				<span class="text-xs font-semibold text-black-900 dark:text-white-100">Command Gate</span>
				if gate.BypassLocked {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600" data-tooltip="Bypass permissions is on — every spawn runs unguarded, the gate cannot enforce. Turn bypass off in agents settings to use the gate.">locked (bypass)</span>
				} else if !masterOn {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600" data-tooltip="Master switch is off — per-provider controls disabled. Turn the global gate on first.">locked</span>
				} else if st.Probing {
					<span class="rounded bg-blue-500 px-2 py-0.5 text-xs font-medium text-white-100 animate-pulse" data-tooltip="Capability probe in flight — refresh in a few seconds to see the result">testing…</span>
				} else if intent && hc.Verified {
					<span class="rounded bg-green-500 px-2 py-0.5 text-xs font-medium text-white-100" data-tooltip="Hook installed every spawn; verified to honor deny">enabled ✓</span>
				} else if intent && !hc.Verified {
					<span class="rounded bg-amber-500 px-2 py-0.5 text-xs font-medium text-white-100" data-tooltip="Intent on but last probe failed — re-run Test or Disable">enabled (unverified)</span>
				} else if hc.Verified {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-800 dark:text-black-600" data-tooltip="Probe passed; not enabled yet">ready</span>
				} else {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-800 dark:text-black-600">disabled</span>
				}
				if hc.Scope != "" {
					<span class="text-xs text-black-700 dark:text-black-600">scope: { hc.Scope }</span>
				}
			</div>
			if masterOn {
				<div class="flex items-center gap-1">
					if st.Probing {
						<button
							type="button"
							class="rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-xs text-black-700 dark:text-black-600 opacity-60 cursor-not-allowed"
							data-tooltip="A probe is already running for this provider"
							data-tooltip-pos="bottom"
							disabled
						>Testing…</button>
					} else if intent {
						<button
							type="button"
							class="rounded-lg border border-white-400 dark:border-navy-600 px-2 py-1 text-xs text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800"
							data-tooltip="Re-run the capability probe without changing the enable state"
							data-tooltip-pos="bottom"
							data-check-hook
							data-check-url={ urlBase + "/check" }
						>Test</button>
						<button
							type="button"
							class="rounded-lg border border-red-400 dark:border-red-700 px-2 py-1 text-xs text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20"
							data-tooltip="Stop installing the gate hook on this provider's spawns"
							data-tooltip-pos="bottom"
							data-hook-action
							data-action-url={ urlBase + "/disable" }
						>Disable</button>
					} else {
						<button
							type="button"
							class="rounded-lg bg-green-500 px-3 py-1 text-xs font-medium text-white-100 hover:bg-green-600"
							data-tooltip="Probe this provider's deny envelope, and on success install the gate hook on every spawn. Takes 5–30s."
							data-tooltip-pos="bottom"
							data-hook-action
							data-action-url={ urlBase + "/enable" }
						>Enable</button>
					}
				</div>
			}
		</div>
		if hc.Error != "" {
			<p class="font-mono text-xs text-red-600 dark:text-red-400 break-all">{ hc.Error }</p>
		}
		if !hc.ProbedAt.IsZero() {
			<p class="font-mono text-xs text-black-700 dark:text-black-600">last probed: { hc.ProbedAt.Local().Format("2006-01-02 15:04:05") }</p>
		}
	</div>
}

templ skillSyncCard(vm SkillSyncVM, base string) {
	<details class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden group">
		<summary class="px-5 py-3 flex items-center justify-between gap-3 cursor-pointer list-none select-none hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
			<div class="flex items-center gap-2 flex-wrap">
				<svg class="w-3.5 h-3.5 text-black-700 dark:text-black-600 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
				<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Skills Sync</h2>
				if len(vm.Files) > 0 {
					<span class="rounded bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-700 dark:text-black-600">{ fmt.Sprintf("%d", len(vm.Files)) }</span>
				}
				<span class="text-xs text-black-700 dark:text-black-600 ml-1">mirrors skills across <code class="font-mono">.claude/skills</code>, <code class="font-mono">.codex/skills</code>, <code class="font-mono">.gemini/skills</code>, <code class="font-mono">.agents/skills</code></span>
			</div>
			<form method="POST" action={ templ.SafeURL(base + "/providers/skills/sync") }>
				<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Sync Skills</button>
			</form>
		</summary>
		<div class="border-t border-white-300 dark:border-navy-600">
			if len(vm.Dirs) == 0 {
				<div class="px-5 py-8 text-center text-sm text-black-700 dark:text-black-600">No skill directories found. Create at least one of the skill dirs above.</div>
			} else if len(vm.Files) == 0 {
				<div class="px-5 py-4 text-sm text-black-700 dark:text-black-600">
					<p>No skill files found. Directories detected:</p>
					<ul class="mt-2 space-y-1">
						for _, d := range vm.Dirs {
							<li class="font-mono text-xs">{ d }</li>
						}
					</ul>
				</div>
			} else {
				if vm.LastResult != "" {
					<div class="px-5 py-2 text-xs text-green-600 dark:text-green-400 border-b border-white-300 dark:border-navy-600">{ vm.LastResult }</div>
				}
				<table class="w-full text-sm">
					<thead>
						<tr class="border-b border-white-300 dark:border-navy-600 text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">
							<th class="px-5 py-2.5 text-left">Skill</th>
							<th class="px-5 py-2.5 text-left">Present In</th>
							<th class="px-5 py-2.5 text-left">Missing From</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-white-300 dark:divide-navy-600">
						for _, f := range vm.Files {
							<tr class="hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
								<td class="px-5 py-2.5 font-mono text-xs text-black-900 dark:text-white-100">{ f.Name }</td>
								<td class="px-5 py-2.5 text-xs text-black-700 dark:text-black-600">{ strings.Join(f.InDirs, ", ") }</td>
								<td class="px-5 py-2.5 text-xs">
									if len(f.Missing) == 0 {
										<span class="text-green-600 dark:text-green-400">all synced</span>
									} else {
										<span class="text-amber-600 dark:text-amber-400">{ strings.Join(f.Missing, ", ") }</span>
									}
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</details>
}

templ addProviderModal(vm ProvidersVM) {
	<div id="add-provider-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
		<div class="w-full max-w-lg rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-6 shadow-xl mx-4">
			<h2 class="mb-4 text-base font-semibold text-black-900 dark:text-white-100">New Provider Instance</h2>
			<form method="POST" action={ templ.SafeURL(vm.Base + "/providers") } class="space-y-4">
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Type <span class="text-red-500">*</span></label>
					<select name="type" required class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100">
						for _, k := range vm.SupportedKeys {
							<option value={ k }>{ k }</option>
						}
					</select>
				</div>
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Name <span class="text-red-500">*</span></label>
					<input type="text" name="name" required placeholder="e.g. work, personal" class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100"/>
				</div>
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Binary path (optional)</label>
					<input type="text" name="binary" placeholder="leave empty to use PATH lookup" class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100"/>
				</div>
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Extra args (space separated)</label>
					<input type="text" name="extra_args" class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100"/>
				</div>
				<div>
					<label class="block text-xs font-medium text-black-800 dark:text-black-600 mb-1">Env (one KEY=VALUE per line)</label>
					<textarea name="env" rows="3" placeholder={ "ANTHROPIC_API_KEY=sk-..." } class="w-full rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm font-mono text-black-900 dark:text-white-100"></textarea>
				</div>
				<div class="flex justify-end gap-3 pt-2">
					<button type="button" onclick="document.getElementById('add-provider-modal').classList.add('hidden')" class="rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800">Cancel</button>
					<button type="submit" class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600">Create</button>
				</div>
			</form>
		</div>
	</div>
}

// ProviderSpawnDetail renders the event timeline of one spawn log file.
templ ProviderSpawnDetail(vm ProviderSpawnDetailVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">Spawn Log</h1>
					<p class="text-xs text-black-700 dark:text-black-600 mt-0.5 font-mono">{ vm.File.ProviderType }/{ vm.File.ProviderName } · session { shortID(vm.File.SessionID) } · { vm.File.StartedAt.Local().Format("2006-01-02 15:04:05") }</p>
				</div>
				<a href={ templ.SafeURL(vm.Base + "/providers") } class="text-xs text-green-600 dark:text-green-400 hover:underline">← Back</a>
			</div>
			if vm.SessionDeleted {
				<div class="rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-3 flex items-start gap-2">
					<span class="text-amber-600 dark:text-amber-400 text-sm">⚠</span>
					<p class="text-xs text-amber-800 dark:text-amber-300">This session has been <strong>deleted</strong>. This is a historical spawn log — its session and the <code class="font-mono">cwd</code> path below may no longer exist.</p>
				</div>
			}
			if vm.File.Binary != "" || len(vm.File.Argv) > 0 {
				<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm p-4 space-y-2">
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Reproduce</h2>
					<p class="text-xs text-black-700 dark:text-black-600">Copy this exact command to reproduce the spawn outside wick.</p>
					<pre class="font-mono text-xs bg-white-200 dark:bg-navy-800 rounded-md p-3 text-black-900 dark:text-white-100 whitespace-pre-wrap break-all select-all">{ shellCommand(vm.File.Binary, vm.File.Argv) }</pre>
				</div>
			}
			<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
				if len(vm.Events) == 0 {
					<div class="px-5 py-12 text-center text-sm text-black-700 dark:text-black-600">No events.</div>
				} else {
					<ul class="divide-y divide-white-300 dark:divide-navy-600">
						for _, ev := range vm.Events {
							<li class="px-5 py-3">
								<div class="flex items-center gap-3">
									<span class="font-mono text-xs text-black-700 dark:text-black-600">{ ev.At.Local().Format("15:04:05.000") }</span>
									<span class="rounded-full bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-medium text-black-900 dark:text-white-100">{ ev.Type }</span>
									if ev.ExitReason != "" {
										<span class="text-xs text-black-800 dark:text-black-600">{ ev.ExitReason }</span>
									}
									if ev.DurationMs > 0 {
										<span class="text-xs text-black-700 dark:text-black-600">{ fmt.Sprintf("%dms", ev.DurationMs) }</span>
									}
								</div>
								if ev.Error != "" {
									<p class="mt-1 font-mono text-xs text-red-600 dark:text-red-400 break-all">{ ev.Error }</p>
								}
								if ev.Workspace != "" {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600 break-all">cwd: { ev.Workspace }</p>
								}
								if ev.ResumeID != "" {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600 break-all">resume: { ev.ResumeID }</p>
								}
								if ev.PID != 0 {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600">pid: { fmt.Sprintf("%d", ev.PID) }</p>
								}
								if ev.Binary != "" {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600 break-all">bin: { ev.Binary }</p>
								}
								if len(ev.Args) > 0 {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600 break-all">args: { strings.Join(ev.Args, " ") }</p>
								}
								if ev.FirstUserMessage != "" {
									<p class="mt-1 font-mono text-xs text-black-800 dark:text-black-600 break-all">msg: { ev.FirstUserMessage }</p>
								}
							</li>
						}
					</ul>
				}
			</div>
		</div>
	}
}

// shellCommand renders binary + argv as a copy-pasteable shell line.
// Args containing whitespace or shell metachars are single-quoted;
// existing single quotes get the close-quote/escape/open-quote dance
// so paste-into-bash always works.
func shellCommand(binary string, argv []string) string {
	parts := make([]string, 0, len(argv)+1)
	parts = append(parts, shellQuote(binary))
	for _, a := range argv {
		parts = append(parts, shellQuote(a))
	}
	return strings.Join(parts, " ")
}

func shellQuote(s string) string {
	if s == "" {
		return "''"
	}
	safe := true
	for _, r := range s {
		switch {
		case r >= 'a' && r <= 'z':
		case r >= 'A' && r <= 'Z':
		case r >= '0' && r <= '9':
		case r == '_' || r == '-' || r == '.' || r == '/' || r == ':' || r == ',' || r == '=' || r == '@' || r == '+' || r == '%':
		default:
			safe = false
		}
		if !safe {
			break
		}
	}
	if safe {
		return s
	}
	return "'" + strings.ReplaceAll(s, "'", `'\''`) + "'"
}

// filenameOf trims everything before the last path separator. Used
// inline by the spawn list to build the detail link without exposing
// host paths.
func filenameOf(p string) string {
	if i := strings.LastIndexAny(p, "/\\"); i >= 0 {
		return p[i+1:]
	}
	return p
}

// binaryPlaceholder returns what the Edit form's binary path input
// should hint when the registry has no override: the auto-detected
// path (registry/PATH/scan hit) so the user can see what wick would
// run, falling back to the bare type name when nothing was found.
func binaryPlaceholder(st provider.Status) string {
	if st.Instance.Binary != "" {
		return string(st.Instance.Type)
	}
	if st.Path != "" {
		return st.Path
	}
	return string(st.Instance.Type)
}
