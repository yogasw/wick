package view

// OverviewSPAVM feeds the thin-shell that hosts the overview SPA inside the
// standard agents layout. AssetURL is the hashed Vite bundle path resolved
// at boot via spaAssetURL("overview").
type OverviewSPAVM struct {
	Layout   AgentsLayoutVM
	Base     string
	AssetURL string
}

// OverviewSPA renders the overview SPA shell inside the agents chrome.
// The SPA reads data-base from the #app div and uses it as the prefix for
// all API calls (e.g. ${base}/api/overview).
templ OverviewSPA(vm OverviewSPAVM) {
	@AgentsLayout(vm.Layout) {
		if vm.AssetURL == "" {
			<div class="p-8 text-sm text-rose-600 dark:text-rose-400">
				Overview bundle not built yet. Run
				<code class="font-mono">npm --workspace=@wick-fe/agents-overview run build</code>
				in <code class="font-mono">fe/</code> and refresh.
			</div>
		} else {
			<div
				id="app"
				data-base={ vm.Base }
				class="h-full"
			></div>
			<script type="module" src={ vm.AssetURL }></script>
		}
	}
}
