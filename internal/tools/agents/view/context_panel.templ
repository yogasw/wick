package view

// ContextPanel renders the right-side slide-over for browsing the
// session cwd. The panel is hidden by default and toggled via a header
// button (data-context-open). All wiring lives in context.js — this
// template only ships the markup.
templ ContextPanel(base, sessionID string) {
	<!-- Edge tab handle — two sections stacked, each clickable -->
	<div class="fixed top-1/2 right-0 z-20 -translate-y-1/2 flex flex-col rounded-l-xl border border-r-0 border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-md overflow-hidden">
		<!-- Context section -->
		<button
			type="button"
			data-context-open
			data-open-tab="context"
			title="Browse files (Ctrl+B)"
			class="group inline-flex flex-col items-center justify-center gap-1 px-1.5 py-2.5 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors border-b border-white-300 dark:border-navy-600"
		>
			<svg viewBox="0 0 16 16" class="h-4 w-4 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5">
				<path d="M2 4a1 1 0 011-1h3l2 2h5a1 1 0 011 1v6a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke-linejoin="round"></path>
			</svg>
			<span class="text-[9px] font-medium text-black-700 dark:text-black-600 [writing-mode:vertical-rl] [transform:rotate(180deg)] tracking-wide">Context</span>
			<span data-context-fab-count class="hidden items-center justify-center min-w-[16px] h-[16px] px-0.5 rounded-full bg-green-500 text-white-100 text-[9px] font-semibold">0</span>
		</button>
		<!-- Process section -->
		<button
			type="button"
			data-context-open
			data-open-tab="process"
			title="Active processes"
			class="group inline-flex flex-col items-center justify-center gap-1 px-1.5 py-2.5 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
		>
			<span data-process-status-dot class="inline-block w-2 h-2 rounded-full bg-white-400 dark:bg-navy-500"></span>
			<span class="text-[9px] font-medium text-black-700 dark:text-black-600 [writing-mode:vertical-rl] [transform:rotate(180deg)] tracking-wide">Process</span>
			<span data-process-fab-count class="hidden items-center justify-center min-w-[16px] h-[16px] px-0.5 rounded-full bg-green-500 text-white-100 text-[9px] font-semibold">0</span>
		</button>
		<!-- Source Control section — opens the SCM SPA in a full modal. -->
		<button
			type="button"
			data-scm-open
			title="Source control"
			class="group inline-flex flex-col items-center justify-center gap-1 px-1.5 py-2.5 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors border-t border-white-300 dark:border-navy-600"
		>
			<svg viewBox="0 0 16 16" class="h-4 w-4 text-green-500" fill="none" stroke="currentColor" stroke-width="1.5">
				<circle cx="4" cy="4" r="1.5"></circle>
				<circle cx="4" cy="12" r="1.5"></circle>
				<circle cx="12" cy="5" r="1.5"></circle>
				<path d="M4 5.5v5M5.5 4H9a2 2 0 012 2v0" stroke-linecap="round"></path>
			</svg>
			<span class="text-[9px] font-medium text-black-700 dark:text-black-600 [writing-mode:vertical-rl] [transform:rotate(180deg)] tracking-wide">Source</span>
			<span data-scm-fab-count class="hidden items-center justify-center min-w-[16px] h-[16px] px-0.5 rounded-full bg-green-500 text-white-100 text-[9px] font-semibold">0</span>
		</button>
	</div>
	<!-- Backdrop -->
	<div
		data-context-backdrop
		class="hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm transition-opacity"
	></div>
	<!-- Slide-over -->
	<aside
		data-context-panel
		data-session-id={ sessionID }
		data-base={ base }
		class="hidden fixed top-0 right-0 z-40 h-full w-full sm:w-[420px] bg-white-100 dark:bg-navy-700 border-l border-white-300 dark:border-navy-600 shadow-xl flex flex-col"
	>
		<!-- Header: title + close -->
		<div class="flex items-center justify-between px-4 py-3 border-b border-white-300 dark:border-navy-600 shrink-0">
			<h2 class="text-sm font-semibold text-black-900 dark:text-white-100" data-panel-title>Context</h2>
			<button
				type="button"
				data-context-close
				title="Close"
				class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
			>
				<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l8 8M12 4l-8 8" stroke-linecap="round"></path></svg>
			</button>
		</div>

		<!-- Context tab content -->
		<div data-panel-content="context" class="flex flex-col flex-1 min-h-0">
			<!-- cwd + toolbar -->
			<div class="flex items-center justify-between px-4 py-2 border-b border-white-300 dark:border-navy-600 shrink-0">
				<p class="text-[11px] text-black-700 dark:text-black-600 truncate flex-1 min-w-0" data-context-cwd>Loading…</p>
				<div class="flex items-center gap-1 shrink-0 ml-2">
					<button type="button" data-context-new-file title="New file" class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 2H4a1 1 0 00-1 1v10a1 1 0 001 1h8a1 1 0 001-1V6L9 2z M9 2v4h4M8 8v4M6 10h4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
					<button type="button" data-context-new-dir title="New folder" class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4a1 1 0 011-1h3l2 2h5a1 1 0 011 1v6a1 1 0 01-1 1H3a1 1 0 01-1-1V4z M8 8v3M6.5 9.5h3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
					<button type="button" data-context-refresh title="Refresh" class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8a6 6 0 0110.5-4M14 8a6 6 0 01-10.5 4M11 2v3h3M5 14v-3H2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
				</div>
			</div>
			<!-- Search + count -->
			<div class="px-4 py-2 border-b border-white-300 dark:border-navy-600 shrink-0 space-y-2">
				<div class="relative">
					<svg viewBox="0 0 16 16" class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-black-600 dark:text-black-700 pointer-events-none" fill="none" stroke="currentColor" stroke-width="1.5">
						<circle cx="6.5" cy="6.5" r="4.5"></circle>
						<path d="M10.5 10.5l3 3" stroke-linecap="round"></path>
					</svg>
					<input type="text" data-context-search placeholder="Filter files…" class="w-full rounded-lg border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-800 pl-8 pr-3 py-1.5 text-xs text-black-900 dark:text-white-100 placeholder-black-600 dark:placeholder-black-700 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"/>
				</div>
				<p class="text-[11px] text-black-700 dark:text-black-600" data-context-count></p>
			</div>
			<!-- File list -->
			<div class="flex-1 overflow-y-auto" data-context-list>
				<div class="flex items-center justify-center py-12 text-xs text-black-700 dark:text-black-600" data-context-loading>Loading…</div>
			</div>
		</div>

		<!-- Process tab content -->
		<div data-panel-content="process" class="hidden flex-col flex-1 min-h-0">
			<div data-process-list class="flex-1 overflow-y-auto p-4 space-y-3">
				<p class="text-xs text-black-700 dark:text-black-600">No active processes.</p>
			</div>
		</div>

		<!-- Bottom tab bar -->
		<div class="shrink-0 border-t border-white-300 dark:border-navy-600 flex">
			<button
				type="button"
				data-panel-tab="context"
				class="flex-1 flex items-center justify-center gap-1.5 py-2.5 text-[11px] font-medium transition-colors"
			>
				<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4a1 1 0 011-1h3l2 2h5a1 1 0 011 1v6a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke-linejoin="round"></path></svg>
				Context
				<span data-context-fab-count class="hidden items-center justify-center min-w-[16px] h-[16px] px-0.5 rounded-full bg-green-500 text-white-100 text-[9px] font-semibold">0</span>
			</button>
			<button
				type="button"
				data-panel-tab="process"
				class="flex-1 flex items-center justify-center gap-1.5 py-2.5 text-[11px] font-medium transition-colors"
			>
				<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1.5" stroke-linejoin="round"/><path d="M5 8h6M5 5.5h4M5 10.5h3" stroke-linecap="round"/></svg>
				Process
				<span data-process-fab-count class="hidden items-center justify-center min-w-[16px] h-[16px] px-0.5 rounded-full bg-green-500 text-white-100 text-[9px] font-semibold">0</span>
			</button>
		</div>
	</aside>
	<!-- Preview / Edit modal -->
	<div
		data-context-modal
		class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4"
	>
		<div class="w-full max-w-5xl h-[85vh] rounded-2xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-2xl flex flex-col overflow-hidden">
			<!-- Modal header -->
			<div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-white-300 dark:border-navy-600 shrink-0">
				<div class="min-w-0 flex-1">
					<p class="text-xs font-mono text-black-900 dark:text-white-100 truncate" data-context-modal-path></p>
					<p class="text-[10px] text-black-700 dark:text-black-600" data-context-modal-meta></p>
				</div>
				<div class="flex items-center gap-1 shrink-0">
					<!-- Tab switcher (preview / edit) -->
					<div class="hidden items-center rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 p-0.5" data-context-tabs>
						<button type="button" data-context-tab="preview" class="px-2.5 py-1 text-[11px] font-medium rounded-md text-black-700 dark:text-black-600">Preview</button>
						<button type="button" data-context-tab="edit" class="px-2.5 py-1 text-[11px] font-medium rounded-md text-black-700 dark:text-black-600">Edit</button>
					</div>
					<button
						type="button"
						data-context-modal-download
						title="Download"
						class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
					>
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 13h10" stroke-linecap="round" stroke-linejoin="round"></path></svg>
					</button>
					<button
						type="button"
						data-context-modal-save
						title="Save"
						class="hidden inline-flex items-center gap-1 rounded-lg bg-green-500 px-2.5 py-1.5 text-[11px] font-medium text-white-100 hover:bg-green-600 transition-colors"
					>
						<svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3a1 1 0 011-1h6l2 2v6a1 1 0 01-1 1H3a1 1 0 01-1-1V3z M4 9h4M4 2v2h3V2" stroke-linejoin="round"></path></svg>
						Save
					</button>
					<button
						type="button"
						data-context-modal-close
						title="Close"
						class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
					>
						<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l8 8M12 4l-8 8" stroke-linecap="round"></path></svg>
					</button>
				</div>
			</div>
			<!-- Modal body -->
			<div class="flex-1 min-h-0 overflow-hidden">
				<!-- Preview surface: image / pdf / markdown / text -->
				<div class="h-full overflow-auto" data-context-preview></div>
				<!-- Editor surface (ace mounts here) -->
				<div class="hidden h-full" data-context-editor></div>
			</div>
			<!-- Status bar -->
			<div class="px-4 py-2 border-t border-white-300 dark:border-navy-600 shrink-0">
				<p class="text-[11px] text-black-700 dark:text-black-600" data-context-modal-status></p>
			</div>
		</div>
	</div>
}
