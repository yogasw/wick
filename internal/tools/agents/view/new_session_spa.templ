package view

// NewSessionSPAVM feeds the thin-shell that hosts the new-session compose SPA
// inside the standard agents layout. AssetURL is the hashed Vite bundle
// path resolved at boot via spaAssetURL("new-session").
type NewSessionSPAVM struct {
	Layout   AgentsLayoutVM
	Base     string
	AssetURL string
}

// NewSessionSPA renders the new-session compose SPA shell inside the agents chrome.
// The SPA reads data-base from the #app div and uses it as the prefix for
// all API calls (e.g. ${base}/providers/options).
templ NewSessionSPA(vm NewSessionSPAVM) {
	@AgentsLayout(vm.Layout) {
		if vm.AssetURL == "" {
			<div class="p-8 text-sm text-rose-600 dark:text-rose-400">
				New-session bundle not built yet. Run
				<code class="font-mono">npm --workspace=@wick-fe/agents-new-session run build</code>
				in <code class="font-mono">fe/</code> and refresh.
			</div>
		} else {
			<div
				id="app"
				data-base={ vm.Base }
				class="h-full"
			></div>
			<script type="module" src={ vm.AssetURL }></script>
		}
	}
}
