package view

import "fmt"

templ Overview(vm OverviewVM) {
	@AgentsLayout(vm.Layout) {
		<div class="space-y-6">
			<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">Overview</h1>
			<!-- Stats row -->
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
				@statCard("Active Slots", fmt.Sprintf("%d / %d", vm.Active, vm.PoolMax), "blue")
				@statCard("Queued", fmt.Sprintf("%d", vm.QueueLen), "amber")
				@statCard("Sessions", fmt.Sprintf("%d", len(vm.Sessions)), "green")
			</div>
			if len(vm.Queued) > 0 {
				<div class="rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 shadow-sm overflow-visible" data-queue-panel data-base={ vm.Base }>
					<div class="border-b border-amber-300 dark:border-amber-700 px-5 py-3">
						<div class="flex items-center justify-between gap-3 flex-wrap">
							<div>
								<h2 class="text-sm font-semibold text-amber-800 dark:text-amber-300">Queue</h2>
								<p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">Sessions waiting for a slot. Kill to release — killed entries won't execute.</p>
							</div>
							<button
								type="button"
								data-queue-kill-selected
								disabled
								class="rounded-md bg-red-600 px-3 py-1.5 text-xs font-medium text-white-100 hover:bg-red-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
							>Kill selected (<span data-queue-selected-count>0</span>)</button>
						</div>
						<div class="mt-3 flex items-center gap-3">
							<label class="flex items-center gap-2 text-xs text-amber-800 dark:text-amber-300 cursor-pointer shrink-0">
								<input type="checkbox" data-queue-check-all class="h-3.5 w-3.5 accent-red-600 rounded cursor-pointer"/>
								Select all
							</label>
							<div class="relative flex-1 min-w-0">
								<svg viewBox="0 0 16 16" class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-amber-600 dark:text-amber-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="4.5"></circle><path d="M10.5 10.5l3 3" stroke-linecap="round"></path></svg>
								<input
									type="text"
									data-queue-search
									placeholder="Filter queue by chat, project, or id..."
									class="w-full rounded-md border border-amber-300 dark:border-amber-700 bg-white-100 dark:bg-navy-800 pl-8 pr-3 py-1.5 text-xs text-black-900 dark:text-white-100 placeholder-amber-600/70 dark:placeholder-amber-500/60 focus:border-amber-500 focus:outline-none"
								/>
							</div>
						</div>
					</div>
					<ul class="divide-y divide-amber-200 dark:divide-amber-800 text-sm" data-queue-list>
						for _, q := range vm.Queued {
							<li
								class="flex items-center gap-3 px-5 py-2.5"
								data-queue-row
								data-queue-id={ q.SessionID }
								data-queue-search-text={ q.Label + " " + q.Project + " " + q.SessionID }
							>
								<input type="checkbox" data-queue-check class="h-3.5 w-3.5 accent-red-600 rounded cursor-pointer shrink-0"/>
								<a href={ templ.SafeURL(vm.Base + "/sessions/" + q.SessionID) } class="min-w-0 flex-1 hover:underline">
									if q.Label != "" {
										<span class="block truncate text-xs text-black-900 dark:text-white-100">{ q.Label }</span>
									} else {
										<span class="block truncate font-mono text-xs text-black-900 dark:text-white-100">{ shortID(q.SessionID) }</span>
									}
									<span class="block text-[11px] text-amber-700 dark:text-amber-400">
										if q.Project != "" {
											{ q.Project } ·
										}
										{ fmt.Sprintf("waiting %ds", q.WaitingMs/1000) }
									</span>
								</a>
								<button
									data-dequeue-session={ q.SessionID }
									class="shrink-0 rounded-md border border-red-300 dark:border-red-800 px-2 py-0.5 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
								>Kill</button>
							</li>
						}
					</ul>
					<p data-queue-empty class="hidden px-5 py-4 text-center text-xs text-amber-700 dark:text-amber-400">No queued sessions match your filter.</p>
				</div>
			}
			<!-- Active sessions (subprocess masih hidup di pool — spawning/working/idle) -->
			<div class="space-y-2">
				<div class="flex items-center justify-between">
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Active Sessions</h2>
					<a href={ templ.SafeURL(vm.Base + "/sessions") } class="text-xs text-green-600 dark:text-green-400 hover:underline">View all →</a>
				</div>
				@SessionsTable(SessionsTableVM{
					Base:          vm.Base,
					IDs:           vm.SessionIDs,
					Sessions:      vm.Sessions,
					Projects:      vm.Projects,
					Lifecycle:     vm.Lifecycle,
					IdleTimeoutMs: vm.IdleTimeoutMs,
					EmptyText:     "No active sessions.",
					ShowPaging:    false,
				})
			</div>
		</div>
		<script src={ vm.Base + "/static/js/agents.js" }></script>
	}
}

templ statCard(label, value, color string) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm">
		<p class="text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">{ label }</p>
		<p class={
			"mt-1 text-3xl font-bold",
			templ.KV("text-blue-600 dark:text-blue-400", color == "blue"),
			templ.KV("text-amber-600 dark:text-amber-400", color == "amber"),
			templ.KV("text-green-600 dark:text-green-400", color == "green"),
			templ.KV("text-black-900 dark:text-white-100", color == "default"),
		}>{ value }</p>
	</div>
}

func shortID(id string) string {
	if len(id) > 8 {
		return id[:8] + "…"
	}
	return id
}
