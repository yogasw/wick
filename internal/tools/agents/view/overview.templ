package view

import "fmt"

templ Overview(vm OverviewVM) {
	@AgentsLayout(vm.Base, "overview") {
		<div class="space-y-6">
			<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">Overview</h1>
			<!-- Stats row -->
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
				@statCard("Active Slots", fmt.Sprintf("%d / %d", vm.Active, vm.PoolMax), "blue")
				@statCard("Queued", fmt.Sprintf("%d", vm.QueueLen), "amber")
				@statCard("Sessions", fmt.Sprintf("%d", len(vm.Sessions)), "green")
			</div>
			if len(vm.Queued) > 0 {
				<div class="rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 shadow-sm overflow-visible">
					<div class="border-b border-amber-300 dark:border-amber-700 px-5 py-3">
						<h2 class="text-sm font-semibold text-amber-800 dark:text-amber-300">Queue</h2>
						<p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">Sessions waiting for a slot. Kill to release.</p>
					</div>
					<ul class="divide-y divide-amber-200 dark:divide-amber-800 text-sm">
						for _, q := range vm.Queued {
							<li class="flex items-center justify-between px-5 py-2.5">
								<a href={ templ.SafeURL(vm.Base + "/sessions/" + q.SessionID) } class="font-mono text-xs text-black-900 dark:text-white-100 hover:underline">{ shortID(q.SessionID) }</a>
								<div class="flex items-center gap-3">
									<span class="text-xs text-amber-700 dark:text-amber-400">{ fmt.Sprintf("waiting %ds", q.WaitingMs/1000) }</span>
									<button
										data-dequeue-session={ q.SessionID }
										class="rounded-md border border-red-300 dark:border-red-800 px-2 py-0.5 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
									>Kill</button>
								</div>
							</li>
						}
					</ul>
				</div>
			}
			<!-- Active sessions (subprocess masih hidup di pool — spawning/working/idle) -->
			<div class="space-y-2">
				<div class="flex items-center justify-between">
					<h2 class="text-sm font-semibold text-black-900 dark:text-white-100">Active Sessions</h2>
					<a href={ templ.SafeURL(vm.Base + "/sessions") } class="text-xs text-green-600 dark:text-green-400 hover:underline">View all →</a>
				</div>
				@SessionsTable(SessionsTableVM{
					Base:          vm.Base,
					IDs:           vm.SessionIDs,
					Sessions:      vm.Sessions,
					Lifecycle:     vm.Lifecycle,
					IdleTimeoutMs: vm.IdleTimeoutMs,
					EmptyText:     "No active sessions.",
					ShowPaging:    false,
				})
			</div>
		</div>
	}
}

templ statCard(label, value, color string) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 p-5 shadow-sm">
		<p class="text-xs font-medium text-black-700 dark:text-black-600 uppercase tracking-wide">{ label }</p>
		<p class={
			"mt-1 text-3xl font-bold",
			templ.KV("text-blue-600 dark:text-blue-400", color == "blue"),
			templ.KV("text-amber-600 dark:text-amber-400", color == "amber"),
			templ.KV("text-green-600 dark:text-green-400", color == "green"),
			templ.KV("text-black-900 dark:text-white-100", color == "default"),
		}>{ value }</p>
	</div>
}

func shortID(id string) string {
	if len(id) > 8 {
		return id[:8] + "…"
	}
	return id
}
