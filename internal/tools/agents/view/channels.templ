package view

import (
	"github.com/yogasw/wick/internal/entity"
	managerview "github.com/yogasw/wick/internal/manager/view"
)

// ChannelVM is one channel card on the channels list page.
type ChannelVM struct {
	Name        string
	Slug        string // "slack" | "telegram"
	Icon        string
	Description string
	Configured  bool   // true when the required credential is set
	HRef        string // link to config page
}

// ChannelListVM is the view model for the Channels index page.
type ChannelListVM struct {
	Layout   AgentsLayoutVM
	Base     string
	Channels []ChannelVM
}

// ChannelConfigVM is the view model for a single channel's config page.
type ChannelConfigVM struct {
	Layout      AgentsLayoutVM
	Base        string
	ChannelName string
	ChannelSlug string
	Rows        []entity.Config
	ActionBase  string
	// Docs is an optional component rendered below the config table.
	// Channels use it to surface usage notes, sample requests, or links
	// to related pages (e.g. PAT management for REST).
	Docs templ.Component
}

// ChannelListPage shows available channels as cards.
templ ChannelListPage(vm ChannelListVM) {
	@AgentsLayout(vm.Layout) {
		<div class="max-w-3xl">
			<h1 class="text-xl font-semibold text-black-900 dark:text-white-100 mb-1">Channels</h1>
			<p class="text-sm text-black-700 dark:text-black-600 mb-6">
				Connect messaging platforms so agents can receive tasks and reply in threads.
			</p>
			<div class="flex flex-col gap-3">
				for _, ch := range vm.Channels {
					@channelCard(ch)
				}
			</div>
		</div>
	}
}

templ channelCard(ch ChannelVM) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden">
		<div class="flex items-center gap-4 px-5 py-4">
			<span class="text-2xl shrink-0">{ ch.Icon }</span>
			<div class="min-w-0 flex-1">
				<div class="flex items-center gap-2 mb-0.5">
					<span class="font-semibold text-sm text-black-900 dark:text-white-100">{ ch.Name }</span>
					if ch.Configured {
						<span class="inline-flex items-center rounded-full bg-pos-100 px-2 py-0.5 text-[10px] font-semibold text-pos-400">configured</span>
					} else {
						<span class="inline-flex items-center rounded-full bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-[10px] font-semibold text-black-700 dark:text-black-600">not configured</span>
					}
				</div>
				<p class="text-xs text-black-700 dark:text-black-600 truncate">{ ch.Description }</p>
			</div>
			<a
				href={ templ.SafeURL(ch.HRef) }
				class="shrink-0 rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:border-green-500 hover:text-green-600 transition-colors"
			>Configure</a>
		</div>
	</div>
}

// ChannelConfigPage shows config fields for one channel.
templ ChannelConfigPage(vm ChannelConfigVM) {
	@AgentsLayout(vm.Layout) {
		<div class="max-w-3xl">
			<nav class="flex items-center gap-1.5 text-xs text-black-700 dark:text-black-600 mb-4">
				<a href={ templ.SafeURL(vm.Base + "/channels") } class="hover:text-green-600 transition-colors">Channels</a>
				<span>›</span>
				<span class="text-black-900 dark:text-white-100 font-medium">{ vm.ChannelName }</span>
			</nav>
			<h1 class="text-xl font-semibold text-black-900 dark:text-white-100 mb-1">{ vm.ChannelName }</h1>
			<p class="text-sm text-black-700 dark:text-black-600 mb-2">
				Configure credentials and access control for the { vm.ChannelName } channel.
			</p>
			@managerview.ConfigsTable(vm.Rows, vm.ActionBase, "", "")
			if vm.Docs != nil {
				<div class="mt-8">
					@vm.Docs
				</div>
			}
		</div>
	}
}

// RestDocsVM is the view model for the REST channel's docs panel.
type RestDocsVM struct {
	Base       string // wick base (for /profile/tokens link)
	Endpoint   string // full URL of the chat completions endpoint
	SampleUser string // session key shown in samples
}

// RestDocs renders usage docs + a copyable curl sample for the REST channel.
templ RestDocs(vm RestDocsVM) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm p-5">
		<h2 class="text-base font-semibold text-black-900 dark:text-white-100 mb-1">How it works</h2>
		<p class="text-sm text-black-700 dark:text-black-600 mb-4">
			This channel exposes an OpenAI Chat Completions compatible endpoint. Point any OpenAI SDK at the base URL below and authenticate with a wick Personal Access Token.
		</p>
		<dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm mb-5">
			<dt class="text-black-700 dark:text-black-600">Endpoint</dt>
			<dd class="font-mono text-xs text-black-900 dark:text-white-100 break-all">{ vm.Endpoint }</dd>
			<dt class="text-black-700 dark:text-black-600">Method</dt>
			<dd class="font-mono text-xs text-black-900 dark:text-white-100">POST</dd>
			<dt class="text-black-700 dark:text-black-600">Auth</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				<code class="font-mono">Authorization: Bearer wick_pat_…</code> —
				<a href={ templ.SafeURL(vm.Base + "/profile/tokens") } class="text-green-600 hover:underline">manage tokens</a>
			</dd>
			<dt class="text-black-700 dark:text-black-600">Session</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				Two modes — pick one:
				<ul class="mt-1 space-y-1 list-disc pl-4">
					<li><b>Stateless</b> (omit <code class="font-mono">session_id</code>): every request spawns a fresh wick session, you re-send the full <code class="font-mono">messages</code> array each turn.</li>
					<li><b>Stateful</b> (<code class="font-mono">session_id</code> set): same <code class="font-mono">session_id</code> across requests reuses one wick session. Only the last user message is sent; wick keeps the history.</li>
				</ul>
				The <code class="font-mono">user</code> field is accepted for parity but used as an audit label only.
			</dd>
			<dt class="text-black-700 dark:text-black-600">Streaming</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">Not supported on this endpoint. Set <code class="font-mono">stream:false</code> (the default).</dd>
			<dt class="text-black-700 dark:text-black-600">Approvals</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">Gate prompts are auto-blocked — REST clients cannot deliver interactive decisions. Use the web UI to approve sensitive commands.</dd>
		</dl>

		<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — stateless</h3>
		<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "curl -X POST " + vm.Endpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"wick\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"Hello, who are you?\" }\n    ]\n  }'" }</code></pre>

		<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — stateful (reuse session)</h3>
		<p class="text-xs text-black-700 dark:text-black-600 mb-2">Send the same <code class="font-mono">session_id</code> on each call. Only the last user message is sent — wick remembers prior turns.</p>
		<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "# Turn 1\ncurl -X POST " + vm.Endpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"wick\",\n    \"session_id\": \"chat-42\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"Remember the number 7.\" }\n    ]\n  }'\n\n# Turn 2 — same session_id, no history needed\ncurl -X POST " + vm.Endpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"wick\",\n    \"session_id\": \"chat-42\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"What number did I ask you to remember?\" }\n    ]\n  }'" }</code></pre>

		<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Python (OpenAI SDK) — stateless</h3>
		<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "from openai import OpenAI\n\nclient = OpenAI(\n    base_url=\"" + vm.Base + "/integrations/rest/v1\",\n    api_key=\"wick_pat_REPLACE_ME\",\n)\n\n# Stateless — manage history yourself and resend it each call.\nhistory = [{\"role\": \"user\", \"content\": \"Hello\"}]\nresp = client.chat.completions.create(model=\"wick\", messages=history)\nprint(resp.choices[0].message.content)" }</code></pre>

		<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Python (OpenAI SDK) — stateful</h3>
		<p class="text-xs text-black-700 dark:text-black-600 mb-2">Pass <code class="font-mono">session_id</code> via <code class="font-mono">extra_body</code> — the OpenAI SDK forwards it as a top-level field.</p>
		<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "from openai import OpenAI\n\nclient = OpenAI(\n    base_url=\"" + vm.Base + "/integrations/rest/v1\",\n    api_key=\"wick_pat_REPLACE_ME\",\n)\n\nSESSION = \"chat-42\"\n\ndef ask(text):\n    return client.chat.completions.create(\n        model=\"wick\",\n        messages=[{\"role\": \"user\", \"content\": text}],\n        extra_body={\"session_id\": SESSION},\n    ).choices[0].message.content\n\nprint(ask(\"Remember the number 7.\"))\nprint(ask(\"What number did I ask you to remember?\"))" }</code></pre>

		<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Response shape</h3>
		<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto"><code>{ "{\n  \"id\": \"wick-rest-…\",\n  \"object\": \"chat.completion\",\n  \"created\": 1715000000,\n  \"model\": \"wick\",\n  \"choices\": [\n    {\n      \"index\": 0,\n      \"message\": { \"role\": \"assistant\", \"content\": \"…\" },\n      \"finish_reason\": \"stop\"\n    }\n  ]\n}" }</code></pre>
	</div>
}
