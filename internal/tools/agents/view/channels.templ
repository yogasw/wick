package view

import (
	"github.com/yogasw/wick/internal/entity"
	managerview "github.com/yogasw/wick/internal/manager/view"
)

// ChannelVM is one channel card on the channels list page.
type ChannelVM struct {
	Name        string
	Slug        string // "slack" | "telegram"
	Icon        string
	Description string
	Configured  bool   // true when the required credential is set
	HRef        string // link to config page
}

// ChannelListVM is the view model for the Channels index page.
type ChannelListVM struct {
	Layout   AgentsLayoutVM
	Base     string
	Channels []ChannelVM
}

// ChannelConfigVM is the view model for a single channel's config page.
type ChannelConfigVM struct {
	Layout      AgentsLayoutVM
	Base        string
	ChannelName string
	ChannelSlug string
	Rows        []entity.Config
	ActionBase  string
	// Docs is an optional component rendered below the config table.
	// Channels use it to surface usage notes, sample requests, or links
	// to related pages (e.g. PAT management for REST).
	Docs templ.Component
}

// ChannelListPage shows available channels as cards.
templ ChannelListPage(vm ChannelListVM) {
	@AgentsLayout(vm.Layout) {
		<div class="p-6">
			<h1 class="text-xl font-semibold text-black-900 dark:text-white-100 mb-1">Channels</h1>
			<p class="text-sm text-black-700 dark:text-black-600 mb-6">
				Connect messaging platforms so agents can receive tasks and reply in threads.
			</p>
			<div class="flex flex-col gap-3">
				for _, ch := range vm.Channels {
					@channelCard(ch)
				}
			</div>
		</div>
	}
}

templ channelCard(ch ChannelVM) {
	<a
		href={ templ.SafeURL(ch.HRef) }
		class="block rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden hover:border-green-500 hover:shadow-md transition-all"
	>
		<div class="flex items-center gap-4 px-5 py-4">
			<span class="text-2xl shrink-0">{ ch.Icon }</span>
			<div class="min-w-0 flex-1">
				<div class="flex items-center gap-2 mb-0.5">
					<span class="font-semibold text-sm text-black-900 dark:text-white-100">{ ch.Name }</span>
					if ch.Configured {
						<span class="inline-flex items-center rounded-full bg-pos-100 px-2 py-0.5 text-[10px] font-semibold text-pos-400">configured</span>
					} else {
						<span class="inline-flex items-center rounded-full bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-[10px] font-semibold text-black-700 dark:text-black-600">not configured</span>
					}
				</div>
				<p class="text-xs text-black-700 dark:text-black-600 truncate">{ ch.Description }</p>
			</div>
			<span class="shrink-0 text-black-700 dark:text-black-600 text-lg leading-none">›</span>
		</div>
	</a>
}

// ChannelConfigPage shows config fields for one channel.
templ ChannelConfigPage(vm ChannelConfigVM) {
	@AgentsLayout(vm.Layout) {
		<div class="p-6">
			<nav class="flex items-center gap-1.5 text-xs text-black-700 dark:text-black-600 mb-4">
				<a href={ templ.SafeURL(vm.Base + "/channels") } class="hover:text-green-600 transition-colors">Channels</a>
				<span>›</span>
				<span class="text-black-900 dark:text-white-100 font-medium">{ vm.ChannelName }</span>
			</nav>
			<h1 class="text-xl font-semibold text-black-900 dark:text-white-100 mb-1">{ vm.ChannelName }</h1>
			<p class="text-sm text-black-700 dark:text-black-600 mb-2">
				Configure credentials and access control for the { vm.ChannelName } channel.
			</p>
			@integrationTestPanel(vm.Base + "/channels/test/" + vm.ChannelSlug)
			@integrationStatusPanel(vm.Base + "/channels/" + vm.ChannelSlug + "/status")
			@managerview.ConfigsTableFull(vm.Rows, vm.ActionBase)
			if vm.Docs != nil {
				<div class="mt-8">
					@vm.Docs
				</div>
			}
		</div>
	}
}

// integrationTestPanel renders the "Test Integration" button + an empty
// results container. JS attached at the bottom POSTs to testURL and fills
// in per-check rows.
templ integrationTestPanel(testURL string) {
	<div class="mt-4 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden" data-integration-test data-test-url={ testURL }>
		<div class="flex items-center justify-between gap-3 px-5 py-3 border-b border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800">
			<div>
				<h3 class="text-sm font-semibold text-black-900 dark:text-white-100">Integration health</h3>
				<p class="text-xs text-black-700 dark:text-black-600">Verify credentials and required Slack scopes.</p>
			</div>
			<button
				type="button"
				data-test-run
				class="rounded-lg bg-green-500 hover:bg-green-600 text-white-100 text-xs font-medium px-3 py-2 transition-colors"
			>Test Integration</button>
		</div>
		<div data-test-results class="hidden p-5 flex flex-col gap-2"></div>
		<script>
		(function(){
			var panel=document.currentScript.closest('[data-integration-test]');
			var url=panel.getAttribute('data-test-url');
			var btn=panel.querySelector('[data-test-run]');
			var box=panel.querySelector('[data-test-results]');
			function render(items,err){
				box.innerHTML='';
				box.classList.remove('hidden');
				if(err){
					var e=document.createElement('div');
					e.className='text-xs text-neg-400 font-mono';
					e.textContent='Request failed: '+err;
					box.appendChild(e);
					return;
				}
				if(!items||items.length===0){
					box.innerHTML='<div class="text-xs text-pos-400 font-mono">✓ All checks passed</div>';
					return;
				}
				items.forEach(function(it){
					var row=document.createElement('div');
					row.className='flex items-start gap-2 text-xs';
					var icon=document.createElement('span');
					icon.className='shrink-0 mt-0.5 font-mono '+(it.ok?'text-pos-400':'text-neg-400');
					icon.textContent=it.ok?'✓':'✗';
					var body=document.createElement('div');
					body.className='flex-1 min-w-0';
					var name=document.createElement('div');
					name.className='font-mono text-black-900 dark:text-white-100';
					name.textContent=it.name;
					body.appendChild(name);
					if(it.detail){
						var d=document.createElement('div');
						d.className='text-[11px] text-black-700 dark:text-black-600 break-words';
						d.textContent=it.detail;
						body.appendChild(d);
					}
					if(it.error){
						var er=document.createElement('div');
						er.className='text-[11px] text-neg-400 font-mono break-words';
						er.textContent=it.error;
						body.appendChild(er);
					}
					row.appendChild(icon);
					row.appendChild(body);
					box.appendChild(row);
				});
			}
			btn.addEventListener('click',function(){
				btn.disabled=true;
				var orig=btn.textContent;
				btn.textContent='Running…';
				box.classList.remove('hidden');
				box.innerHTML='<div class="text-xs text-black-700 dark:text-black-600">Running probes…</div>';
				fetch(url,{method:'POST',credentials:'same-origin'})
					.then(function(r){return r.json().then(function(b){return{ok:r.ok,body:b};});})
					.then(function(res){
						if(!res.ok){render(null,(res.body&&res.body.error)||'HTTP '+res.body);return;}
						render(res.body,null);
					})
					.catch(function(e){render(null,e.message||String(e));})
					.then(function(){btn.disabled=false;btn.textContent=orig;});
			});
		})();
		</script>
	</div>
}

// integrationStatusPanel renders the "Integration status" card under
// the test button. JS auto-fetches statusURL on load and re-fetches
// 2s after every successful Test Integration run so the displayed
// state stays in sync with reconnect actions kicked off by the test.
templ integrationStatusPanel(statusURL string) {
	<div class="mt-4 rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm overflow-hidden" data-integration-status data-status-url={ statusURL }>
		<div class="flex items-center justify-between gap-3 px-5 py-3 border-b border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800">
			<div>
				<h3 class="text-sm font-semibold text-black-900 dark:text-white-100">Integration status</h3>
				<p class="text-xs text-black-700 dark:text-black-600">Live identity and transport state.</p>
			</div>
			<button
				type="button"
				data-status-refresh
				class="rounded-lg border border-white-300 dark:border-navy-600 text-xs font-medium px-3 py-2 text-black-900 dark:text-white-100 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors"
			>Refresh</button>
		</div>
		<div data-status-rows class="p-5 flex flex-col gap-2">
			<div class="text-xs text-black-700 dark:text-black-600">Loading…</div>
		</div>
		<script>
		(function(){
			var panel=document.currentScript.closest('[data-integration-status]');
			var url=panel.getAttribute('data-status-url');
			var rows=panel.querySelector('[data-status-rows]');
			var btn=panel.querySelector('[data-status-refresh]');
			function render(items,err){
				rows.innerHTML='';
				if(err){
					var e=document.createElement('div');
					e.className='text-xs text-neg-400 font-mono';
					e.textContent='Request failed: '+err;
					rows.appendChild(e);
					return;
				}
				if(!items||items.length===0){
					rows.innerHTML='<div class="text-xs text-black-700 dark:text-black-600">No status reported.</div>';
					return;
				}
				items.forEach(function(it){
					var row=document.createElement('div');
					row.className='flex items-start gap-2 text-xs';
					var icon=document.createElement('span');
					var color='text-black-700 dark:text-black-600';
					if(it.ok) color='text-pos-400';
					else if(it.warn) color='text-warn-400';
					icon.className='shrink-0 mt-0.5 font-mono '+color;
					icon.textContent=it.ok?'✓':(it.warn?'!':'·');
					var body=document.createElement('div');
					body.className='flex-1 min-w-0';
					var label=document.createElement('span');
					label.className='font-semibold text-black-900 dark:text-white-100';
					label.textContent=it.label+': ';
					var val=document.createElement('span');
					val.className='font-mono text-black-900 dark:text-white-100 break-all';
					val.textContent=it.value;
					body.appendChild(label);
					body.appendChild(val);
					row.appendChild(icon);
					row.appendChild(body);
					rows.appendChild(row);
				});
			}
			function load(){
				rows.innerHTML='<div class="text-xs text-black-700 dark:text-black-600">Loading…</div>';
				fetch(url,{credentials:'same-origin'})
					.then(function(r){
						// 501 = channel doesn't implement StatusReporter (telegram/rest/etc).
						// Hide the whole panel — no value in showing an error to the operator.
						if(r.status===501){ panel.style.display='none'; return null; }
						return r.json().then(function(b){return{ok:r.ok,body:b};});
					})
					.then(function(res){
						if(!res) return;
						if(!res.ok){render(null,(res.body&&res.body.error)||'HTTP error');return;}
						render(res.body,null);
					})
					.catch(function(e){render(null,e.message||String(e));});
			}
			btn.addEventListener('click',load);
			load();
			// Re-fetch shortly after a successful test run so the reconnect
			// kicked off by probeTransport has time to settle.
			var testPanel=document.querySelector('[data-integration-test]');
			if(testPanel){
				testPanel.querySelector('[data-test-run]').addEventListener('click',function(){
					setTimeout(load,2000);
				});
			}
		})();
		</script>
	</div>
}

// RestDocsVM is the view model for the REST channel's docs panel.
//
// APIBase is the SDK base_url (no trailing slash). The three endpoint
// fields are full URLs derived from it — handler precomputes them so
// the templ stays free of string concat noise.
type RestDocsVM struct {
	Base              string // wick external URL (also used for /profile/tokens link)
	APIBase           string // <Base>/integrations/rest/api/v1/openai — what SDK base_url points at
	ChatEndpoint      string // <APIBase>/chat/completions
	ResponsesEndpoint string // <APIBase>/responses
	ModelsEndpoint    string // <APIBase>/models
}

// RestDocs renders usage docs for the three OpenAI-compatible routes
// the REST channel exposes. Top section is the common contract (base
// URL, auth, streaming, approvals); below it a tab strip jumps between
// per-endpoint examples.
templ RestDocs(vm RestDocsVM) {
	<div class="rounded-xl border border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700 shadow-sm p-5">
		<h2 class="text-base font-semibold text-black-900 dark:text-white-100 mb-1">How it works</h2>
		<p class="text-sm text-black-700 dark:text-black-600 mb-4">
			This channel exposes three OpenAI-compatible endpoints under a single base URL. Point any OpenAI SDK at the base URL and authenticate with a wick Personal Access Token.
		</p>
		<dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm mb-5">
			<dt class="text-black-700 dark:text-black-600">Base URL</dt>
			<dd class="font-mono text-xs text-black-900 dark:text-white-100 break-all">{ vm.APIBase }</dd>
			<dt class="text-black-700 dark:text-black-600">Auth</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				<code class="font-mono">Authorization: Bearer wick_pat_…</code> —
				<a href={ templ.SafeURL(vm.Base + "/profile/tokens") } class="text-green-600 hover:underline">manage tokens</a>
			</dd>
			<dt class="text-black-700 dark:text-black-600">Models</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				The <code class="font-mono">model</code> field must match one of the providers returned by <code class="font-mono">GET /models</code> (e.g. <code class="font-mono">claude</code>, <code class="font-mono">codex</code>, <code class="font-mono">gemini</code>, or <code class="font-mono">type/name</code> { "for" } named instances). Unknown ids return <code class="font-mono">404 model_not_found</code>. Empty <code class="font-mono">model</code> lets wick pick.
			</dd>
			<dt class="text-black-700 dark:text-black-600">Session</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				Two modes — pick one:
				<ul class="mt-1 space-y-1 list-disc pl-4">
					<li><b>Stateless</b> (omit <code class="font-mono">conversation</code> / <code class="font-mono">previous_response_id</code>): every request spawns a fresh wick session, you re-send the full history each turn.</li>
					<li><b>Stateful</b>: reuse the same <code class="font-mono">conversation</code> id across calls, or chain Responses turns with <code class="font-mono">previous_response_id</code> — wick keeps the history and only the new turn is sent.</li>
				</ul>
			</dd>
			<dt class="text-black-700 dark:text-black-600">Project</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">
				Optional <code class="font-mono">project</code> field (a project id) picks which wick Project the session runs in — its folder becomes the agent cwd and its preset/provider defaults apply. Omit it for the channel's configured default project. Also accepted as <code class="font-mono">metadata.project</code> / <code class="font-mono">metadata.project_id</code>.
			</dd>
			<dt class="text-black-700 dark:text-black-600">Streaming</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">Not supported. Set <code class="font-mono">stream:false</code> (the default).</dd>
			<dt class="text-black-700 dark:text-black-600">Approvals</dt>
			<dd class="text-xs text-black-900 dark:text-white-100">Gate prompts are auto-blocked — REST clients cannot deliver interactive decisions. Use the web UI to approve sensitive commands.</dd>
		</dl>

		<!-- Tab strip — three endpoints. JS below toggles `hidden` on panels. -->
		<div class="border-b border-white-300 dark:border-navy-600 mb-4" role="tablist">
			<div class="flex flex-wrap gap-1 -mb-px">
				<button type="button" data-rest-tab="chat" class="rest-tab-btn px-3 py-2 text-sm font-medium border-b-2 border-green-600 text-green-600">
					Chat Completions
				</button>
				<button type="button" data-rest-tab="responses" class="rest-tab-btn px-3 py-2 text-sm font-medium border-b-2 border-transparent text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">
					Responses
				</button>
				<button type="button" data-rest-tab="models" class="rest-tab-btn px-3 py-2 text-sm font-medium border-b-2 border-transparent text-black-700 dark:text-black-600 hover:text-black-900 dark:hover:text-white-100">
					Models
				</button>
			</div>
		</div>

		<!-- Panel: Chat Completions -->
		<section data-rest-panel="chat" class="rest-tab-panel">
			<dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm mb-4">
				<dt class="text-black-700 dark:text-black-600">Endpoint</dt>
				<dd class="font-mono text-xs text-black-900 dark:text-white-100 break-all">POST { vm.ChatEndpoint }</dd>
			</dl>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — stateless</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "curl -X POST " + vm.ChatEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"Hello, who are you?\" }\n    ]\n  }'" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — pick a project</h3>
			<p class="text-xs text-black-700 dark:text-black-600 mb-2">Add <code class="font-mono">project</code> (a project id) to run in a specific project's folder + defaults. Omit it to use the channel's default project.</p>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "curl -X POST " + vm.ChatEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"project\": \"PROJECT_ID\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"Hello, who are you?\" }\n    ]\n  }'" }</code></pre>
			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — stateful (reuse session)</h3>
			<p class="text-xs text-black-700 dark:text-black-600 mb-2">Send the same <code class="font-mono">conversation</code> id on each call. Only the last user message is sent — wick remembers prior turns.</p>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "# Turn 1\ncurl -X POST " + vm.ChatEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"conversation\": \"chat-42\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"Remember the number 7.\" }\n    ]\n  }'\n\n# Turn 2 — same conversation, no history needed\ncurl -X POST " + vm.ChatEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"conversation\": \"chat-42\",\n    \"messages\": [\n      { \"role\": \"user\", \"content\": \"What number did I ask you to remember?\" }\n    ]\n  }'" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Python (OpenAI SDK)</h3>
			<p class="text-xs text-black-700 dark:text-black-600 mb-2">Pass <code class="font-mono">conversation</code> via <code class="font-mono">extra_body</code> to keep the wick session across calls.</p>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "from openai import OpenAI\n\nclient = OpenAI(\n    base_url=\"" + vm.APIBase + "\",\n    api_key=\"wick_pat_REPLACE_ME\",\n)\n\n# Stateless — resend history each call.\nresp = client.chat.completions.create(\n    model=\"claude\",\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n)\nprint(resp.choices[0].message.content)\n\n# Stateful — same conversation id reuses one wick session.\nresp = client.chat.completions.create(\n    model=\"claude\",\n    messages=[{\"role\": \"user\", \"content\": \"Remember 7.\"}],\n    extra_body={\"conversation\": \"chat-42\"},\n)" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Response shape</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto"><code>{ "{\n  \"id\": \"wick-rest-…\",\n  \"object\": \"chat.completion\",\n  \"created\": 1715000000,\n  \"model\": \"claude\",\n  \"choices\": [\n    {\n      \"index\": 0,\n      \"message\": { \"role\": \"assistant\", \"content\": \"…\" },\n      \"finish_reason\": \"stop\"\n    }\n  ]\n}" }</code></pre>
		</section>

		<!-- Panel: Responses -->
		<section data-rest-panel="responses" class="rest-tab-panel hidden">
			<dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm mb-4">
				<dt class="text-black-700 dark:text-black-600">Endpoint</dt>
				<dd class="font-mono text-xs text-black-900 dark:text-white-100 break-all">POST { vm.ResponsesEndpoint }</dd>
			</dl>
			<p class="text-xs text-black-700 dark:text-black-600 mb-3">
				OpenAI's newer Responses API surface. <code class="font-mono">input</code> accepts either a plain string or the OpenAI array form. To chain turns, pass the <code class="font-mono">id</code> returned by the previous response as <code class="font-mono">previous_response_id</code> — wick reuses the same underlying session.
			</p>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — single turn</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "curl -X POST " + vm.ResponsesEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"instructions\": \"You are a terse assistant.\",\n    \"input\": \"Summarize the wick project in one sentence.\"\n  }'" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl — chained turns</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "# Turn 1 — note the id in the response.\ncurl -X POST " + vm.ResponsesEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"input\": \"Remember the number 7.\"\n  }'\n\n# Turn 2 — pass previous_response_id from turn 1.\ncurl -X POST " + vm.ResponsesEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"model\": \"claude\",\n    \"input\": \"What number did I ask you to remember?\",\n    \"previous_response_id\": \"resp_<id-from-turn-1>\"\n  }'" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Python (OpenAI SDK)</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "from openai import OpenAI\n\nclient = OpenAI(\n    base_url=\"" + vm.APIBase + "\",\n    api_key=\"wick_pat_REPLACE_ME\",\n)\n\nfirst = client.responses.create(\n    model=\"claude\",\n    instructions=\"You are a terse assistant.\",\n    input=\"Remember the number 7.\",\n)\nprint(first.output_text)\n\nsecond = client.responses.create(\n    model=\"claude\",\n    input=\"What number did I ask you to remember?\",\n    previous_response_id=first.id,\n)\nprint(second.output_text)" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Response shape</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto"><code>{ "{\n  \"id\": \"resp_…\",\n  \"object\": \"response\",\n  \"created_at\": 1715000000,\n  \"status\": \"completed\",\n  \"model\": \"claude\",\n  \"previous_response_id\": null,\n  \"output\": [\n    {\n      \"type\": \"message\",\n      \"id\": \"msg_…\",\n      \"status\": \"completed\",\n      \"role\": \"assistant\",\n      \"content\": [\n        { \"type\": \"output_text\", \"text\": \"…\", \"annotations\": [] }\n      ]\n    }\n  ],\n  \"output_text\": \"…\",\n  \"usage\": { \"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0 }\n}" }</code></pre>
		</section>

		<!-- Panel: Models -->
		<section data-rest-panel="models" class="rest-tab-panel hidden">
			<dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm mb-4">
				<dt class="text-black-700 dark:text-black-600">Endpoint</dt>
				<dd class="font-mono text-xs text-black-900 dark:text-white-100 break-all">GET { vm.ModelsEndpoint }</dd>
			</dl>
			<p class="text-xs text-black-700 dark:text-black-600 mb-3">
				Lists every enabled wick provider as an OpenAI model object. Each enabled instance shows up once: default-seeded entries surface as the bare type (<code class="font-mono">claude</code>), named instances as <code class="font-mono">type/name</code> (<code class="font-mono">claude/work</code>). The chat / responses handlers validate the <code class="font-mono">model</code> field against this list.
			</p>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">curl</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "curl " + vm.ModelsEndpoint + " \\\n  -H 'Authorization: Bearer wick_pat_REPLACE_ME'" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Python (OpenAI SDK)</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto mb-5"><code>{ "from openai import OpenAI\n\nclient = OpenAI(\n    base_url=\"" + vm.APIBase + "\",\n    api_key=\"wick_pat_REPLACE_ME\",\n)\nfor m in client.models.list().data:\n    print(m.id, m.owned_by)" }</code></pre>

			<h3 class="text-sm font-semibold text-black-900 dark:text-white-100 mb-2">Response shape</h3>
			<pre class="rounded-lg border border-white-300 dark:border-navy-600 bg-white-200 dark:bg-navy-800 text-black-900 dark:text-white-100 text-xs font-mono p-3 overflow-x-auto"><code>{ "{\n  \"object\": \"list\",\n  \"data\": [\n    { \"id\": \"claude\",      \"object\": \"model\", \"created\": 1715000000, \"owned_by\": \"claude\" },\n    { \"id\": \"codex/work\",  \"object\": \"model\", \"created\": 1715000000, \"owned_by\": \"codex\" },\n    { \"id\": \"gemini\",      \"object\": \"model\", \"created\": 1715000000, \"owned_by\": \"gemini\" }\n  ]\n}" }</code></pre>
		</section>

		<script>
		(function(){
			var root = document.currentScript.parentElement;
			var btns = root.querySelectorAll('.rest-tab-btn');
			var panels = root.querySelectorAll('.rest-tab-panel');
			function activate(name){
				btns.forEach(function(b){
					var on = b.getAttribute('data-rest-tab') === name;
					b.classList.toggle('border-green-600', on);
					b.classList.toggle('text-green-600', on);
					b.classList.toggle('border-transparent', !on);
					b.classList.toggle('text-black-700', !on);
					b.classList.toggle('dark:text-black-600', !on);
				});
				panels.forEach(function(p){
					p.classList.toggle('hidden', p.getAttribute('data-rest-panel') !== name);
				});
			}
			btns.forEach(function(b){
				b.addEventListener('click', function(){ activate(b.getAttribute('data-rest-tab')); });
			});
		})();
		</script>
	</div>
}
