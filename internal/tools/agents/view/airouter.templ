package view

// AirouterVM feeds the thin-shell that hosts the AI Router SPA inside the
// standard agents layout. AssetURL is the hashed Vite bundle path resolved at
// boot via spaAssetURL("airouter"). The SPA fetches the router list + each
// router's status/toggles from /tools/agents/airouter/* itself.
type AirouterVM struct {
	Layout   AgentsLayoutVM
	Base     string // /tools/agents
	AssetURL string
}

// AirouterPage renders the AI Router SPA shell inside the agents chrome. The
// SPA reads data-base from the #app div, then drives the router switcher and
// per-router tabs client-side.
templ AirouterPage(vm AirouterVM) {
	@AgentsLayout(vm.Layout) {
		if vm.AssetURL == "" {
			<div class="p-8 text-sm text-rose-600 dark:text-rose-400">
				AI Router bundle not built yet. Run
				<code class="font-mono">npm --workspace=@wick-fe/agents-airouter run build</code>
				in <code class="font-mono">fe/</code> and refresh.
			</div>
		} else {
			<div
				id="app"
				data-base={ vm.Base }
				class="h-full"
			></div>
			<script type="module" src={ vm.AssetURL }></script>
		}
	}
}
