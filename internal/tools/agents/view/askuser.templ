package view

// AskUserCard is the empty inline card that JS hydrates when an
// ask_user request lands. Rendered once per session detail page;
// hidden by default. Lives above the composer so the user can
// answer without scrolling.
templ AskUserCard(base string) {
	<div
		id="ask-user-card"
		data-base={ base }
		class="hidden rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-3 space-y-3 shadow-sm"
	>
		<div class="flex items-start gap-3">
			<span class="mt-0.5 inline-flex h-2 w-2 shrink-0 rounded-full bg-amber-500 animate-pulse"></span>
			<div class="flex-1 min-w-0">
				<div class="text-xs font-medium uppercase tracking-wide text-amber-700 dark:text-amber-300">Agent is asking you</div>
				<div data-ask-question class="mt-1 text-sm text-black-900 dark:text-white-100 whitespace-pre-wrap break-words">—</div>
			</div>
		</div>
		<!-- Option buttons. JS rebuilds children per request. -->
		<div data-ask-options class="flex flex-wrap gap-2"></div>
		<!-- Freeform answer (JS unhides when allow_freeform=true). -->
		<form data-ask-freeform class="hidden flex flex-wrap gap-2 items-end">
			<input
				type="text"
				data-ask-text
				placeholder="Type your answer…"
				class="flex-1 min-w-0 rounded-lg border border-white-400 dark:border-navy-600 bg-white-100 dark:bg-navy-800 px-3 py-2 text-sm text-black-900 dark:text-white-100 placeholder-black-600 dark:placeholder-black-700 focus:border-green-500 focus:ring-2 focus:ring-green-200 dark:focus:ring-green-800 focus:outline-none"
			/>
			<button
				type="submit"
				class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors"
			>Send</button>
		</form>
		<!-- Validation / error line (JS shows on empty-required submit). -->
		<p data-ask-error class="hidden text-xs font-medium text-neg-400"></p>
	</div>
}

// AskUserFormModal is the overlay dialog JS hydrates when an
// ask_user request carries structured fields (e.g. a session config
// override form). Hidden by default; one ask is in flight per
// session at a time, so the body is rebuilt per request. Secret
// fields render as password inputs — their values go straight to
// the server via POST /answer and are never echoed into the chat.
templ AskUserFormModal(base string) {
	<div
		id="ask-form-modal"
		data-base={ base }
		class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black-900/50"
	>
		<!-- Flex column capped at the viewport so the footer (Submit/Next)
		     is ALWAYS visible — only the body scrolls. On phones it docks
		     to the bottom as a full-width sheet. -->
		<div class="flex w-full sm:max-w-lg max-h-[90vh] flex-col overflow-hidden rounded-t-xl sm:rounded-xl bg-white-100 dark:bg-navy-800 border border-white-300 dark:border-navy-600 shadow-xl">
			<!-- Header: step question + progress (X of Y, JS-driven). -->
			<div class="flex items-start gap-3 px-5 pt-5 sm:px-6 sm:pt-6 shrink-0">
				<span class="mt-1 inline-flex h-2 w-2 shrink-0 rounded-full bg-amber-500 animate-pulse"></span>
				<div class="flex-1 min-w-0">
					<div data-ask-form-question class="text-sm font-medium text-black-900 dark:text-white-100 whitespace-pre-wrap break-words">—</div>
					<div data-ask-form-help class="mt-1 text-xs text-black-700 dark:text-black-600"></div>
				</div>
				<div data-ask-form-progress class="shrink-0 text-xs font-medium text-black-700 dark:text-black-600"></div>
			</div>
			<!-- Body: the current step's field — the only scrolling region. -->
			<div data-ask-form-fields class="flex-1 overflow-y-auto px-5 py-4 sm:px-6"></div>
			<!-- Error line (JS shows on empty-required submit). -->
			<p data-ask-form-error class="hidden px-5 sm:px-6 text-xs font-medium text-neg-400"></p>
			<!-- Footer: skip + prev/next/submit. Always visible (shrink-0). -->
			<div class="flex items-center justify-between gap-2 px-5 pb-5 pt-3 sm:px-6 sm:pb-6 shrink-0 border-t border-white-200 dark:border-navy-700">
				<button
					type="button"
					data-ask-form-skip
					class="rounded-lg px-3 py-2 text-sm font-medium text-black-700 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors"
				>Skip</button>
				<div class="flex items-center gap-2">
					<button
						type="button"
						data-ask-form-prev
						class="hidden rounded-lg border border-white-400 dark:border-navy-600 px-4 py-2 text-sm font-medium text-black-800 dark:text-white-200 hover:bg-white-200 dark:hover:bg-navy-700 transition-colors"
					>Back</button>
					<button
						type="button"
						data-ask-form-next
						class="rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors"
					>Next</button>
				</div>
			</div>
		</div>
	</div>
}
