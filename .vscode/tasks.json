{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "templ: watch",
      "type": "shell",
      "command": "templ generate --watch",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "css: watch",
      "type": "shell",
      "command": "bin/tailwindcss -i web/src/input.css -o web/public/css/app.css --watch",
      "windows": {
        "command": "bin/tailwindcss.exe -i web/src/input.css -o web/public/css/app.css --watch"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "templ: generate",
      "type": "shell",
      "command": "templ generate ./...",
      "problemMatcher": []
    },
    {
      "label": "css: build",
      "type": "shell",
      "command": "bin/tailwindcss -i web/src/input.css -o web/public/css/app.css",
      "windows": {
        "command": "bin/tailwindcss.exe -i web/src/input.css -o web/public/css/app.css"
      },
      "problemMatcher": []
    },
    {
      "label": "lab: build",
      "type": "shell",
      "command": "go build -o bin/wick-lab ./cmd/lab",
      "windows": {
        "command": "go build -o bin/wick-lab.exe ./cmd/lab"
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "gate: build",
      "type": "shell",
      "command": "go build -o bin/wick-lab-gate ./cmd/gate",
      "windows": {
        "command": "go build -o bin/wick-lab-gate.exe ./cmd/gate"
      },
      "problemMatcher": ["$go"]
    },
    {
      // Standalone task — run via Run Task whenever you change a plugin's
      // source. Builds EVERY connector plugin for the host OS/arch and drops
      // each unzipped { binary, plugin.json } into wick-lab's plugin dir
      // (~/.wick-lab/plugins/connectors/<name>/). The already-running lab's
      // hot-reload poller picks them up within ~5s — no server restart needed.
      "label": "plugin: build all → lab",
      "type": "shell",
      "command": "bash",
      "args": [".vscode/build-plugins-to-lab.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"]
    },
    {
      // Build ONE connector plugin (picked from a dropdown) → lab, so iterating
      // on a single connector doesn't rebuild every plugin. The picker options
      // live in the "pluginName" input below — add a folder under
      // plugins/connector/ AND a line there to make it selectable.
      "label": "plugin: build ONE → lab",
      "type": "shell",
      "command": "bash",
      "args": [".vscode/build-one-plugin-to-lab.sh", "${input:pluginName}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"]
    },
    {
      // preLaunchTask for the "plugin debug (loki)" launch config. Installs the
      // debugged plugin (from WICK_DEBUG_PLUGIN in .env) into wick-lab so it
      // registers + shows in the connector list before dlv runs it. See
      // install-debug-target-to-lab.sh.
      "label": "plugin: install debug target → lab",
      "type": "shell",
      "command": "bash",
      "args": [".vscode/install-debug-target-to-lab.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"]
    },
    {
      // Standalone task — uninstall every connector plugin from wick-lab. The
      // running lab's poller drops them within ~5s; no server restart needed.
      "label": "plugin: clear lab",
      "type": "shell",
      "command": "bash",
      "args": [".vscode/clear-plugins-from-lab.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "fe: install",
      "type": "shell",
      "command": "npm install --no-audit --no-fund",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "problemMatcher": []
    },
    {
      "label": "fe: build",
      "type": "shell",
      "command": "npm run build:workflow",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "problemMatcher": []
    },
    {
      "label": "fe: dev",
      "type": "shell",
      "command": "npm run dev:workflow",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "ready in"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "debug: prep",
      "dependsOn": ["templ: generate", "css: build", "gate: build"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "debug: prep with fe",
      "dependsOn": ["templ: generate", "css: build", "gate: build", "fe: build"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "debug: prep + fe dev",
      "dependsOn": ["templ: generate", "css: build", "gate: build", "fe: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "dev",
      "dependsOn": ["css: watch", "templ: watch", "gate: build"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      // Dropdown for "plugin: build ONE → lab". Keep in sync with the folders
      // under plugins/connector/ (excluding _template).
      "id": "pluginName",
      "type": "pickString",
      "description": "Which connector plugin to rebuild into wick-lab?",
      "options": [
        "bitbucket",
        "github",
        "google_workspace",
        "httpbin",
        "loki",
        "phoenix",
        "playwright_browser"
      ]
    }
  ]
}
