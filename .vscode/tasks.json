{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "templ: watch",
      "type": "shell",
      "command": "templ generate --watch",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "css: watch",
      "type": "shell",
      "command": "bin/tailwindcss -i web/src/input.css -o web/public/css/app.css --watch",
      "windows": {
        "command": "bin/tailwindcss.exe -i web/src/input.css -o web/public/css/app.css --watch"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "templ: generate",
      "type": "shell",
      "command": "templ generate ./...",
      "problemMatcher": []
    },
    {
      "label": "css: build",
      "type": "shell",
      "command": "bin/tailwindcss -i web/src/input.css -o web/public/css/app.css",
      "windows": {
        "command": "bin/tailwindcss.exe -i web/src/input.css -o web/public/css/app.css"
      },
      "problemMatcher": []
    },
    {
      "label": "lab: build",
      "type": "shell",
      "command": "go build -o bin/wick-lab ./cmd/lab",
      "windows": {
        "command": "go build -o bin/wick-lab.exe ./cmd/lab"
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "gate: build",
      "type": "shell",
      "command": "go build -o bin/wick-lab-gate ./cmd/gate",
      "windows": {
        "command": "go build -o bin/wick-lab-gate.exe ./cmd/gate"
      },
      "problemMatcher": ["$go"]
    },
    {
      // Build EVERY connector plugin for the host OS/arch and drop each unzipped
      // { binary, plugin.json } into wick-lab's plugin dir
      // (~/.wick-lab/plugins/connectors/<name>/), where the running lab scans.
      // Builds from current source via the dev `wick` CLI, so manifests reflect
      // the latest code (e.g. new Meta.DefaultTags) without cutting a release.
      // The running lab's hot-reload poller registers them within ~5s.
      "label": "plugin: build all → lab",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "set -euo pipefail; root=\"$HOME/.wick-lab/plugins/connectors\"; tmp=\"$(mktemp -d)\"; cli=\"$tmp/wick\"; go build -o \"$cli\" .; (cd plugins && \"$cli\" plugin build --kind connector --all-plugins --output \"$tmp\"); mkdir -p \"$root\"; for zip in \"$tmp\"/*.zip; do [ -e \"$zip\" ] || { echo 'no plugins built'; break; }; base=$(basename \"$zip\"); name=\"${base%%-*}\"; dest=\"$root/$name\"; rm -rf \"$dest\"; mkdir -p \"$dest\"; unzip -oq \"$zip\" -d \"$dest\"; echo \"installed $name -> $dest\"; done"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"]
    },
    {
      // Wipe every installed connector plugin from wick-lab so the next launch
      // starts clean. The running lab's poller drops them within ~5s.
      "label": "plugin: clear lab",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "root=\"$HOME/.wick-lab/plugins/connectors\"; rm -rf \"$root\"; mkdir -p \"$root\"; echo \"cleared $root\""
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "fe: install",
      "type": "shell",
      "command": "npm install --no-audit --no-fund",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "problemMatcher": []
    },
    {
      "label": "fe: build",
      "type": "shell",
      "command": "npm run build:workflow",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "problemMatcher": []
    },
    {
      "label": "fe: dev",
      "type": "shell",
      "command": "npm run dev:workflow",
      "options": { "cwd": "${workspaceFolder}/fe" },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [{ "regexp": "." }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "ready in"
          }
        }
      ],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "debug: prep",
      "dependsOn": ["templ: generate", "css: build", "gate: build"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "debug: prep with fe",
      "dependsOn": ["templ: generate", "css: build", "gate: build", "fe: build"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      // debug: prep + build every plugin into the lab plugin dir. preLaunchTask
      // for the "wicklab + plugins" launch config.
      "label": "debug: prep + plugins",
      "dependsOn": ["templ: generate", "css: build", "gate: build", "plugin: build all → lab"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "debug: prep + fe dev",
      "dependsOn": ["templ: generate", "css: build", "gate: build", "fe: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "dev",
      "dependsOn": ["css: watch", "templ: watch", "gate: build"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
