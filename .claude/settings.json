{
  "permissions": {
    "allow": [
      "Bash(templ generate:*)",
      "Bash(go build:*)",
      "Skill(tool-module)",
      "Skill(tool-module:*)",
      "Bash(ls Makefile)",
      "Skill(design-system)",
      "Skill(design-system:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-docs-synced.sh",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
