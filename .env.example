# Copy this file to .env and edit the values.
# Every variable has a working default — the app boots without any configuration.
# Runtime knobs (branding, SSO, OAuth) are edited from /admin/configs, not here.

# ── Server ───────────────────────────────────────────────────────────────────
# HTTP listen port. Default: 9425 ("WICK" on T9 keypad — picked to
# avoid collisions with common dev tools (3000, 5173).
PORT=9425

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (wick.db in the project root) — no setup needed.
# For PostgreSQL, uncomment and fill in the connection string below.
DATABASE_URL=

# PostgreSQL example:
# DATABASE_URL=postgres://user:password@localhost:5432/myapp?sslmode=disable

# ── App ──────────────────────────────────────────────────────────────────────
# App name shown in the UI. Only used on first boot to seed the database.
# After that, change it from /admin/configs — the DB value always wins.
APP_NAME=My App

# App URL used for SSO callbacks and absolute links. Only used on first boot.
# Change it from /admin/configs after the first run.
APP_URL=http://localhost:9425

# Extra URLs that may reach the admin/host allowlist alongside APP_URL.
# Comma-separated. Overrides the allowed_origins kvlist in /admin/variables
# at read time — handy for bootstrapping LAN/Termux access before you can
# open the admin UI. Example:
# ALLOWED_ORIGINS=http://192.168.1.42:9425,http://10.0.0.5:9425
ALLOWED_ORIGINS=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails automatically granted admin role on first login.
# Env-only by design — admins cannot remove themselves from this list via the UI.
APP_ADMIN_EMAILS=admin@example.com

# Seed for the admin password. Leave blank (or as "admin") to let wick
# generate a 5-word passphrase on first boot — saved to
# ~/.<app>/INITIAL_CREDENTIALS.txt. The admin is forced through
# /profile/setup at first login to rotate it; once admin_password_changed
# is set, this env is ignored.
APP_ADMIN_PASSWORD=

# ── Agents gate (dev only) ───────────────────────────────────────────────────
# Path to the wick-gate binary used by claude's PreToolUse hook for
# command-approval. In production wick embeds the binary via //go:embed
# and extracts it on demand — leave this unset. For local dev (go run /
# VSCode F5) the embed is empty, so set this to a freshly-built binary:
#   go build -o bin/wick-gate.exe ./cmd/wick-gate
# WICK_GATE_BIN=./bin/wick-gate.exe

# ── Debug a connector plugin (dev only) ──────────────────────────────────────
# Connector plugins run as separate gRPC subprocesses wick-lab spawns, so a
# plain wicklab launch can't breakpoint their code. The "lab + plugin debug"
# launch compound debugs one: dlv runs the plugin, and wick-lab ATTACHES to it
# (dialing its reattach file) instead of spawning its own child.
#
# WICK_DEBUG_PLUGIN = the plugin folder/key to debug. wick-lab uses it to find
# the conventional reattach file bin/plugin-<key>.reattach.json and attach when
# it's live (a dial check — a stopped debugger falls back to a normal spawn, so
# leaving this set is harmless when you're not debugging). It must match the
# hardcoded folder in the "plugin debug (…)" launch config.
#   bitbucket | github | google_workspace | httpbin | loki | phoenix | playwright_browser
# Leave blank to never attempt reattach.
WICK_DEBUG_PLUGIN=

# Optional explicit override (key=path[,key=path...]) if you don't use the
# conventional bin/plugin-<key>.reattach.json location:
# WICK_PLUGIN_REATTACH=loki=/abs/path/to/reattach.json
