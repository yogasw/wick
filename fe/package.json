{
  "name": "wick-fe",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "agents/*",
    "common/*"
  ],
  "scripts": {
    "build": "npm --workspaces --if-present run build",
    "dev": "npm --workspaces --if-present run build:watch",
    "check": "npm --workspaces --if-present run check",
    "test": "npm --workspaces --if-present run test:unit",
    "e2e": "npm --workspaces --if-present run test:e2e",
    "dev:workflow": "npm --workspace=@wick-fe/agents-workflow run dev",
    "dev:scm": "npm --workspace=@wick-fe/agents-scm run dev",
    "dev:conversation": "npm --workspace=@wick-fe/agents-conversation run dev",
    "dev:skills": "npm --workspace=@wick-fe/agents-skills run dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.10.0",
    "svelte": "^5.1.0",
    "svelte-check": "^4.1.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/svelte": "^5.2.4"
  }
}
