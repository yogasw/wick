{
  "name": "@wick-fe/agents-workflow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint:gotchas": "node scripts/check-svelte-gotchas.mjs",
    "prebuild": "npm run lint:gotchas",
    "prebuild:watch": "npm run lint:gotchas",
