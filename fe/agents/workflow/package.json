    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@wick-fe/common-api": "*",
    "@wick-fe/common-stores": "*",
    "@wick-fe/common-ui": "*",
    "ace-builds": "^1.44.0"
  }
}
